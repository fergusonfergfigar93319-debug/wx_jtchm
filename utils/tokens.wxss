/* ========== Design Tokens / Utility classes ========== */
/* 健康饮食管理小程序 UI 规范 - 现代简约·清新健康·轻量治愈 */

/* CSS自定义属性 - 健康饮食管理设计系统 */
:root {
  /* 主色调（品牌色）- 略降饱和，偏青绿，更耐看 */
  --color-primary: #2DBA8E;
  --color-primary-light: #5ED4B0;
  --color-primary-dark: #1FA67A;
  
  /* 辅助色 - 数据蓝、图表、进度 */
  --color-secondary: #58B0E7;      /* 数据蓝 */
  --color-secondary-light: #8AC9F0; /* 数据蓝浅色 */
  --color-secondary-dark: #3B9BD4;  /* 数据蓝深色 */
  
  /* 功能色 - 高亮强调（按钮、打卡、行动点） */
  --color-accent: #FF9F66;         /* 高亮强调 */
  --color-accent-light: #FFB88C;   /* 强调浅色 */
  --color-accent-dark: #FF8640;    /* 强调深色 */
  
  /* 暖色 - 警示 */
  --color-warm: #FF7B54;           /* 警示橙 - 超标提醒、热量警告 */
  --color-warm-light: #FF9A7A;     /* 警示橙浅色 */
  --color-warm-dark: #F5623A;      /* 警示橙深色 */
  /* 氛围色：低饱和杏/紫，仅作点缀 */
  --color-peach-mist: #FAF8F6;
  --color-peach-soft: #F3E8E0;
  --color-lavender: #7C6BBF;
  --color-lavender-soft: #C9C2E8;
  --color-lavender-mist: #F7F6FC;
  
  /* 语义色 */
  --color-success: #2ECC71;        /* 成功绿 - 完成、达标 */
  --color-warning: #FF9F66;        /* 警告 - 沿用强调色 */
  --color-danger: #FF7B54;         /* 危险 - 警示橙 */
  --color-info: #58B0E7;           /* 信息 - 数据蓝 */
  
  /* 中性色 */
  --color-bg-page: #F8FAFC;
  --color-bg-page-alt: #F1F5F9;
  --color-bg-card: #FFFFFF;
  --color-bg-muted: #F1F5F9;
  
  --color-text-primary: #0F172A;
  --color-text-secondary: #475569;
  --color-text-tertiary: #94A3B8;
  --color-text-inverse: #FFFFFF;   /* 反色文字 */
  
  --color-border-light: #E2E8F0;
  --color-border-medium: #CBD5E1;
  --color-border-heavy: #64748B;
  
  /* 阴影：中性 slate，层次柔和 */
  --shadow-sm: 0 1rpx 4rpx rgba(15, 23, 42, 0.04);
  --shadow-md: 0 4rpx 20rpx rgba(15, 23, 42, 0.06);
  --shadow-lg: 0 8rpx 32rpx rgba(15, 23, 42, 0.07);
  --shadow-xl: 0 16rpx 48rpx rgba(15, 23, 42, 0.08);
  --shadow-inner: inset 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  
  /* 圆角系统 - 卡片16px 按钮12~16px */
  --radius-xs: 8rpx;   /* 4px */
  --radius-sm: 24rpx;  /* 12px - 按钮 */
  --radius-md: 28rpx;  /* 14px */
  --radius-lg: 32rpx;  /* 16px - 卡片 */
  --radius-xl: 36rpx;  /* 18px */
  --radius-2xl: 40rpx; /* 20px */
  --radius-full: 9999rpx;
  
  /* 间距系统 (基于8px网格) */
  --space-1: 4rpx;    /* 2px */
  --space-2: 8rpx;    /* 4px */
  --space-3: 12rpx;   /* 6px */
  --space-4: 16rpx;   /* 8px */
  --space-5: 20rpx;   /* 10px */
  --space-6: 24rpx;   /* 12px */
  --space-8: 32rpx;   /* 16px */
  --space-10: 40rpx;  /* 20px */
  --space-12: 48rpx;  /* 24px */
  --space-16: 64rpx;  /* 32px */
  --space-20: 80rpx;  /* 40px */
  
  /* 字体系统 */
  --font-family-base: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  --font-family-mono: 'SF Mono', Monaco, 'Cascadia Code', 'Roboto Mono', monospace;
  
  --font-size-xs: 20rpx;   /* 10px */
  --font-size-sm: 22rpx;   /* 11px */
  --font-size-base: 28rpx; /* 14px */
  --font-size-lg: 32rpx;   /* 16px */
  --font-size-xl: 36rpx;   /* 18px */
  --font-size-2xl: 40rpx;  /* 20px */
  --font-size-3xl: 48rpx;  /* 24px */
  --font-size-4xl: 56rpx;  /* 28px */
  
  --font-weight-light: 300;
  --font-weight-normal: 400;
  --font-weight-medium: 500;
  --font-weight-semibold: 600;
  --font-weight-bold: 700;
  --font-weight-extrabold: 800;
  
  --line-height-tight: 1.25;
  --line-height-normal: 1.5;
  --line-height-relaxed: 1.75;
  
  /* 动画和过渡 */
  --transition-fast: 150ms cubic-bezier(0.4, 0, 0.2, 1);
  --transition-normal: 250ms cubic-bezier(0.4, 0, 0.2, 1);
  --transition-slow: 350ms cubic-bezier(0.4, 0, 0.2, 1);
  --transition-bounce: 400ms cubic-bezier(0.34, 1.56, 0.64, 1);
  /* 全站统一：页面进入 / Tab 切换（偏弹性、少眩晕） */
  --ease-page-enter: cubic-bezier(0.22, 1, 0.36, 1);
  --ease-tap: cubic-bezier(0.34, 1.56, 0.64, 1);
  --duration-page-enter: 420ms;
  --duration-tap: 220ms;
  
  /* 层级 */
  --z-index-dropdown: 1000;
  --z-index-sticky: 1020;
  --z-index-fixed: 1030;
  --z-index-modal-backdrop: 1040;
  --z-index-modal: 1050;
  --z-index-popover: 1060;
  --z-index-tooltip: 1070;
  --z-index-toast: 1080;

  /* ===== Neo：中性底 + 青绿点缀（现代简约） ===== */
  --neo-bg-0: #F8FAFC;
  --neo-bg-1: #F1F5F9;
  --neo-glass: rgba(255, 255, 255, 0.92);
  --neo-glass-2: rgba(255, 255, 255, 0.78);
  --neo-border: rgba(15, 23, 42, 0.06);
  --neo-text: rgba(15, 23, 42, 0.92);
  --neo-text-2: rgba(15, 23, 42, 0.72);
  --neo-text-3: rgba(15, 23, 42, 0.52);
  --neo-neon-a: #64748B;
  --neo-neon-b: #94A3B8;
  --neo-neon-c: #CBD5E1;
  --neo-shadow: 0 8rpx 32rpx rgba(15, 23, 42, 0.07);
  --neo-shadow-soft: 0 4rpx 24rpx rgba(15, 23, 42, 0.045);
  --tabbar-active: #0F9B7A;
  --tabbar-active-bg: rgba(15, 155, 122, 0.12);
  --tabbar-active-ring: rgba(15, 155, 122, 0.14);
  --tabbar-glass: rgba(255, 255, 255, 0.96);
}

/* 暗色模式变量 */
.dark-mode {
  --color-bg-page: #111827;        /* 深色页面背景 */
  --color-bg-card: #1F2937;        /* 深色卡片背景 */
  --color-bg-muted: #374151;       /* 深色次要背景 */
  
  --color-text-primary: #F9FAFB;   /* 深色模式主要文字 */
  --color-text-secondary: #D1D5DB; /* 深色模式次要文字 */
  --color-text-tertiary: #9CA3AF;  /* 深色模式三级文字 */
  --color-text-inverse: #1F2937;   /* 深色模式反色文字 */
  
  --color-border-light: #374151;   /* 深色模式浅边框 */
  --color-border-medium: #4B5563;  /* 深色模式中等边框 */
  --color-border-heavy: #6B7280;   /* 深色模式深边框 */
  
  --shadow-sm: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
  --shadow-md: 0 6rpx 16rpx rgba(0, 0, 0, 0.35);
  --shadow-lg: 0 12rpx 32rpx rgba(0, 0, 0, 0.4);
  --shadow-xl: 0 20rpx 60rpx rgba(0, 0, 0, 0.45);
  --shadow-inner: inset 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

