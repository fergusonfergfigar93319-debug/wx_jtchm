/* 现代卡片样式 */
.u-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: var(--space-6);
  box-shadow: var(--shadow-md);
  border: 1rpx solid var(--color-border-light);
  transition: all var(--transition-normal);
}

.u-card:hover {
  box-shadow: var(--shadow-lg);
  transform: translateY(-2rpx);
}

.u-card:active {
  transform: translateY(0);
}

/* 现代按钮样式 */
.u-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-4) var(--space-6);
  border-radius: var(--radius-md);
  font-weight: var(--font-weight-semibold);
  font-size: var(--font-size-base);
  line-height: var(--line-height-normal);
  text-align: center;
  cursor: pointer;
  transition: all var(--transition-fast);
  border: 1rpx solid transparent;
  user-select: none;
  white-space: nowrap;
}

.u-btn-primary {
  background: var(--color-primary);
  color: white;
}

.u-btn-primary:hover {
  background: var(--color-primary-dark);
  transform: translateY(-1rpx);
  box-shadow: var(--shadow-md);
}

.u-btn-primary:active {
  transform: translateY(0);
}

.u-btn-secondary {
  background: var(--color-secondary);
  color: white;
}

.u-btn-secondary:hover {
  background: var(--color-secondary-dark);
  transform: translateY(-1rpx);
  box-shadow: var(--shadow-md);
}

.u-btn-outline {
  background: transparent;
  color: var(--color-text-primary);
  border-color: var(--color-border-medium);
}

.u-btn-outline:hover {
  background: var(--color-bg-muted);
  border-color: var(--color-border-heavy);
}

.u-btn-ghost {
  background: transparent;
  color: var(--color-text-primary);
}

.u-btn-ghost:hover {
  background: var(--color-bg-muted);
}

/* 现代输入框样式 */
.u-input {
  width: 100%;
  padding: var(--space-4) var(--space-5);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--color-border-medium);
  background: var(--color-bg-card);
  color: var(--color-text-primary);
  font-size: var(--font-size-base);
  transition: all var(--transition-fast);
}

.u-input:focus {
  outline: none;
  border-color: var(--color-primary);
  box-shadow: 0 0 0 3rpx rgba(52, 211, 153, 0.1);
}

.u-input::placeholder {
  color: var(--color-text-tertiary);
}

/* 现代标签样式 */
.u-label {
  display: block;
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-secondary);
  margin-bottom: var(--space-2);
}

/* 现代徽章样式 */
.u-badge {
  display: inline-flex;
  align-items: center;
  padding: var(--space-1) var(--space-3);
  border-radius: var(--radius-full);
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-medium);
  line-height: 1;
}

.u-badge-primary {
  background: var(--color-primary);
  color: white;
}

.u-badge-secondary {
  background: var(--color-secondary);
  color: white;
}

.u-badge-success {
  background: var(--color-success);
  color: white;
}

.u-badge-warning {
  background: var(--color-warning);
  color: white;
}

.u-badge-danger {
  background: var(--color-danger);
  color: white;
}

/* 现代头像样式 */
.u-avatar {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-full);
  overflow: hidden;
  background: var(--color-bg-muted);
}

.u-avatar-sm {
  width: 32rpx;
  height: 32rpx;
  font-size: var(--font-size-xs);
}

.u-avatar-md {
  width: 48rpx;
  height: 48rpx;
  font-size: var(--font-size-sm);
}

.u-avatar-lg {
  width: 64rpx;
  height: 64rpx;
  font-size: var(--font-size-base);
}

.u-avatar-xl {
  width: 80rpx;
  height: 80rpx;
  font-size: var(--font-size-lg);
}

/* 现代分隔线 */
.u-divider {
  height: 1rpx;
  background: var(--color-border-light);
  margin: var(--space-6) 0;
  border: none;
}

.u-divider-vertical {
  width: 1rpx;
  height: auto;
  margin: 0 var(--space-6);
}

/* 现代加载指示器 */
.u-loading {
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.u-loading-spinner {
  width: 24rpx;
  height: 24rpx;
  border: 2rpx solid var(--color-border-light);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

.u-loading-dots {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
}

/* 使用类选择器：自定义组件 wxss 不允许标签选择器（如 span） */
.u-loading-dots .u-loading-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: var(--color-primary);
  animation: pulse 1.5s ease-in-out infinite;
}

.u-loading-dots .u-loading-dot:nth-child(2) {
  animation-delay: 0.2s;
}

.u-loading-dots .u-loading-dot:nth-child(3) {
  animation-delay: 0.4s;
}

/* 现代工具提示 */
.u-tooltip {
  position: relative;
}

.u-tooltip:hover::before {
  content: attr(data-tooltip);
  position: absolute;
  bottom: 100%;
  left: 50%;
  transform: translateX(-50%);
  padding: var(--space-2) var(--space-3);
  background: var(--color-bg-card);
  color: var(--color-text-primary);
  font-size: var(--font-size-xs);
  border-radius: var(--radius-sm);
  box-shadow: var(--shadow-lg);
  white-space: nowrap;
  z-index: var(--z-index-tooltip);
  pointer-events: none;
}

/* 现代滚动条样式 */
.u-scrollbar {
  scrollbar-width: thin;
  scrollbar-color: var(--color-border-medium) transparent;
}

.u-scrollbar::-webkit-scrollbar {
  width: 6rpx;
  height: 6rpx;
}

.u-scrollbar::-webkit-scrollbar-track {
  background: transparent;
}

.u-scrollbar::-webkit-scrollbar-thumb {
  background: var(--color-border-medium);
  border-radius: var(--radius-full);
}

.u-scrollbar::-webkit-scrollbar-thumb:hover {
  background: var(--color-border-heavy);
}

/* 现代网格系统 */
.u-grid-cols-1 { grid-template-columns: repeat(1, minmax(0, 1fr)); }
.u-grid-cols-2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
.u-grid-cols-3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }
.u-grid-cols-4 { grid-template-columns: repeat(4, minmax(0, 1fr)); }
.u-grid-cols-5 { grid-template-columns: repeat(5, minmax(0, 1fr)); }
.u-grid-cols-6 { grid-template-columns: repeat(6, minmax(0, 1fr)); }

.u-col-span-1 { grid-column: span 1 / span 1; }
.u-col-span-2 { grid-column: span 2 / span 2; }
.u-col-span-3 { grid-column: span 3 / span 3; }
.u-col-span-4 { grid-column: span 4 / span 4; }
.u-col-span-5 { grid-column: span 5 / span 5; }
.u-col-span-6 { grid-column: span 6 / span 6; }
.u-col-span-full { grid-column: 1 / -1; }

/* 现代响应式容器 */
.u-container {
  width: 100%;
  margin-left: auto;
  margin-right: auto;
  padding-left: var(--space-6);
  padding-right: var(--space-6);
}

@media (min-width: 768rpx) {
  .u-container {
    max-width: 750rpx;
  }
}

@media (min-width: 1024rpx) {
  .u-container {
    max-width: 1000rpx;
  }
}

@media (min-width: 1280rpx) {
  .u-container {
    max-width: 1200rpx;
  }
}

/* 性能优化类 */
.u-will-change-transform { will-change: transform; }
.u-will-change-opacity { will-change: opacity; }
.u-will-change-scroll { will-change: scroll-position; }

.u-contain-paint { contain: paint; }
.u-contain-layout { contain: layout; }
.u-contain-content { contain: content; }
.u-contain-strict { contain: strict; }

/* 打印样式 */
@media print {
  .u-print-hidden { display: none !important; }
  .u-print-block { display: block !important; }
  .u-print-inline { display: inline !important; }
  .u-print-inline-block { display: inline-block !important; }
