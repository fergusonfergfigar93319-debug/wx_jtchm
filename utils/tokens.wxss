/* 动画关键帧 - 现代微交互 */
@keyframes fade-in {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes fade-out {
  from { opacity: 1; }
  to { opacity: 0; }
}

@keyframes slide-in-up {
  from { transform: translateY(20rpx); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

@keyframes slide-in-down {
  from { transform: translateY(-20rpx); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

@keyframes slide-in-left {
  from { transform: translateX(-20rpx); opacity: 0; }
  to { transform: translateX(0); opacity: 1; }
}

@keyframes slide-in-right {
  from { transform: translateX(20rpx); opacity: 0; }
  to { transform: translateX(0); opacity: 1; }
}

@keyframes scale-in {
  from { transform: scale(0.9); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}

@keyframes scale-out {
  from { transform: scale(1); opacity: 1; }
  to { transform: scale(0.9); opacity: 0; }
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

@keyframes ping {
  75%, 100% { transform: scale(2); opacity: 0; }
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

/* 动画工具类 */
.u-animate-fade-in { animation: fade-in var(--transition-normal); }
.u-animate-fade-out { animation: fade-out var(--transition-normal); }
.u-animate-slide-in-up { animation: slide-in-up var(--transition-normal); }
.u-animate-slide-in-down { animation: slide-in-down var(--transition-normal); }
.u-animate-slide-in-left { animation: slide-in-left var(--transition-normal); }
.u-animate-slide-in-right { animation: slide-in-right var(--transition-normal); }
.u-animate-scale-in { animation: scale-in var(--transition-bounce); }
.u-animate-scale-out { animation: scale-out var(--transition-normal); }
.u-animate-bounce { animation: bounce 1s infinite; }
.u-animate-pulse { animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite; }
.u-animate-spin { animation: spin 1s linear infinite; }
.u-animate-ping { animation: ping 1s cubic-bezier(0, 0, 0.2, 1) infinite; }
.u-animate-float { animation: float 3s ease-in-out infinite; }

