  padding: 0;
  margin: -1rpx;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border: 0;
}

.u-focus-visible:focus-visible {
  outline: 2rpx solid var(--color-primary);
  outline-offset: 2rpx;
}

