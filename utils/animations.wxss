/* utils/animations.wxss - 现代动画系统 */
/* 2025+ 现代动画库 - 支持CSS变量、GPU加速、性能优化 */

/* ========== 基础动画关键帧 ========== */

/* 淡入淡出动画 */
@keyframes fade-in {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes fade-out {
  from { opacity: 1; }
  to { opacity: 0; }
}

@keyframes fade-in-up {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fade-in-down {
  from {
    opacity: 0;
    transform: translateY(-20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fade-in-left {
  from {
    opacity: 0;
    transform: translateX(-20rpx);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

@keyframes fade-in-right {
  from {
    opacity: 0;
    transform: translateX(20rpx);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

/* 缩放动画 */
@keyframes scale-in {
  from {
    opacity: 0;
    transform: scale(0.9);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

@keyframes scale-out {
  from {
    opacity: 1;
    transform: scale(1);
  }
  to {
    opacity: 0;
    transform: scale(0.9);
  }
}

@keyframes scale-in-bounce {
  0% {
    opacity: 0;
    transform: scale(0.3);
  }
  50% {
    opacity: 1;
    transform: scale(1.05);
  }
  70% {
    transform: scale(0.95);
  }
  100% {
    opacity: 1;
    transform: scale(1);
  }
}

/* 旋转动画 */
@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

@keyframes spin-reverse {
  from { transform: rotate(360deg); }
  to { transform: rotate(0deg); }
}

@keyframes spin-slow {
  from { transform: rotate(0deg); }
  to { transform: rotate(180deg); }
}

/* 弹跳动画 */
@keyframes bounce {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-10rpx);
  }
}

@keyframes bounce-sm {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-5rpx);
  }
}

@keyframes bounce-lg {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-15rpx);
  }
}

/* 脉动动画 */
@keyframes pulse {
  0%, 100% {
    opacity: 1;
  }
  50% {
    opacity: 0.5;
  }
}

@keyframes pulse-soft {
  0%, 100% {
    opacity: 1;
  }
  50% {
    opacity: 0.8;
  }
}

@keyframes pulse-strong {
  0%, 100% {
    opacity: 1;
  }
  50% {
    opacity: 0.3;
  }
}

/* 浮动动画 */
@keyframes float {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-10rpx);
  }
}

@keyframes float-slow {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-5rpx);
  }
}

@keyframes float-fast {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-15rpx);
  }
}

/* 滑动动画 */
@keyframes slide-in-up {
  from {
    transform: translateY(100%);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

@keyframes slide-in-down {
  from {
    transform: translateY(-100%);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

@keyframes slide-in-left {
  from {
    transform: translateX(-100%);
    opacity: 0;
  }
  to {
    transform: translateX(0);
    opacity: 1;
  }
}

@keyframes slide-in-right {
  from {
    transform: translateX(100%);
    opacity: 0;
  }
  to {
    transform: translateX(0);
    opacity: 1;
  }
}

/* 滑动退出动画 */
@keyframes slide-out-up {
  from {
    transform: translateY(0);
    opacity: 1;
  }
  to {
    transform: translateY(-100%);
    opacity: 0;
  }
}

@keyframes slide-out-down {
  from {
    transform: translateY(0);
    opacity: 1;
  }
  to {
    transform: translateY(100%);
    opacity: 0;
  }
}

@keyframes slide-out-left {
  from {
    transform: translateX(0);
    opacity: 1;
  }
  to {
    transform: translateX(-100%);
    opacity: 0;
  }
}

@keyframes slide-out-right {
  from {
    transform: translateX(0);
    opacity: 1;
  }
  to {
    transform: translateX(100%);
    opacity: 0;
  }
}

/* ========== 现代特效动画 ========== */

/* 流光效果 */
@keyframes shine {
  0% {
    background-position: -100% 0;
  }
  100% {
    background-position: 200% 0;
  }
}

/* 渐变流动 */
@keyframes gradient-flow {
  0% {
    background-position: 0% 50%;
  }
  50% {
    background-position: 100% 50%;
  }
  100% {
    background-position: 0% 50%;
  }
}

/* 呼吸灯效果 */
@keyframes breathing {
  0%, 100% {
    opacity: 0.6;
    transform: scale(1);
  }
  50% {
    opacity: 1;
    transform: scale(1.05);
  }
}

/* 波纹扩散 */
@keyframes ripple {
  0% {
    transform: scale(0.8);
    opacity: 1;
  }
  100% {
    transform: scale(2);
    opacity: 0;
  }
}

/* 粒子效果 */
@keyframes particle-float {
  0% {
    transform: translate(0, 0) rotate(0deg);
    opacity: 0;
  }
  10% {
    opacity: 1;
  }
  90% {
    opacity: 1;
  }
  100% {
    transform: translate(var(--tx, 100rpx), var(--ty, -100rpx)) rotate(var(--tr, 360deg));
    opacity: 0;
  }
}

/* 霓虹闪烁 */
@keyframes neon-flicker {
  0%, 19%, 21%, 23%, 25%, 54%, 56%, 100% {
    opacity: 1;
  }
  20%, 24%, 55% {
    opacity: 0.5;
  }
}

/* 3D翻转 */
@keyframes flip-x {
  0% {
    transform: perspective(400px) rotateX(90deg);
    opacity: 0;
  }
  100% {
    transform: perspective(400px) rotateX(0deg);
    opacity: 1;
  }
}

@keyframes flip-y {
  0% {
    transform: perspective(400px) rotateY(90deg);
    opacity: 0;
  }
  100% {
    transform: perspective(400px) rotateY(0deg);
    opacity: 1;
  }
}

/* 抖动效果 */
@keyframes shake {
  0%, 100% {
    transform: translateX(0);
  }
  10%, 30%, 50%, 70%, 90% {
    transform: translateX(-2rpx);
  }
  20%, 40%, 60%, 80% {
    transform: translateX(2rpx);
  }
}

/* 打字机效果 */
@keyframes typing {
  from {
    width: 0;
  }
  to {
    width: 100%;
  }
}

@keyframes blink-caret {
  from, to {
    border-color: transparent;
  }
  50% {
    border-color: currentColor;
  }
}

/* ========== 加载动画 ========== */

/* 点状加载 */
@keyframes dots-loading {
  0%, 20% {
    opacity: 0.1;
    transform: translateY(0);
  }
  50% {
    opacity: 1;
    transform: translateY(-8rpx);
  }
  100% {
    opacity: 0.1;
    transform: translateY(0);
  }
}

/* 波浪加载 */
@keyframes wave {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-10rpx);
  }
}

/* 进度条加载 */
@keyframes progress-loading {
  0% {
    width: 0%;
    opacity: 1;
  }
  100% {
    width: 100%;
    opacity: 1;
  }
}

/* ========== 悬停动画 ========== */

/* 悬停上浮 */
@keyframes hover-float {
  0% {
    transform: translateY(0);
  }
  100% {
    transform: translateY(-4rpx);
  }
}

/* 悬停缩放 */
@keyframes hover-scale {
  0% {
    transform: scale(1);
  }
  100% {
    transform: scale(1.05);
  }
}

/* 悬停旋转 */
@keyframes hover-rotate {
  0% {
    transform: rotate(0deg);
  }
  100% {
    transform: rotate(5deg);
  }
}

/* 悬停发光 */
@keyframes hover-glow {
  0% {
    box-shadow: 0 0 0 rgba(52, 211, 153, 0);
  }
  100% {
    box-shadow: 0 0 20rpx rgba(52, 211, 153, 0.5);
  }
}

/* ========== 页面过渡动画 ========== */

/* 页面进入 */
@keyframes page-enter {
  from {
    opacity: 0;
    transform: translateY(20rpx) scale(0.98);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

/* 页面退出 */
@keyframes page-exit {
  from {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
  to {
    opacity: 0;
    transform: translateY(-20rpx) scale(0.98);
  }
}

/* 模态框进入 */
@keyframes modal-enter {
  from {
    opacity: 0;
    transform: scale(0.8) translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: scale(1) translateY(0);
  }
}

/* 模态框退出 */
@keyframes modal-exit {
  from {
    opacity: 1;
    transform: scale(1) translateY(0);
  }
  to {
    opacity: 0;
    transform: scale(0.8) translateY(40rpx);
  }
}

/* ========== 工具类动画 ========== */

/* 淡入动画类 */
.animate-fade-in {
  animation: fade-in var(--transition-normal);
}

.animate-fade-in-up {
  animation: fade-in-up var(--transition-normal);
}

.animate-fade-in-down {
  animation: fade-in-down var(--transition-normal);
}

.animate-fade-in-left {
  animation: fade-in-left var(--transition-normal);
}

.animate-fade-in-right {
  animation: fade-in-right var(--transition-normal);
}

/* 缩放动画类 */
.animate-scale-in {
  animation: scale-in var(--transition-bounce);
}

.animate-scale-in-bounce {
  animation: scale-in-bounce 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
}

/* 旋转动画类 */
.animate-spin {
  animation: spin 1s linear infinite;
}

.animate-spin-slow {
  animation: spin 2s linear infinite;
}

.animate-spin-reverse {
  animation: spin-reverse 1s linear infinite;
}

/* 弹跳动画类 */
.animate-bounce {
  animation: bounce 1s infinite;
}

.animate-bounce-sm {
  animation: bounce-sm 1s infinite;
}

.animate-bounce-lg {
  animation: bounce-lg 1s infinite;
}

/* 脉动动画类 */
.animate-pulse {
  animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
}

.animate-pulse-soft {
  animation: pulse-soft 2s ease-in-out infinite;
}

.animate-pulse-strong {
  animation: pulse-strong 2s ease-in-out infinite;
}

/* 浮动动画类 */
.animate-float {
  animation: float 3s ease-in-out infinite;
}

.animate-float-slow {
  animation: float-slow 4s ease-in-out infinite;
}

.animate-float-fast {
  animation: float-fast 2s ease-in-out infinite;
}

/* 滑动动画类 */
.animate-slide-in-up {
  animation: slide-in-up var(--transition-normal);
}

.animate-slide-in-down {
  animation: slide-in-down var(--transition-normal);
}

.animate-slide-in-left {
  animation: slide-in-left var(--transition-normal);
}

.animate-slide-in-right {
  animation: slide-in-right var(--transition-normal);
}

/* 现代特效动画类 */
.animate-shine {
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(255, 255, 255, 0.4) 50%, 
    transparent 100%
  );
  background-size: 200% 100%;
  animation: shine 2s ease-in-out infinite;
}

.animate-gradient-flow {
  background-size: 200% 200%;
  animation: gradient-flow 4s ease infinite;
}

.animate-breathing {
  animation: breathing 3s ease-in-out infinite;
}

.animate-ripple {
  animation: ripple 1s ease-out;
}

.animate-neon-flicker {
  animation: neon-flicker 1.5s infinite;
}

.animate-flip-x {
  animation: flip-x 0.6s cubic-bezier(0.4, 0, 0.2, 1);
}

.animate-flip-y {
  animation: flip-y 0.6s cubic-bezier(0.4, 0, 0.2, 1);
}

.animate-shake {
  animation: shake 0.5s ease-in-out;
}

/* 加载动画类 */
.animate-dots-loading span {
  animation: dots-loading 1.4s infinite;
}

.animate-dots-loading span:nth-child(2) {
  animation-delay: 0.2s;
}

.animate-dots-loading span:nth-child(3) {
  animation-delay: 0.4s;
}

.animate-wave {
  animation: wave 1.5s ease-in-out infinite;
}

.animate-wave:nth-child(2) {
  animation-delay: 0.1s;
}

.animate-wave:nth-child(3) {
  animation-delay: 0.2s;
}

.animate-wave:nth-child(4) {
  animation-delay: 0.3s;
}

.animate-wave:nth-child(5) {
  animation-delay: 0.4s;
}

.animate-progress-loading {
  animation: progress-loading 2s ease-in-out infinite;
}

/* 悬停动画类 */
.hover-float:hover {
  animation: hover-float 0.3s ease forwards;
}

.hover-scale:hover {
  animation: hover-scale 0.3s ease forwards;
}

.hover-rotate:hover {
  animation: hover-rotate 0.3s ease forwards;
}

.hover-glow:hover {
  animation: hover-glow 0.3s ease forwards;
}

/* 页面过渡动画类 */
.page-enter {
  animation: page-enter 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

.page-exit {
  animation: page-exit 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

.modal-enter {
  animation: modal-enter 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.modal-exit {
  animation: modal-exit 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

/* ========== 性能优化类 ========== */

/* GPU加速 */
.gpu-accelerate {
  transform: translateZ(0);
  backface-visibility: hidden;
  perspective: 1000;
}

/* 动画性能优化 */
.will-change-transform {
  will-change: transform;
}

.will-change-opacity {
  will-change: opacity;
}

.will-change-all {
  will-change: transform, opacity;
}

/* 减少动画 - WXSS不支持通配符，使用具体选择器 */
.reduce-motion view,
.reduce-motion text,
.reduce-motion image,
.reduce-motion button,
.reduce-motion input,
.reduce-motion textarea,
.reduce-motion scroll-view,
.reduce-motion swiper,
.reduce-motion swiper-item {
  animation-duration: 0.001ms !important;
  animation-iteration-count: 1 !important;
  transition-duration: 0.001ms !important;
}

/* ========== 动画延迟工具类 ========== */
.delay-100 { animation-delay: 100ms; }
.delay-200 { animation-delay: 200ms; }
.delay-300 { animation-delay: 300ms; }
.delay-400 { animation-delay: 400ms; }
.delay-500 { animation-delay: 500ms; }
.delay-600 { animation-delay: 600ms; }
.delay-700 { animation-delay: 700ms; }
.delay-800 { animation-delay: 800ms; }
.delay-900 { animation-delay: 900ms; }
.delay-1000 { animation-delay: 1000ms; }

/* ========== 动画持续时间工具类 ========== */
.duration-100 { animation-duration: 100ms; }
.duration-200 { animation-duration: 200ms; }
.duration-300 { animation-duration: 300ms; }
.duration-400 { animation-duration: 400ms; }
.duration-500 { animation-duration: 500ms; }
.duration-600 { animation-duration: 600ms; }
.duration-700 { animation-duration: 700ms; }
.duration-800 { animation-duration: 800ms; }
.duration-900 { animation-duration: 900ms; }
.duration-1000 { animation-duration: 1000ms; }
.duration-1500 { animation-duration: 1500ms; }
.duration-2000 { animation-duration: 2000ms; }
.duration-3000 { animation-duration: 3000ms; }

/* ========== 动画填充模式工具类 ========== */
.animate-fill-forwards { animation-fill-mode: forwards; }
.animate-fill-backwards { animation-fill-mode: backwards; }
.animate-fill-both { animation-fill-mode: both; }
.animate-fill-none { animation-fill-mode: none; }

/* ========== 动画计时函数工具类 ========== */
.animate-ease { animation-timing-function: ease; }
.animate-ease-in { animation-timing-function: ease-in; }
.animate-ease-out { animation-timing-function: ease-out; }
.animate-ease-in-out { animation-timing-function: ease-in-out; }
.animate-linear { animation-timing-function: linear; }
.animate-cubic-bezier { animation-timing-function: cubic-bezier(0.4, 0, 0.2, 1); }
.animate-bounce { animation-timing-function: cubic-bezier(0.34, 1.56, 0.64, 1); }

/* ========== 动画迭代次数工具类 ========== */
.animate-iteration-1 { animation-iteration-count: 1; }
.animate-iteration-2 { animation-iteration-count: 2; }
.animate-iteration-3 { animation-iteration-count: 3; }
.animate-iteration-infinite { animation-iteration-count: infinite; }

/* ========== 动画方向工具类 ========== */
.animate-direction-normal { animation-direction: normal; }
.animate-direction-reverse { animation-direction: reverse; }
.animate-direction-alternate { animation-direction: alternate; }
.animate-direction-alternate-reverse { animation-direction: alternate-reverse; }

/* ========== 动画播放状态工具类 ========== */
.animate-play-running { animation-play-state: running; }
.animate-play-paused { animation-play-state: paused; }

/* ========== 现代交互反馈动画 ========== */

/* 点击涟漪效果 */
.ripple-effect {
  position: relative;
  overflow: hidden;
}

.ripple-effect::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 0;
  height: 0;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.6);
  transform: translate(-50%, -50%);
  animation: ripple 0.6s ease-out;
  pointer-events: none;
}

/* 加载骨架屏动画 */
.skeleton-animate {
  background: linear-gradient(90deg, 
    var(--color-bg-muted) 0%, 
    var(--color-border-light) 50%, 
    var(--color-bg-muted) 100%
  );
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s ease-in-out infinite;
}

@keyframes skeleton-loading {
  0% {
    background-position: 200% 0;
  }
  100% {
    background-position: -200% 0;
  }
}

/* 进度条动画 */
.progress-animate {
  animation: progress-loading 2s ease-in-out infinite;
}

/* 打字机效果 */
.typewriter {
  overflow: hidden;
  border-right: 2rpx solid;
  white-space: nowrap;
  animation: 
    typing 3.5s steps(40, end),
    blink-caret 0.75s step-end infinite;
}

/* 粒子系统动画 */
.particle-system {
  position: relative;
  overflow: hidden;
}

.particle {
  position: absolute;
  width: 4rpx;
  height: 4rpx;
  border-radius: 50%;
  background: var(--color-primary);
  animation: particle-float 2s ease-out forwards;
}

/* 3D卡片翻转 */
.card-3d {
  transform-style: preserve-3d;
  transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
}

.card-3d:hover {
  transform: rotateY(10deg) rotateX(5deg);
}

/* 视差滚动效果 */
.parallax-layer {
  transform: translateZ(0);
  will-change: transform;
}

.parallax-layer-1 {
  transform: translateZ(-2px) scale(3);
}

.parallax-layer-2 {
  transform: translateZ(-1px) scale(2);
}

.parallax-layer-3 {
  transform: translateZ(0) scale(1);
}

/* 响应式动画 - 根据屏幕尺寸调整 */
@media (max-width: 768rpx) {
  .mobile-animate-fade-in {
    animation: fade-in var(--transition-normal);
  }
  
  .mobile-animate-slide-in-up {
    animation: slide-in-up var(--transition-normal);
  }
}

@media (min-width: 769rpx) {
  .desktop-animate-fade-in {
    animation: fade-in var(--transition-normal);
  }
  
  .desktop-animate-scale-in {
    animation: scale-in var(--transition-bounce);
  }
}

/* 暗色模式动画适配 */
.dark-mode .animate-glow {
  animation: hover-glow 0.3s ease forwards;
  box-shadow: 0 0 20rpx rgba(52, 211, 153, 0.3);
}

/* 打印模式禁用动画 */
@media print {
  .animate-fade-in,
  .animate-scale-in,
  .animate-slide-in-up,
  .animate-spin,
  .animate-pulse,
  .animate-float,
  .animate-bounce,
  .animate-shine,
  .animate-gradient-flow,
  .animate-breathing,
  .animate-ripple,
  .animate-neon-flicker,
  .animate-flip-x,
  .animate-flip-y,
  .animate-shake,
  .animate-dots-loading,
  .animate-wave,
  .animate-progress-loading,
  .hover-float,
  .hover-scale,
  .hover-rotate,
  .hover-glow,
  .page-enter,
  .page-exit,
  .modal-enter,
  .modal-exit {
    animation: none !important;
    transition: none !important;
  }
}

/* ========== 性能优化提示 ========== */
/* 使用动画的最佳实践： */
/* 1. 优先使用 transform 和 opacity 属性进行动画，这些属性可以由GPU加速 */
/* 2. 避免在动画中使用 width、height、margin、padding 等属性，这些会导致重排 */
/* 3. 使用 will-change 属性提示浏览器哪些属性将要变化 */
/* 4. 对于复杂的动画，考虑使用 requestAnimationFrame */
/* 5. 在移动设备上，减少动画的复杂度和持续时间 */
/* 6. 提供减少动画的选项，支持 prefers-reduced-motion 媒体查询 */

/* 支持 prefers-reduced-motion */
@media (prefers-reduced-motion: reduce) {
  .animate-fade-in,
  .animate-scale-in,
  .animate-slide-in-up,
  .animate-spin,
  .animate-pulse,
  .animate-float,
  .animate-bounce,
  .animate-shine,
  .animate-gradient-flow,
  .animate-breathing,
  .animate-ripple,
  .animate-neon-flicker,
  .animate-flip-x,
  .animate-flip-y,
  .animate-shake,
  .animate-dots-loading,
  .animate-wave,
  .animate-progress-loading,
  .hover-float,
  .hover-scale,
  .hover-rotate,
  .hover-glow,
  .page-enter,
  .page-exit,
  .modal-enter,
  .modal-exit {
    animation: none !important;
    transition: none !important;
  }
  
  .reduce-motion {
    animation-duration: 0.001ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.001ms !important;
  }
}
