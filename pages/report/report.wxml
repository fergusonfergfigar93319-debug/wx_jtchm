<!--pages/report/report.wxml-->
<view class="container page-container {{viewMode !== 'day' ? 'container--report-bento' : ''}}">
  <custom-nav-bar title="健康管理" isScrolled="{{navScrolled}}" />
  <!-- 顶部统计卡片（仅日报） -->
  <view class="summary-cards" wx:if="{{viewMode === 'day'}}">
    <view class="summary-card consumed-card">
      <view class="summary-icon">🔥</view>
      <view class="summary-content">
        <text class="summary-label">今日摄入</text>
        <text class="summary-value">{{dailyData.consumed || 0}}</text>
        <text class="summary-unit">kcal</text>
      </view>
      <view class="summary-progress">
        <view class="progress-circle" style="background: conic-gradient(#34c759 {{progressPercent * 3.6}}deg, #e0e0e0 {{progressPercent * 3.6}}deg 360deg);"></view>
        <text class="progress-text">{{progressPercent}}%</text>
      </view>
    </view>
    
    <view class="summary-card target-card">
      <view class="summary-icon">🎯</view>
      <view class="summary-content">
        <text class="summary-label">目标摄入</text>
        <text class="summary-value">{{dailyData.target || 2000}}</text>
        <text class="summary-unit">kcal</text>
      </view>
    </view>
  </view>

  <!-- 日历条 + 分段控制 -->
  <view class="calendar-wrapper report-sticky-header" style="top: {{navTopPx}}px;">
    <view class="calendar-header">
      <text class="calendar-title" wx:if="{{viewMode === 'day'}}">📅 选择日期</text>
      <text class="calendar-title" wx:else>📊 健康报告</text>
      <view class="segment-control">
        <view class="segment-item pressable {{viewMode === 'day' ? 'active' : ''}}" bindtap="switchView" data-mode="day" hover-class="press-hover" hover-stay-time="80">日报</view>
        <view class="segment-item pressable {{viewMode === 'week' ? 'active' : ''}}" bindtap="switchView" data-mode="week" hover-class="press-hover" hover-stay-time="80">周报</view>
        <view class="segment-item pressable {{viewMode === 'month' ? 'active' : ''}}" bindtap="switchView" data-mode="month" hover-class="press-hover" hover-stay-time="80">月报</view>
      </view>
    </view>
    <view class="report-date-range" wx:if="{{viewMode === 'week' || viewMode === 'month'}}">{{reportDateRangeLabel}}</view>
    <scroll-view wx:if="{{viewMode === 'day'}}" class="calendar-bar" scroll-x="true" scroll-left="{{scrollLeft}}">
      <view class="calendar-list">
        <view 
          class="calendar-item pressable {{selectedDate === item.date ? 'active' : ''}} {{item.isToday ? 'today' : ''}} {{item.status}} {{item.weekend ? 'weekend' : ''}}"
          wx:for="{{calendarDays}}"
          wx:for-index="calIdx"
          wx:key="calIdx"
          bindtap="selectDate"
          data-date="{{item.date}}"
          hover-class="press-hover"
          hover-stay-time="80"
        >
          <view class="date-wrapper">
            <text class="date-text">{{item.day}}</text>
            <text class="week-text">{{item.week}}</text>
          </view>
          <view class="status-indicator">
            <view class="status-dot"></view>
            <view wx:if="{{item.isToday}}" class="today-badge">今</view>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 核心数据 - 日报视图 -->
  <view class="data-section" wx:if="{{viewMode === 'day'}}">
    <!-- 饮水（与首页联动） -->
    <view
      class="water-intake-card pressable"
      bindtap="goToWaterRecord"
      hover-class="press-hover"
      hover-stay-time="80"
    >
      <view class="water-intake-header">
        <view class="water-intake-title-wrap">
          <text class="water-intake-icon">💧</text>
          <text class="water-intake-title">饮水记录</text>
        </view>
        <view class="water-intake-badge">
          <text class="water-intake-num">{{todayWater}}</text>
          <text class="water-intake-div">/</text>
          <text class="water-intake-total">{{waterGoal}}</text>
          <text class="water-intake-unit">ml</text>
        </view>
      </view>
      <view class="water-intake-progress-bar">
        <view class="water-intake-progress-bg">
          <view class="water-intake-progress-fill" style="width: {{waterGoal > 0 ? (todayWater / waterGoal * 100) : 0}}%;"></view>
        </view>
      </view>
      <view class="water-intake-footer">
        <view class="water-intake-btn-hint">查看饮水记录</view>
        <text class="water-intake-tip-inline" wx:if="{{selectedDate !== waterDateToday}}">含饮食估算水分</text>
      </view>
    </view>

    <!-- 卡路里对比 -->
    <view class="chart-card">
      <view class="chart-header">
        <view class="chart-title-wrapper">
          <text class="chart-icon">📊</text>
          <text class="chart-title">卡路里摄入</text>
        </view>
        <view class="chart-subtitle">今日 vs 目标</view>
      </view>
      <view class="chart-container">
        <canvas 
          canvas-id="calorieChart" 
          class="chart-canvas"
          width="{{canvasWidth}}"
          height="{{canvasHeight}}"
          style="width: {{canvasWidth}}px; height: {{canvasHeight}}px;"
        ></canvas>
      </view>
      <view class="chart-legend">
        <view class="legend-item">
          <view class="legend-color consumed-color"></view>
          <text class="legend-label">已摄入</text>
          <text class="legend-value">{{dailyData.consumed || 0}} kcal</text>
        </view>
        <view class="legend-divider"></view>
        <view class="legend-item">
          <view class="legend-color target-color"></view>
          <text class="legend-label">目标</text>
          <text class="legend-value">{{dailyData.target || 2000}} kcal</text>
        </view>
        <view class="legend-divider"></view>
        <view class="legend-item">
          <view class="legend-color remaining-color"></view>
          <text class="legend-label">剩余</text>
          <text class="legend-value">{{remainingCalories}} kcal</text>
        </view>
      </view>
    </view>

    <!-- 三大营养素 -->
    <view class="chart-card">
      <view class="chart-header">
        <view class="chart-title-wrapper">
          <text class="chart-icon">🥗</text>
          <text class="chart-title">营养素分布</text>
        </view>
        <view class="nutrient-header-row">
          <view class="chart-subtitle">碳水 / 蛋白质 / 脂肪</view>
          <view class="nutrient-scope-switch" aria-label="营养素统计口径">
            <text class="scope-item pressable {{nutrientScope === 'day' ? 'active' : ''}}" bindtap="switchNutrientScope" data-scope="day" hover-class="press-hover" hover-stay-time="80">本日</text>
            <text class="scope-item pressable {{nutrientScope === '7d' ? 'active' : ''}}" bindtap="switchNutrientScope" data-scope="7d" hover-class="press-hover" hover-stay-time="80">近7天</text>
            <text class="scope-item pressable {{nutrientScope === '30d' ? 'active' : ''}}" bindtap="switchNutrientScope" data-scope="30d" hover-class="press-hover" hover-stay-time="80">近30天</text>
          </view>
        </view>
        <view class="nutrient-chart-legend">
          <view class="nutrient-legend-item"><view class="nutrient-legend-dot carb-dot"></view><text>碳水</text></view>
          <view class="nutrient-legend-item"><view class="nutrient-legend-dot protein-dot"></view><text>蛋白质</text></view>
          <view class="nutrient-legend-item"><view class="nutrient-legend-dot fat-dot"></view><text>脂肪</text></view>
        </view>
      </view>
      <view class="chart-container nutrient-chart-container">
        <canvas 
          canvas-id="nutrientChart" 
          class="chart-canvas"
          width="{{canvasNutrientWidth}}"
          height="{{canvasNutrientHeight}}"
          style="width: {{canvasNutrientWidth}}px; height: {{canvasNutrientHeight}}px;"
        ></canvas>
      </view>
      <view class="nutrient-stats">
        <view class="nutrient-stat-item pressable {{selectedNutrientType === 'carb' ? 'active' : ''}}" bindtap="onNutrientTap" data-type="carb" hover-class="press-hover" hover-stay-time="80">
          <view class="stat-icon carb-icon">🌾</view>
          <view class="stat-content">
            <text class="stat-label">碳水</text>
            <text class="stat-value">{{nutrientDisplay.carb || 0}}g</text>
            <text class="stat-percent">{{nutrientPercents.carb}}%</text>
          </view>
        </view>
        <view class="nutrient-stat-item pressable {{selectedNutrientType === 'protein' ? 'active' : ''}}" bindtap="onNutrientTap" data-type="protein" hover-class="press-hover" hover-stay-time="80">
          <view class="stat-icon protein-icon">🥩</view>
          <view class="stat-content">
            <text class="stat-label">蛋白质</text>
            <text class="stat-value">{{nutrientDisplay.protein || 0}}g</text>
            <text class="stat-percent">{{nutrientPercents.protein}}%</text>
          </view>
        </view>
        <view class="nutrient-stat-item pressable {{selectedNutrientType === 'fat' ? 'active' : ''}}" bindtap="onNutrientTap" data-type="fat" hover-class="press-hover" hover-stay-time="80">
          <view class="stat-icon fat-icon">🥑</view>
          <view class="stat-content">
            <text class="stat-label">脂肪</text>
            <text class="stat-value">{{nutrientDisplay.fat || 0}}g</text>
            <text class="stat-percent">{{nutrientPercents.fat}}%</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 健康管理总览：运动 / 碳足迹 / 补救 / 挑战 -->
    <view class="health-summary-section">
      <view class="health-summary-header">
        <text class="health-summary-title">健康管理总览</text>
        <text class="health-summary-subtitle">运动 · 碳足迹 · 补救 · 挑战</text>
      </view>
      <view class="health-summary-grid">
        <view class="health-summary-card pressable" bindtap="goToWorkoutPage" hover-class="press-hover" hover-stay-time="80">
          <view class="health-icon-circle workout-icon">🏃</view>
          <view class="health-card-main">
            <text class="health-card-label">今日运动</text>
            <text class="health-card-value">{{todayWorkoutStats.totalCalories || 0}} kcal</text>
          </view>
          <text class="health-card-extra">{{todayWorkoutStats.totalDistance || 0}} km · {{todayWorkoutStats.workoutCount || 0}} 次</text>
        </view>
        <view class="health-summary-card pressable" bindtap="goToCarbonTracker" hover-class="press-hover" hover-stay-time="80">
          <view class="health-icon-circle carbon-icon">🌍</view>
          <view class="health-card-main">
            <text class="health-card-label">今日碳足迹</text>
            <text class="health-card-value">{{todayCarbonBrief.total || 0}} kg CO₂e</text>
          </view>
          <text class="health-card-extra">查看趋势与环保成就</text>
        </view>
        <view class="health-summary-card pressable" bindtap="goToRemedyPage" hover-class="press-hover" hover-stay-time="80">
          <view class="health-icon-circle remedy-icon">🩹</view>
          <view class="health-card-main">
            <text class="health-card-label">健康补救</text>
            <text class="health-card-value">饮食失衡后怎么补救</text>
          </view>
          <text class="health-card-extra">熬夜 / 暴食 / 宿醉等场景</text>
        </view>
        <view class="health-summary-card pressable" bindtap="goToChallengePage" hover-class="press-hover" hover-stay-time="80">
          <view class="health-icon-circle challenge-icon">🥇</view>
          <view class="health-card-main">
            <text class="health-card-label">健康挑战</text>
            <text class="health-card-value">参与打卡赢勋章</text>
          </view>
          <text class="health-card-extra" bindtap="goToAchievementsPage" catchtap="goToAchievementsPage">查看荣誉墙 ›</text>
        </view>
      </view>
    </view>
  </view>

  <!-- AI 营养师小结（日报优先展示） -->
  <view class="ai-section" wx:if="{{viewMode === 'day' && aiSummary}}">
    <view class="ai-header">
      <view class="ai-title-wrap">
        <text class="ai-icon">🤖</text>
        <text class="ai-title">AI 营养师 · 今日小结</text>
      </view>
      <text class="ai-date">{{selectedDate}}</text>
    </view>
    <view class="ai-body">
      <text class="ai-main">{{aiSummary.overview || aiSummary.summary || aiSummary}}</text>
      <view wx:if="{{aiSummary.suggestions && aiSummary.suggestions.length}}" class="ai-suggest-list">
        <view
          class="ai-suggest-item"
          wx:for="{{aiSummary.suggestions}}"
          wx:key="index"
        >
          <text class="dot">•</text>
          <text class="text">{{item}}</text>
        </view>
      </view>
      <view wx:if="{{healthWarnings && healthWarnings.length}}" class="ai-warning">
        <text class="ai-warning-title">⚠️ 今日需要注意：</text>
        <view
          class="ai-warning-item"
          wx:for="{{healthWarnings}}"
          wx:key="id"
        >
          <text>{{item.message || item}}</text>
        </view>
      </view>
    </view>
    <view class="ai-footer">
      <text class="ai-footer-text">建议仅供参考，如有基础疾病请遵医嘱。</text>
      <text class="ai-link pressable" bindtap="goToAIChat" hover-class="press-hover" hover-stay-time="80">向 AI 营养师继续提问 ›</text>
    </view>
  </view>

  <!-- 时间轴 - 日报视图 -->
  <view class="timeline-section" wx:if="{{viewMode === 'day'}}">
    <view class="section-header">
      <view class="section-title-wrapper">
        <text class="section-icon">⏰</text>
        <text class="section-title">今日时间轴</text>
      </view>
      <text class="section-count">共 {{timeline.length}} 条记录</text>
    </view>
    
    <!-- 按餐次分组显示 -->
    <view wx:if="{{groupedTimeline.length > 0}}" class="timeline-groups">
      <view 
        class="meal-group"
        wx:for="{{groupedTimeline}}"
        wx:key="mealType"
      >
        <!-- 餐次标题栏 -->
        <view class="meal-group-header">
          <view class="meal-group-title-wrapper">
            <view class="meal-group-dot {{item.mealType}}"></view>
            <text class="meal-group-label">{{item.label}}</text>
            <text class="meal-group-count">({{item.items.length}}项)</text>
          </view>
          <view class="meal-group-total">
            <text class="meal-group-total-label">总计</text>
            <text class="meal-group-total-value">{{item.totalCalories}} kcal</text>
          </view>
        </view>
        
        <!-- 该餐次的记录列表 -->
        <view class="timeline">
          <view 
            class="timeline-item pressable"
            wx:for="{{item.items}}"
            wx:for-item="record"
            wx:key="id"
            bindtap="editIntake"
            data-id="{{record.id}}"
            bindlongpress="changeMealType"
            data-meal-type="{{record.meal_type}}"
            hover-class="press-hover"
            hover-stay-time="80"
          >
            <view class="timeline-line"></view>
            <view class="timeline-dot {{record.meal_type}}"></view>
            <view class="timeline-content-wrapper">
              <view class="timeline-header">
                <view class="timeline-time-wrapper">
                  <text class="timeline-time">{{record.meal_time}}</text>
                  <text class="meal-type-hint">长按可修改餐次</text>
                </view>
                <view class="timeline-cal-badge">
                  <text class="cal-icon">🔥</text>
                  <text class="cal-value">{{record.calories}} kcal</text>
                </view>
              </view>
              <view class="timeline-name">{{record.food_name}}</view>
              <view wx:if="{{record.portion}}" class="timeline-portion">分量: {{record.portion}}</view>
              <view wx:if="{{record.protein != null || record.fat != null || record.carbs != null}}" class="timeline-nutrients">
                <text wx:if="{{record.protein != null}}">蛋白质 {{record.protein}}g</text>
                <text wx:if="{{record.fat != null}}">脂肪 {{record.fat}}g</text>
                <text wx:if="{{record.carbs != null}}">碳水 {{record.carbs}}g</text>
              </view>
              <view wx:if="{{record.note}}" class="timeline-note">备注: {{record.note}}</view>
            </view>
            <view class="timeline-action">
              <text class="action-icon">›</text>
            </view>
          </view>
        </view>
      </view>
    </view>
    
    <!-- 空状态 -->
    <view wx:if="{{timeline.length === 0}}" class="empty-timeline">
      <view class="empty-icon">📝</view>
      <text class="empty-text">今天还没有记录饮食</text>
      <text class="empty-hint">快去记录你的第一餐吧！</text>
      <button class="btn-primary mt-20" bindtap="goToAdd">添加记录</button>
    </view>
  </view>

  <!-- 周报 / 月报：Bento + 原生 CSS 柱状图 + AI 洞察 -->
  <view wx:if="{{viewMode === 'week' || viewMode === 'month'}}" class="report-bento-wrap">
    <view class="bento-item-report hero-chart-report">
      <view class="bento-header-report">
        <view class="header-left-report">
          <text class="bento-title-report">{{viewMode === 'week' ? '热量摄入趋势' : '本月热量分段'}}</text>
          <text class="bento-subtitle-report">日均摄入 {{reportAvgDailyKcal}} kcal · 目标 {{reportDailyTarget}} kcal</text>
        </view>
        <view class="header-right-report">
          <text class="trend-tag-report {{reportTrendTagClass}}">{{reportTrendTagText}}</text>
        </view>
      </view>

      <view class="css-bar-chart-report">
        <view
          class="chart-bar-group-report"
          wx:for="{{barChartDays}}"
          wx:for-index="barIdx"
          wx:key="barIdx"
        >
          <view class="bar-bg-report">
            <view class="bar-fill-report {{item.isOver ? 'over-target' : ''}}" style="height: {{item.percent}}%;"></view>
          </view>
          <text class="bar-label-report {{item.isToday ? 'today' : ''}}">{{item.day}}</text>
        </view>
        <view class="target-line-report" style="bottom: {{reportTargetLineBottom}}%;"></view>
      </view>
    </view>

    <view class="report-bento-grid">
      <view class="bento-item-report bento-square-report">
        <view class="bento-icon-report">📅</view>
        <view class="bento-value-report">
          {{bentoPerfectDays}}<text class="small-unit-report">天</text>
        </view>
        <view class="bento-label-report">{{viewMode === 'week' ? '热量接近目标' : '达标日数'}}</view>
      </view>
      <view class="bento-item-report bento-square-report">
        <view class="bento-icon-report">📝</view>
        <view class="bento-value-report">
          {{bentoSecondaryValue}}<text class="small-unit-report">{{bentoSecondaryUnit}}</text>
        </view>
        <view class="bento-label-report">{{bentoSecondaryLabel}}</view>
      </view>
    </view>

    <view wx:if="{{viewMode === 'week'}}" class="weekly-mini-extreme">
      <view class="weekly-mini-row" wx:if="{{weeklyData.max_calorie_item}}">
        <text class="weekly-mini-label">本周最高热量</text>
        <text class="weekly-mini-val">{{weeklyData.max_calorie_item.food_name}} · {{weeklyData.max_calorie_item.calories}} kcal</text>
      </view>
    </view>

    <view class="bento-item-report macro-analysis-report">
      <text class="bento-title-report macro-title-block">营养素结构 · 日均 vs 目标</text>
      <view class="macro-row-report">
        <view class="macro-info-report">
          <text class="macro-name-report">🥚 蛋白质</text>
          <text class="macro-data-report">日均 {{macroWeekModel.proteinAvg}}g · 目标达成 {{macroWeekModel.proteinPct}}%</text>
        </view>
        <view class="macro-progress-bg-report">
          <view class="macro-progress-fill-report protein-m" style="width: {{macroWeekModel.proteinPct}}%;"></view>
        </view>
      </view>
      <view class="macro-row-report">
        <view class="macro-info-report">
          <text class="macro-name-report">🌾 碳水化合物</text>
          <text class="macro-data-report">日均 {{macroWeekModel.carbAvg}}g · 目标达成 {{macroWeekModel.carbPct}}%</text>
        </view>
        <view class="macro-progress-bg-report">
          <view class="macro-progress-fill-report carbs-m" style="width: {{macroWeekModel.carbPct}}%;"></view>
        </view>
      </view>
      <view class="macro-row-report">
        <view class="macro-info-report">
          <text class="macro-name-report">🥑 脂肪</text>
          <text class="macro-data-report">日均 {{macroWeekModel.fatAvg}}g · 目标达成 {{macroWeekModel.fatPct}}%</text>
        </view>
        <view class="macro-progress-bg-report">
          <view class="macro-progress-fill-report fat-m" style="width: {{macroWeekModel.fatPct}}%;"></view>
        </view>
      </view>
    </view>

    <view class="bento-item-report ai-insight-report">
      <view class="insight-header-report">
        <text class="insight-icon-report">✨</text>
        <text class="insight-title-report">{{viewMode === 'week' ? 'AI 营养师 · 本周洞察' : 'AI 营养师 · 本月洞察'}}</text>
      </view>
      <view class="insight-content-report">
        <block wx:for="{{weekInsightSpans}}" wx:key="spanIdx" wx:for-index="spanIdx">
          <text class="{{item.spanClass}}">{{item.t}}</text>
        </block>
      </view>
      <view class="insight-actions-report">
        <text class="insight-action-report pressable" bindtap="openReportInsightPlan" hover-class="press-hover" hover-stay-time="80">{{reportInsightButtonLabel}}</text>
        <text class="insight-action-report insight-action-secondary pressable" bindtap="goToAIChat" hover-class="press-hover" hover-stay-time="80">继续提问 ›</text>
      </view>
    </view>

    <!-- 记录时间轴 -->
    <view class="timeline-section report-bento-timeline">
      <view class="section-header">
        <view class="section-title-wrapper">
          <text class="section-icon">⏰</text>
          <text class="section-title">{{viewMode === 'week' ? '本周记录' : '本月记录'}}</text>
        </view>
        <text class="section-count">共 {{timeline.length}} 条</text>
      </view>
      <view class="timeline">
        <view
          class="timeline-item pressable"
          wx:for="{{timeline}}"
          wx:key="id"
          bindtap="editIntake"
          data-id="{{item.id}}"
          hover-class="press-hover"
          hover-stay-time="80"
        >
          <view class="timeline-line"></view>
          <view class="timeline-dot {{item.meal_type}}"></view>
          <view class="timeline-content-wrapper">
            <view class="timeline-header">
              <view class="timeline-time-wrapper">
                <text class="timeline-date">{{item.date}}</text>
                <text class="timeline-time">{{item.meal_time}}</text>
                <text class="meal-type-label">{{mealTypeLabels[item.meal_type] || '其他'}}</text>
              </view>
              <view class="timeline-cal-badge">
                <text class="cal-icon">🔥</text>
                <text class="cal-value">{{item.calories}} kcal</text>
              </view>
            </view>
            <view class="timeline-name">{{item.food_name}}</view>
          </view>
          <view class="timeline-action">
            <text class="action-icon">›</text>
          </view>
        </view>
      </view>
      <view wx:if="{{timeline.length === 0}}" class="empty-timeline">
        <view class="empty-icon">📝</view>
        <text class="empty-text">{{viewMode === 'week' ? '本周还没有记录' : '本月还没有记录'}}</text>
      </view>
    </view>

    <!-- 月报：底部日历图例（与上方列表呼应） -->
    <view wx:if="{{viewMode === 'month'}}" class="monthly-legend-bento">
      <text class="monthly-legend-title">📅 日历图例</text>
      <view class="calendar-legend calendar-legend--compact">
        <view class="legend-item">
          <view class="legend-dot perfect"></view>
          <text>达标</text>
        </view>
        <view class="legend-item">
          <view class="legend-dot exceeded"></view>
          <text>超标</text>
        </view>
        <view class="legend-item">
          <view class="legend-dot insufficient"></view>
          <text>不足</text>
        </view>
        <view class="legend-item">
          <view class="legend-dot none"></view>
          <text>无记录</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 营养素详情弹层（点击碳水/蛋白质/脂肪） -->
  <view class="modal nutrient-modal {{showNutrientDetail ? 'show' : ''}}" catchtap="closeNutrientDetail">
    <view class="modal-content nutrient-modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">{{nutrientDetail.title || '营养素详情'}}</text>
        <text class="modal-close" bindtap="closeNutrientDetail">✕</text>
      </view>
      <view class="modal-body">
        <view class="nutrient-detail-summary">
          <view class="nutrient-detail-pill">{{nutrientDetail.scopeLabel}}</view>
          <view class="nutrient-detail-metrics">
            <text class="nutrient-detail-gram">{{nutrientDetail.grams}}g</text>
            <text class="nutrient-detail-percent">{{nutrientDetail.percent}}%</text>
            <text class="nutrient-detail-kcal">≈ {{nutrientDetail.kcal}} kcal</text>
          </view>
        </view>
        <view class="nutrient-detail-range">
          <text class="range-label">建议区间</text>
          <text class="range-value">{{nutrientDetail.rangeText}}</text>
        </view>
        <view class="nutrient-detail-tip">
          <text class="tip-title">{{nutrientDetail.levelLabel}}</text>
          <text class="tip-text">{{nutrientDetail.tip}}</text>
        </view>
      </view>
      <view class="modal-footer">
        <button class="btn-secondary" bindtap="closeNutrientDetail">知道了</button>
      </view>
    </view>
  </view>
</view>
