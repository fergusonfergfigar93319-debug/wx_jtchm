  border-bottom: 1rpx solid var(--color-border-light);
}

.summary-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.summary-label {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  margin-bottom: 8rpx;
}

.summary-value {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--color-success);
}

.recent-records {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.record-item {
  display: flex;
  align-items: center;
  padding: 16rpx;
  background: #F7F8FA;
  border-radius: 12rpx;
  transition: all 0.3s;
}

.record-item:active {
  transform: scale(0.98);
  background: #E8F5E9;
}

.record-time {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  width: 120rpx;
  margin-right: 20rpx;
}

.record-content {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.record-name {
  font-size: 26rpx;
  color: var(--color-text-primary);
}

.record-kcal {
  font-size: 24rpx;
  color: var(--color-success);
  font-weight: bold;
}

/* 健康报告 */
.report-preview {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.report-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx;
  background: linear-gradient(135deg, #F7F8FA 0%, #E8F5E9 100%);
  border-radius: 12rpx;
}

.report-label {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.report-value {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--color-success);
}

.report-actions {
  margin-top: 20rpx;
}

.report-button {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(135deg, var(--color-success) 0%, var(--color-primary-dark) 100%);
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
  border-radius: 40rpx;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.3);
}

.report-button:active {
  opacity: 0.8;
  transform: scale(0.98);
}

/* 周报图表 */
.weekly-chart-section {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid var(--color-border-light);
}

.chart-title-small {
  font-size: 24rpx;
  font-weight: bold;
  color: var(--color-text-primary);
  margin-bottom: 16rpx;
}

.weekly-chart {
  padding: 20rpx 0;
}

.chart-bars {
  display: flex;
  justify-content: space-around;
  align-items: flex-end;
  height: 200rpx;
  padding: 0 10rpx;
}

.chart-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  height: 100%;
  margin: 0 4rpx;
}

.bar-wrapper {
  flex: 1;
  width: 100%;
  display: flex;
  align-items: flex-end;
  margin-bottom: 8rpx;
  position: relative;
}

.bar-fill {
  width: 100%;
  background: linear-gradient(180deg, var(--color-success) 0%, var(--color-primary-light) 100%);
  border-radius: 8rpx 8rpx 0 0;
  min-height: 4rpx;
  transition: height 0.5s ease-out;
  position: relative;
}

.bar-fill::after {
  content: '';
  position: absolute;
  top: -2rpx;
  left: 0;
  right: 0;
  height: 2rpx;
  background: rgba(255, 255, 255, 0.3);
}

.bar-label {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  margin-bottom: 4rpx;
}

.bar-value {
  font-size: 20rpx;
  color: var(--color-text-secondary);
  font-weight: bold;
}

/* 营养素分布 */
.nutrition-distribution {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid var(--color-border-light);
}

.nutrition-rings {
  display: flex;
  justify-content: space-around;
  padding: 20rpx 0;
}

.nutrition-ring {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.ring-wrapper {
  position: relative;
  width: 100rpx;
  height: 100rpx;
  margin-bottom: 10rpx;
}

.ring-progress {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  position: relative;
  overflow: hidden;
}

.ring-progress::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  border-radius: 50%;
  border: 12rpx solid transparent;
  border-top-color: currentColor;
  border-right-color: currentColor;
  transform: rotate(calc(var(--progress) * 3.6deg - 90deg));
  transition: transform 0.5s ease-out;
}

.carb-ring {
  color: #FF9800;
  background: conic-gradient(
    from -90deg,
    #FF9800 0deg,
    #FF9800 calc(var(--progress) * 3.6deg),
    var(--color-border-light) calc(var(--progress) * 3.6deg),
    var(--color-border-light) 360deg
  );
}

.protein-ring {
  color: var(--color-secondary);
  background: conic-gradient(
    from -90deg,
    var(--color-secondary) 0deg,
    var(--color-secondary) calc(var(--progress) * 3.6deg),
    var(--color-border-light) calc(var(--progress) * 3.6deg),
    var(--color-border-light) 360deg
  );
}

.fat-ring {
  color: var(--color-success);
  background: conic-gradient(
    from -90deg,
    var(--color-success) 0deg,
    var(--color-success) calc(var(--progress) * 3.6deg),
    var(--color-border-light) calc(var(--progress) * 3.6deg),
    var(--color-border-light) 360deg
  );
}

.ring-text {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 1;
}

.ring-value {
  font-size: 24rpx;
  font-weight: bold;
  color: var(--color-text-primary);
  margin-bottom: 4rpx;
}

.ring-label {
  font-size: 20rpx;
  color: var(--color-text-tertiary);
}

/* 提醒设置 */
.reminder-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.reminder-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  background: #F7F8FA;
  border-radius: 14rpx;
  transition: all 0.3s;
}

.reminder-item:active {
  transform: scale(0.98);
}

.reminder-info {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.reminder-label {
  font-size: 26rpx;
  font-weight: bold;
  color: var(--color-text-primary);
  margin-bottom: 6rpx;
}

.reminder-desc {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
}
