  min-height: 120rpx;
}

/* 成就徽章 */
.badges-section {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid var(--color-border-light);
}

.badges-title {
  font-size: 26rpx;
  font-weight: bold;
  color: var(--color-text-primary);
  margin-bottom: 16rpx;
}

.badges-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
