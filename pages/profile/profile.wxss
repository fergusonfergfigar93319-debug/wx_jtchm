  margin-bottom: 8rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  margin-bottom: 4rpx;
}

.empty-hint {
  font-size: 22rpx;
  color: #CCC;
}

.empty-state.weight-empty {
