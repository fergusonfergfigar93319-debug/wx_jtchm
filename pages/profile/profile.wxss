/* 个人中心：层级清晰 · 留白 · 低饱和（简约） */

.page-profile {
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  min-height: 100vh;
  background: #f1f5f9;
  position: relative;
  z-index: 1;
}

.page-profile::before {
  content: '';
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 38vh;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.95) 0%, rgba(241, 245, 249, 0) 100%);
  pointer-events: none;
  z-index: 0;
}

/* 顶栏：一级信息面 */
.page-profile .header {
  padding: 12rpx 24rpx 14rpx;
  background: #ffffff;
  border-bottom: 1rpx solid rgba(15, 23, 42, 0.06);
  position: relative;
  z-index: 10;
}

.page-profile .status-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 20rpx;
  color: var(--neo-text-3);
  margin-bottom: 8rpx;
}

.page-profile .status-text {
  line-height: 1;
}

.page-profile .top-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.page-profile .header-title-wrap {
  flex: 1;
}

.page-profile .header-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #0f172a;
  letter-spacing: 0.5rpx;
}

.page-profile .header-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.page-profile .header-icon-wrap {
  padding: 8rpx;
  min-width: 48rpx;
  min-height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  font-size: 30rpx;
  border-radius: 14rpx;
  background: #f8fafc;
}

.profile-main {
  position: relative;
  z-index: 2;
}

@keyframes slideUpFade {
  from {
    opacity: 0;
    transform: translateY(28rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* ========== 身份区：毛玻璃名片 ========== */
.user-hero-card {
  position: relative;
  margin: 20rpx 24rpx 0;
  padding: 0;
  border-radius: 44rpx;
  overflow: hidden;
  border: 2rpx solid rgba(255, 255, 255, 0.95);
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.7) 0%, rgba(255, 255, 255, 0.45) 100%);
  backdrop-filter: blur(28px);
  -webkit-backdrop-filter: blur(28px);
  box-shadow: 0 12rpx 48rpx -8rpx rgba(15, 23, 42, 0.08), inset 0 2rpx 16rpx rgba(255, 255, 255, 0.6);
  animation: slideUpFade 0.55s cubic-bezier(0.16, 1, 0.3, 1) both;
  transform: translateZ(0);
}

.user-hero-card-glow {
  position: absolute;
  top: -40%;
  right: -20%;
  width: 60%;
  height: 90%;
  background: radial-gradient(circle at 70% 35%, rgba(52, 211, 153, 0.12) 0%, transparent 58%);
  pointer-events: none;
  z-index: 0;
}

.user-hero-inner {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 26rpx 22rpx 26rpx 20rpx;
  gap: 12rpx;
}

.hero-avatar-ring {
  flex-shrink: 0;
}

.user-hero-text {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  padding-top: 2rpx;
}

.user-name-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx 12rpx;
}

.user-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #0f172a;
  letter-spacing: 0.3rpx;
}

.goal-chip--hero {
  transform: scale(0.95);
  transform-origin: left center;
}

.user-greet {
  font-size: 26rpx;
  font-weight: 600;
  color: #334155;
  line-height: 1.35;
}

.user-tagline {
  font-size: 22rpx;
  color: #94a3b8;
  line-height: 1.4;
}

.user-signature {
  font-size: 22rpx;
  color: #64748b;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.user-medals--hero {
  margin-top: 4rpx;
  margin-bottom: 0;
}

.user-date-pill {
  align-self: flex-start;
  margin-top: 6rpx;
  padding: 6rpx 14rpx;
  font-size: 22rpx;
  color: #64748b;
  background: rgba(248, 250, 252, 0.95);
  border-radius: 999rpx;
  border: 1rpx solid rgba(15, 23, 42, 0.06);
}

.user-edit-btn {
  flex-shrink: 0;
  align-self: flex-start;
  margin-top: 8rpx;
  padding: 8rpx 4rpx 8rpx 12rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #0f9b7a;
  letter-spacing: 0.02em;
}

/* 社交紧凑条 */
.social-row-compact {
  display: flex;
  flex-direction: row;
  align-items: stretch;
  gap: 12rpx;
  margin: 20rpx 24rpx 0;
  animation: slideUpFade 0.5s cubic-bezier(0.16, 1, 0.3, 1) 0.05s both;
}

.social-pill {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 22rpx 10rpx;
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.9);
  box-shadow: 0 4rpx 20rpx rgba(15, 23, 42, 0.03);
  min-width: 0;
  transition: all 0.2s ease;
}
.social-pill:active {
  transform: scale(0.94);
  background: #ffffff;
}

.social-pill-num {
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
}

.social-pill-label {
  font-size: 20rpx;
  color: #94a3b8;
  margin-top: 6rpx;
  font-weight: 500;
}

/* ========== Bento 网格 ========== */
.bento-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  padding: 0 24rpx;
  margin-top: 20rpx;
  box-sizing: border-box;
}

.bento-item {
  background: linear-gradient(180deg, #ffffff 0%, #fdfdfd 100%);
  border-radius: 40rpx;
  padding: 30rpx 26rpx;
  box-shadow: 0 6rpx 28rpx -6rpx rgba(15, 23, 42, 0.06), inset 0 2rpx 4rpx rgba(255, 255, 255, 0.9);
  border: 1rpx solid rgba(15, 23, 42, 0.04);
  display: flex;
  flex-direction: column;
  position: relative;
  overflow: hidden;
  animation: slideUpFade 0.55s cubic-bezier(0.16, 1, 0.3, 1) both;
  transition: transform 0.25s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.25s ease;
}
.bento-item:active {
  transform: scale(0.96);
  border-color: rgba(16, 185, 129, 0.15);
  box-shadow: 0 4rpx 16rpx -4rpx rgba(15, 23, 42, 0.05);
}

.bento-large {
  grid-column: span 2;
  animation-delay: 0.08s;
}

.bento-square {
  grid-column: span 1;
  min-height: 200rpx;
  justify-content: space-between;
  animation-delay: 0.14s;
}

.bento-square--late {
  animation-delay: 0.18s;
}

.bento-header {
  margin-bottom: 20rpx;
}

.bento-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
  letter-spacing: 0.2rpx;
}

.bento-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #64748b;
  font-weight: 500;
}

.rings-container {
  display: flex;
  flex-direction: row;
  justify-content: space-around;
  align-items: center;
  padding: 8rpx 0 4rpx;
}

.bento-ring-unit {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  flex-shrink: 0;
}

.bento-ring-disk {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  box-sizing: border-box;
}

.bento-ring-carb {
  background: conic-gradient(
    from -90deg,
    #f59e0b 0deg,
    #f59e0b calc(var(--progress, 0) * 3.6deg),
    #e2e8f0 calc(var(--progress, 0) * 3.6deg),
    #e2e8f0 360deg
  );
}

.bento-ring-protein {
  background: conic-gradient(
    from -90deg,
    #e11d48 0deg,
    #e11d48 calc(var(--progress, 0) * 3.6deg),
    #e2e8f0 calc(var(--progress, 0) * 3.6deg),
    #e2e8f0 360deg
  );
}

.bento-ring-fat {
  background: conic-gradient(
    from -90deg,
    #0f9b7a 0deg,
    #0f9b7a calc(var(--progress, 0) * 3.6deg),
    #e2e8f0 calc(var(--progress, 0) * 3.6deg),
    #e2e8f0 360deg
  );
}

.bento-ring-meta {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}

.bento-ring-pct {
  font-size: 26rpx;
  font-weight: 700;
  color: #0f172a;
  line-height: 1.1;
}

.bento-ring-name {
  font-size: 20rpx;
  color: #64748b;
  margin-top: 4rpx;
  font-weight: 500;
}

.bento-icon-label {
  font-size: 22rpx;
  font-weight: 600;
  color: #64748b;
  letter-spacing: 0.04em;
}

.bento-value-row {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  flex-wrap: wrap;
  gap: 4rpx;
}

.bento-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #0f172a;
  line-height: 1.1;
  font-variant-numeric: tabular-nums;
}

.bento-value--muted {
  color: #94a3b8;
  font-weight: 600;
}

.bento-value-unit {
  font-size: 26rpx;
  font-weight: 600;
  color: #64748b;
}

.bento-foot {
  font-size: 22rpx;
  color: #94a3b8;
  margin-top: 4rpx;
}

/* ========== 内嵌分组列表 ========== */
.settings-group {
  margin: 24rpx 24rpx 20rpx;
  background: #ffffff;
  border-radius: 40rpx;
  overflow: hidden;
  border: 1rpx solid rgba(15, 23, 42, 0.04);
  box-shadow: 0 6rpx 28rpx -6rpx rgba(15, 23, 42, 0.05), inset 0 2rpx 4rpx rgba(255, 255, 255, 0.9);
  animation: slideUpFade 0.55s cubic-bezier(0.16, 1, 0.3, 1) 0.22s both;
}

.settings-item {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 28rpx;
  border-bottom: 1rpx solid #f1f5f9;
}

.settings-item:last-child {
  border-bottom: none;
}

.settings-item:active {
  background: #f8fafc;
}

.settings-item-left {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  min-width: 0;
}

.settings-icon {
  font-size: 32rpx;
  line-height: 1;
}

.settings-name {
  font-size: 28rpx;
  color: #1e293b;
  font-weight: 600;
}

.settings-item-right {
  display: flex;
  flex-direction: row;
  align-items: center;
  flex-shrink: 0;
  gap: 8rpx;
}

.settings-status {
  font-size: 26rpx;
  color: #94a3b8;
  max-width: 260rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.settings-arrow {
  font-size: 30rpx;
  color: #cbd5e1;
  font-weight: 300;
}

/* 身体档案与下方卡片：与 Bento 留白统一 */
.profile-main .section-card {
  margin-left: 24rpx;
  margin-right: 24rpx;
}

.profile-main .body-archive-card {
  margin-top: 20rpx;
}

.avatar-ring {
  flex-shrink: 0;
  padding: 6rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #a7f3d0 0%, #34d399 50%, #38bdf8 100%);
  border: 2rpx solid rgba(255, 255, 255, 0.8);
  box-shadow: 0 8rpx 24rpx rgba(52, 211, 153, 0.25), inset 0 2rpx 6rpx rgba(255, 255, 255, 0.5);
  position: relative;
}
.avatar-ring::after {
  content: '';
  position: absolute;
  top: -4rpx; left: -4rpx; right: -4rpx; bottom: -4rpx;
  border-radius: 50%;
  background: linear-gradient(180deg, rgba(255,255,255,0.6) 0%, transparent 100%);
  pointer-events: none;
}

.avatar-wrapper {
  position: relative;
}

/* 不依赖 Lottie 内 AE 表达式（eval）：用 CSS 模拟弹性缩放，与 personal.js 约 2.2s/圈 同步 */
.avatar-lottie-elastic {
  position: absolute;
  top: -6rpx;
  left: -6rpx;
  width: 132rpx;
  height: 132rpx;
  border-radius: 50%;
  overflow: hidden;
  transform-origin: 50% 50%;
  z-index: 1;
  pointer-events: none;
  animation: profileAvatarElastic 2.2s cubic-bezier(0.33, 1.15, 0.52, 1) infinite;
}

@keyframes profileAvatarElastic {
  0% {
    transform: scale(1);
  }
  9% {
    transform: scale(1.07);
  }
  18% {
    transform: scale(0.96);
  }
  27% {
    transform: scale(1.035);
  }
  36% {
    transform: scale(1);
  }
  100% {
    transform: scale(1);
  }
}

.avatar-lottie {
  display: block;
  width: 100%;
  height: 100%;
}

.avatar {
  position: relative;
  z-index: 2;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  flex-shrink: 0;
  object-fit: cover;
  background: var(--color-bg-muted);
  border: 3rpx solid rgba(255, 255, 255, 0.8);
  box-shadow: var(--shadow-md);
  transition: transform var(--transition-normal);
}

.avatar:active {
  transform: scale(0.95);
}

.avatar-placeholder {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-secondary) 100%);
}

.avatar-icon {
  font-size: 68rpx;
  opacity: 0.8;
}

.avatar-badge {
  position: absolute;
  z-index: 3;
  left: 50%;
  bottom: -6rpx;
  transform: translateX(-50%);
  max-width: 112rpx;
  padding: 4rpx 12rpx;
  background: rgba(15, 23, 42, 0.78);
  border-radius: 999rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.35);
  box-shadow: 0 6rpx 16rpx rgba(15, 23, 42, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-badge-text {
  font-size: 18rpx;
  color: #f8fafc;
  font-weight: 600;
  white-space: nowrap;
  line-height: 1.2;
}

.user-medals {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 8rpx;
}

.user-medal {
  width: 40rpx;
  height: 40rpx;
  border-radius: 12rpx;
  background: #f8fafc;
  border: 1rpx solid rgba(15, 23, 42, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
}

.user-medal-icon {
  font-size: 26rpx;
  line-height: 1;
}

.signature-block {
  align-self: stretch;
  display: flex;
  flex-direction: row;
  align-items: stretch;
  gap: 14rpx;
  margin-top: 12rpx;
  padding: 18rpx 20rpx;
  border-radius: 16rpx;
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.92) 0%, #f1f5f9 55%, #eef2f7 100%);
  border: 1rpx solid rgba(15, 23, 42, 0.07);
  box-shadow: 0 2rpx 12rpx rgba(15, 23, 42, 0.04);
  max-width: 100%;
  box-sizing: border-box;
}

.signature-accent-bar {
  width: 6rpx;
  min-height: 40rpx;
  align-self: stretch;
  border-radius: 6rpx;
  background: linear-gradient(180deg, #5eead4 0%, #38bdf8 45%, #22c55e 100%);
  flex-shrink: 0;
}

.signature-text {
  flex: 1;
  min-width: 0;
  font-size: 24rpx;
  color: #475569;
  line-height: 1.7;
  font-weight: 400;
  letter-spacing: 0.02em;
  word-break: break-word;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 4;
  overflow: hidden;
}

.goal-chip {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 5rpx 12rpx;
  background: #ecfdf5;
  color: #047857;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
  border: 1rpx solid rgba(16, 185, 129, 0.2);
}

.goal-chip-icon {
  font-size: 22rpx;
}

/* 社交数据：L2 次级信息区 */
.social-panel {
  display: flex;
  flex-direction: row;
  align-items: stretch;
  background: #f8fafc;
  border-radius: 16rpx;
  border: 1rpx solid rgba(15, 23, 42, 0.06);
  overflow: hidden;
  margin-bottom: 16rpx;
}

.social-cell {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 18rpx 8rpx;
  min-width: 0;
}

.social-divider {
  width: 1rpx;
  align-self: stretch;
  margin: 16rpx 0;
  background: linear-gradient(180deg, transparent, rgba(148, 163, 184, 0.35), transparent);
}

.social-stat-num {
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
  line-height: 1.15;
}

.social-stat-label {
  font-size: 20rpx;
  color: #94a3b8;
  margin-top: 6rpx;
  font-weight: 500;
}

/* 坚持记录：L3 入口条（线框 + 左色条，少渐变） */
.streak-banner {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 20rpx 20rpx;
  border-radius: 16rpx;
  background: #ffffff;
  border: 1rpx solid rgba(15, 23, 42, 0.08);
  box-shadow: inset 4rpx 0 0 0 #34d399;
}

.streak-banner-left {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 14rpx;
  flex: 1;
  min-width: 0;
}

.streak-emoji {
  font-size: 36rpx;
  line-height: 1;
  flex-shrink: 0;
}

.streak-copy {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
}

.streak-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #0f172a;
}

.streak-sub {
  font-size: 22rpx;
  color: #94a3b8;
  line-height: 1.45;
  font-weight: 400;
}

.streak-chevron {
  font-size: 32rpx;
  color: #cbd5e1;
  font-weight: 300;
  flex-shrink: 0;
}

/* 身体档案等卡片仍用 stat-value / stat-label 时保留 */
.stat-item {
  display: flex;
  flex-direction: column;
}

.stat-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  margin-bottom: 4rpx;
}

.stat-value {
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-bold);
  color: var(--color-success);
}

.stat-value.low {
  color: var(--color-secondary);
}

.stat-value.high {
  color: #ff9800;
}

.stat-value.very-high {
  color: #ff5252;
}

/* 卡片通用：L2 内容块（白底 · 轻阴影 · 统一边距） */
.section-card {
  margin: 0 24rpx 20rpx;
  padding: 28rpx 24rpx 30rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.95) 0%, rgba(255, 255, 255, 1) 100%);
  border-radius: 36rpx;
  border: 1rpx solid rgba(15, 23, 42, 0.04);
  box-shadow: 0 8rpx 32rpx rgba(15, 23, 42, 0.04), inset 0 2rpx 6rpx rgba(255, 255, 255, 0.8);
  animation: fadeInUp 0.55s cubic-bezier(0.16, 1, 0.3, 1);
  animation-fill-mode: both;
}

.section-card:nth-of-type(1) {
  animation-delay: 0.06s;
}

.section-card:nth-of-type(2) {
  animation-delay: 0.1s;
}

.section-card:nth-of-type(3) {
  animation-delay: 0.14s;
}

.section-card:nth-of-type(4) {
  animation-delay: 0.18s;
}

.section-card:nth-of-type(5) {
  animation-delay: 0.22s;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f1f5f9;
}

.card-title-wrapper {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.card-icon {
  font-size: 26rpx;
  opacity: 0.9;
}

.card-icon-chart {
  font-size: 28rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
  letter-spacing: 0.3rpx;
}

.card-arrow {
  font-size: 28rpx;
  color: #cbd5e1;
  font-weight: 300;
}

/* 身体档案 */
.body-data {
  margin-bottom: 24rpx;
}

.data-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

/* 身体档案：数据格（浅底区分层级） */
.body-archive-card .data-item-grid {
  display: flex;
  align-items: center;
  padding: 20rpx 18rpx;
  background: #f8fafc;
  border-radius: 14rpx;
  border: 1rpx solid rgba(15, 23, 42, 0.05);
  transition: background 0.2s ease;
}

.body-archive-card .data-item-grid:active {
  transform: scale(0.98);
}

.body-archive-card .data-item-grid.highlight {
  background: #ecfdf5;
  border-color: rgba(16, 185, 129, 0.2);
  grid-column: 1 / -1;
}

.data-item-grid {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #F7F8FA;
  border-radius: 14rpx;
  transition: all 0.3s;
}

.data-item-grid:active {
  transform: scale(0.98);
  background: #E8F5E9;
}

.data-item-grid.highlight {
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
  grid-column: 1 / -1;
}

.data-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.data-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.data-label {
  font-size: 22rpx;
  color: #94a3b8;
  font-weight: 500;
  margin-bottom: 6rpx;
}

.data-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #0f172a;
}

.highlight-value {
  color: #059669;
  font-size: 30rpx;
  font-weight: 700;
}

/* BMI指示器 */
.bmi-indicator {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid var(--color-border-light);
}

.bmi-bar {
  width: 100%;
  height: 12rpx;
  background: #E8E8E8;
  border-radius: 6rpx;
  overflow: visible;
  position: relative;
  margin-bottom: 16rpx;
}

.bmi-marker {
  position: absolute;
  top: 100%;
  left: 0;
  width: 4rpx;
  height: 16rpx;
  margin-left: -2rpx;
  margin-top: 4rpx;
  background: #9E9E9E;
  border-radius: 2rpx;
  transition: left 0.5s ease-out;
}

.bmi-fill {
  height: 100%;
  border-radius: 6rpx;
  transition: width 0.5s ease-out;
}

.bmi-fill.low {
  background: linear-gradient(90deg, var(--color-secondary) 0%, var(--color-secondary-light) 100%);
}

.bmi-fill.normal {
  background: linear-gradient(90deg, var(--color-success) 0%, var(--color-primary-light) 100%);
}

.bmi-fill.high {
  background: linear-gradient(90deg, #FF9800 0%, #FFB74D 100%);
}

.bmi-fill.very-high {
  background: linear-gradient(90deg, #FF5252 0%, #FF8A80 100%);
}

.bmi-labels {
  display: flex;
  justify-content: space-between;
  font-size: 22rpx;
  color: var(--color-text-tertiary);
}

.bmi-label {
  flex: 1;
  text-align: center;
}

/* 三大营养素 */
.macros-section {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid var(--color-border-light);
}

.macros-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #64748b;
  margin-bottom: 16rpx;
  letter-spacing: 0.5rpx;
}

.macros-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.macro-item {
  display: flex;
  flex-direction: column;
}

.macro-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.macro-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.macro-name {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text-primary);
}

.macro-value {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--color-success);
}

.macro-bar {
  width: 100%;
  height: 8rpx;
  background: var(--color-border-light);
  border-radius: 4rpx;
  overflow: hidden;
}

.macro-fill {
  height: 100%;
  border-radius: 4rpx;
  transition: width 0.5s ease-out;
}

.carb-fill {
  background: linear-gradient(90deg, #FF9800 0%, #FFB74D 100%);
}

.protein-fill {
  background: linear-gradient(90deg, #E53935 0%, #EF5350 100%);
}

.fat-fill {
  background: linear-gradient(90deg, #43A047 0%, #66BB6A 100%);
}

/* 每日营养素目标：图标与文字配色（橙/红/绿） */
.macro-icon-carb { filter: none; }
.macro-item.macro-carb .macro-name,
.macro-item.macro-carb .macro-value { color: #E65100; }
.macro-icon-protein { filter: none; }
.macro-item.macro-protein .macro-name,
.macro-item.macro-protein .macro-value { color: #C62828; }
.macro-icon-fat { filter: none; }
.macro-item.macro-fat .macro-name,
.macro-item.macro-fat .macro-value { color: #2E7D32; }

/* 体重图表 */
.weight-chart {
  width: 100%;
  height: 260rpx;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid var(--color-border-light);
  overflow: hidden;
  position: relative;
}

.chart-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #64748b;
  margin-bottom: 12rpx;
}

.chart-canvas {
  width: 100%;
  height: 100%;
  display: block;
}

/* 我的目标 */
.goal-cards {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.goal-card {
  flex: 1;
  padding: 18rpx 12rpx;
  background: #f8fafc;
  border-radius: 14rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  transition: border-color 0.2s ease, background 0.2s ease;
  border: 1rpx solid rgba(15, 23, 42, 0.06);
}

.goal-card:active {
  opacity: 0.92;
}

.goal-card.active {
  background: #ecfdf5;
  border-color: rgba(16, 185, 129, 0.35);
  box-shadow: none;
}

.goal-icon {
  font-size: 42rpx;
  margin-bottom: 10rpx;
}

.goal-name {
  font-size: 26rpx;
  font-weight: bold;
  color: var(--color-text-primary);
  margin-bottom: 6rpx;
}

.goal-desc {
  font-size: 20rpx;
  color: var(--color-text-tertiary);
  margin-bottom: 10rpx;
}

.goal-kcal {
  font-size: 24rpx;
  color: var(--color-success);
  font-weight: bold;
}

.custom-goal {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx;
  background: #F7F8FA;
  border-radius: 12rpx;
  margin-top: 12rpx;
}

.custom-goal-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.custom-goal-arrow {
  font-size: 28rpx;
  color: var(--color-text-tertiary);
}

/* 偏好设置 */
.preference-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.preference-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #F7F8FA;
  border-radius: 14rpx;
