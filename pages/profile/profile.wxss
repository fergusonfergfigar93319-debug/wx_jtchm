  background: linear-gradient(135deg, #FF6B35 0%, #FF8C5A 100%);
  border-radius: 16rpx;
  color: white;
}

.challenge-icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.challenge-icon {
  font-size: 48rpx;
}

.challenge-content {
  flex: 1;
}

.challenge-title {
  font-size: 32rpx;
  font-weight: 500;
  display: block;
  margin-bottom: 8rpx;
}

.challenge-desc {
  font-size: 24rpx;
  opacity: 0.9;
  display: block;
}

.challenge-arrow {
  font-size: 32rpx;
  opacity: 0.8;
}

/* 菜单列表 */
.menu-list {
  display: flex;
  flex-direction: column;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--color-border-light);
  transition: all 0.3s ease;
}

.menu-item .menu-label-wrapper {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.menu-item:active {
  transform: translateX(4rpx);
  background: rgba(76, 175, 80, 0.02);
  border-radius: 8rpx;
  padding-left: 12rpx;
  padding-right: 12rpx;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  margin-right: 16rpx;
}

.menu-label {
  flex: 1;
  font-size: 26rpx;
  color: var(--color-text-primary);
}

.core-badge-small {
  padding: 4rpx 10rpx;
  background: linear-gradient(135deg, #6BCB77 0%, #4ECDC4 100%);
  color: #FFFFFF;
  font-size: 18rpx;
  font-weight: 700;
  border-radius: 10rpx;
  margin-right: 12rpx;
  box-shadow: 0 2rpx 6rpx rgba(107, 203, 119, 0.3);
  letter-spacing: 0.5rpx;
}

.menu-desc {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  margin-top: 4rpx;
}

.menu-value {
  font-size: 26rpx;
  color: var(--color-text-tertiary);
  margin-right: 12rpx;
}

.menu-arrow {
  font-size: 32rpx;
  color: var(--color-text-tertiary);
}

/* 弹窗样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  animation: fadeIn 0.3s ease-out;
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

.modal-content {
  width: 90%;
  max-width: 600rpx;
  max-height: 80vh;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  animation: slideUp 0.3s ease-out;
}

@keyframes slideUp {
  from {
    transform: translateY(100rpx);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid var(--color-border-light);
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--color-text-primary);
}

.modal-close {
  font-size: 36rpx;
  color: var(--color-text-tertiary);
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: var(--color-bg-muted);
  transition: all 0.3s;
}

.modal-close:active {
  background: var(--color-border-light);
  transform: scale(0.9);
}

.modal-body {
  padding: 30rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.option-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.option-item {
  padding: 16rpx 32rpx;
  border: 2rpx solid var(--color-border-light);
  border-radius: 40rpx;
  font-size: 28rpx;
  color: var(--color-text-primary);
  background: var(--color-bg-muted);
  transition: all 0.3s;
}

.option-item.selected {
  background: linear-gradient(135deg, var(--color-success) 0%, var(--color-primary-dark) 100%);
  color: #fff;
  border-color: var(--color-success);
  box-shadow: 0 2rpx 8rpx rgba(76, 175, 80, 0.3);
}

.option-item:active {
  transform: scale(0.95);
}

.spiciness-section {
  margin-top: 40rpx;
  padding-top: 40rpx;
  border-top: 1rpx solid var(--color-border-light);
}

.spiciness-label {
  display: block;
  font-size: 28rpx;
  color: var(--color-text-primary);
  margin-bottom: 20rpx;
  text-align: center;
  font-weight: bold;
}

.spiciness-slider {
  margin: 20rpx 0;
}

.spiciness-labels {
  display: flex;
  justify-content: space-between;
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  margin-top: 12rpx;
}

.modal-footer {
  padding: 20rpx 30rpx 30rpx;
  border-top: 1rpx solid var(--color-border-light);
}

.modal-button {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, var(--color-success) 0%, var(--color-primary-dark) 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 44rpx;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.3);
  transition: all 0.3s;
}

.modal-button:active {
  opacity: 0.8;
  transform: scale(0.98);
}

/* 加载状态 */
.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--color-border-light);
  border-top-color: var(--color-success);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

/* 空状态 */
.empty-state {
  display: flex;
