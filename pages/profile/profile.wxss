}

.achievement-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  background: linear-gradient(135deg, #F7F8FA 0%, #E8F5E9 100%);
  border-radius: 14rpx;
  transition: all 0.3s;
}

.achievement-item:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.2);
}

.achievement-icon {
  font-size: 42rpx;
  margin-bottom: 10rpx;
}

.achievement-value {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--color-success);
