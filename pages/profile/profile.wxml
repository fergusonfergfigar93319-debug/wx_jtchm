<!--pages/profile/profile.wxml - 参照首页的简约设计-->
<view class="page-profile page-container">
  <custom-nav-bar title="我的" isScrolled="{{navScrolled}}" />
  <!-- 加载状态 -->
  <view class="loading-mask" wx:if="{{loading}}">
    <view class="loading-content">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>
  </view>

  <!-- 顶部栏（与首页风格统一，精简为标题 + 右侧入口） -->
  <view class="header">
    <view class="top-row">
      <view class="header-title-wrap">
        <text class="header-title">我的</text>
      </view>
      <view class="header-actions">
        <view
          class="header-icon-wrap pressable"
          bindtap="goToAINutritionist"
          hover-class="press-hover"
          hover-stay-time="80"
        >
          <text>🤖</text>
        </view>
        <view
          class="header-icon-wrap pressable"
          bindtap="goToShoppingList"
          hover-class="press-hover"
          hover-stay-time="80"
        >
          <text>🛒</text>
        </view>
        <view
          class="header-icon-wrap pressable"
          bindtap="showSettings"
          hover-class="press-hover"
          hover-stay-time="80"
        >
          <text>⚙️</text>
        </view>
      </view>
    </view>
  </view>

  <view class="profile-main">
  <!-- 身份区：毛玻璃名片（问候 + 日期 + 编辑） -->
  <view class="user-hero-card" wx:if="{{!loading || userInfo.nickname}}">
    <view class="user-hero-card-glow" aria-hidden="true"></view>
    <view class="user-hero-inner">
      <view class="avatar-ring hero-avatar-ring" catchtap="onAvatarTap" hover-class="press-hover" hover-stay-time="80">
        <view class="avatar-wrapper">
          <view class="avatar-lottie-elastic" wx:if="{{showAvatarLottie && userInfo.avatar}}">
            <canvas type="2d" id="profileLottie" class="avatar-lottie"></canvas>
          </view>
          <image class="avatar" wx:if="{{userInfo.avatar}}" src="{{avatarSrc}}" mode="aspectFill"></image>
          <view class="avatar avatar-placeholder" wx:else>
            <text class="avatar-icon">👤</text>
          </view>
          <view class="avatar-badge">
            <text class="avatar-badge-text">更新形象</text>
          </view>
        </view>
      </view>
      <view class="user-hero-text">
        <view class="user-name-row">
          <text class="user-name">{{userInfo.nickname || '美食探索家'}}</text>
          <view class="goal-chip goal-chip--hero" wx:if="{{userInfo.goal_type}}">
            <text class="goal-chip-icon">🎯</text>
            <text wx:if="{{userInfo.goal_type === 'lose'}}">减脂</text>
            <text wx:elif="{{userInfo.goal_type === 'gain'}}">增肌</text>
            <text wx:else>维持</text>
          </view>
        </view>
        <text class="user-greet">{{profileGreeting}}</text>
        <text class="user-tagline">你吃过的每一顿饭，都藏着健康密码 🌟</text>
        <text class="user-signature" wx:if="{{userInfo.signature}}">{{userInfo.signature}}</text>
        <view class="user-medals user-medals--hero" wx:if="{{featuredBadges && featuredBadges.length}}">
          <view class="user-medal" wx:for="{{featuredBadges}}" wx:key="id">
            <text class="user-medal-icon">{{item.icon}}</text>
          </view>
        </view>
        <view class="user-date-pill">{{currentDate}}</view>
      </view>
      <view class="user-edit-btn pressable" bindtap="editProfile" hover-class="press-hover" hover-stay-time="80">完善数字档案 ›</view>
    </view>
  </view>

  <!-- 社交数据：紧凑横条 -->
  <view class="social-row-compact" wx:if="{{!loading || userInfo.nickname}}">
    <view class="social-pill pressable" catchtap="editProfile" hover-class="press-hover" hover-stay-time="80">
      <text class="social-pill-num">{{userInfo.follow_count || 0}}</text>
      <text class="social-pill-label">关注</text>
    </view>
    <view class="social-pill pressable" catchtap="goToFans" hover-class="press-hover" hover-stay-time="80">
      <text class="social-pill-num">{{userInfo.fans_count || 0}}</text>
      <text class="social-pill-label">粉丝</text>
    </view>
    <view class="social-pill pressable" catchtap="editProfile" hover-class="press-hover" hover-stay-time="80">
      <text class="social-pill-num">{{userInfo.like_count || 0}}</text>
      <text class="social-pill-label">获赞</text>
    </view>
  </view>

  <!-- Bento：今日营养 + 双格指标 -->
  <view class="bento-grid" wx:if="{{!loading || userInfo.nickname}}">
    <view class="bento-item bento-large">
      <view class="bento-header">
        <text class="bento-title">今日能量环</text>
        <text class="bento-subtitle">已充能 {{todayConsumed}} / {{todayTarget}} kcal</text>
      </view>
      <view class="rings-container">
        <view class="bento-ring-unit">
          <view class="bento-ring-disk bento-ring-carb" style="--progress: {{carbsPct}}"></view>
          <view class="bento-ring-meta">
            <text class="bento-ring-pct">{{carbsPct}}%</text>
            <text class="bento-ring-name">碳水</text>
          </view>
        </view>
        <view class="bento-ring-unit">
          <view class="bento-ring-disk bento-ring-protein" style="--progress: {{proteinPct}}"></view>
          <view class="bento-ring-meta">
            <text class="bento-ring-pct">{{proteinPct}}%</text>
            <text class="bento-ring-name">蛋白质</text>
          </view>
        </view>
        <view class="bento-ring-unit">
          <view class="bento-ring-disk bento-ring-fat" style="--progress: {{fatPct}}"></view>
          <view class="bento-ring-meta">
            <text class="bento-ring-pct">{{fatPct}}%</text>
            <text class="bento-ring-name">脂肪</text>
          </view>
        </view>
      </view>
    </view>

    <view class="bento-item bento-square pressable" bindtap="editProfile" hover-class="press-hover" hover-stay-time="80">
      <text class="bento-icon-label">BMI</text>
      <view class="bento-value-row">
        <text class="bento-value" wx:if="{{bmi > 0}}">{{bmi}}</text>
        <text class="bento-value bento-value--muted" wx:else>--</text>
      </view>
      <text class="bento-foot">{{bmiStatusLabel}}</text>
    </view>

    <view class="bento-item bento-square bento-square--late pressable" bindtap="editProfile" hover-class="press-hover" hover-stay-time="80">
      <text class="bento-icon-label">充满热爱的</text>
      <view class="bento-value-row">
        <text class="bento-value">{{streakDays}}</text>
        <text class="bento-value-unit">天</text>
      </view>
      <text class="bento-foot">继续保持，你超棒的！</text>
    </view>
  </view>

  <!-- 身体档案 -->
  <view class="section-card card body-archive-card">
    <view class="card-header" bindtap="editProfile">
      <view class="card-title-wrapper">
        <text class="card-icon card-icon-chart">📊</text>
        <text class="card-title">身体数据舱</text>
      </view>
      <text class="card-arrow">›</text>
    </view>
    <view class="body-data">
      <view class="data-grid">
        <view class="data-item-grid">
          <text class="data-icon">📏</text>
          <view class="data-content">
            <text class="data-label">身高</text>
            <text class="data-value">{{userInfo.height || '--'}} cm</text>
          </view>
        </view>
        <view class="data-item-grid">
          <text class="data-icon">⚖️</text>
          <view class="data-content">
            <text class="data-label">体重</text>
            <text class="data-value">{{userInfo.weight || '--'}} kg</text>
          </view>
        </view>
        <view class="data-item-grid">
          <text class="data-icon">🎯</text>
          <view class="data-content">
            <text class="data-label">理想形态</text>
            <text class="data-value">{{userInfo.target_weight || '--'}} kg</text>
          </view>
        </view>
        <view class="data-item-grid highlight">
          <text class="data-icon">🔥</text>
          <view class="data-content">
            <text class="data-label">每日引力碑</text>
            <text class="data-value highlight-value">{{userInfo.daily_kcal_limit || '--'}} kcal</text>
          </view>
        </view>
      </view>
    </view>
    
    <!-- BMI健康状态指示（偏瘦|正常|偏胖|肥胖） -->
    <view class="bmi-indicator" wx:if="{{bmi > 0}}">
      <view class="bmi-bar">
        <view class="bmi-fill {{bmiStatus}}" style="width: {{bmiPercent}}%"></view>
        <view class="bmi-marker" style="left: {{bmiPercent}}%"></view>
      </view>
      <view class="bmi-labels">
        <text class="bmi-label">偏瘦</text>
        <text class="bmi-label">正常</text>
        <text class="bmi-label">偏胖</text>
        <text class="bmi-label">肥胖</text>
      </view>
    </view>

    <!-- 每日营养素目标（碳水/蛋白质/脂肪） -->
    <view class="macros-section" wx:if="{{macrosTarget}}">
      <view class="macros-title">每日营养素目标</view>
      <view class="macros-list">
        <view class="macro-item macro-carb">
          <view class="macro-header">
            <text class="macro-icon macro-icon-carb">🍞</text>
            <text class="macro-name">碳水</text>
            <text class="macro-value">{{macrosTarget.carb}}g</text>
          </view>
          <view class="macro-bar">
            <view class="macro-fill carb-fill" style="width: 100%"></view>
          </view>
        </view>
        <view class="macro-item macro-protein">
          <view class="macro-header">
            <text class="macro-icon macro-icon-protein">❤️</text>
            <text class="macro-name">蛋白质</text>
            <text class="macro-value">{{macrosTarget.protein}}g</text>
          </view>
          <view class="macro-bar">
            <view class="macro-fill protein-fill" style="width: 100%"></view>
          </view>
        </view>
        <view class="macro-item macro-fat">
          <view class="macro-header">
            <text class="macro-icon macro-icon-fat">🥑</text>
            <text class="macro-name">脂肪</text>
            <text class="macro-value">{{macrosTarget.fat}}g</text>
          </view>
          <view class="macro-bar">
            <view class="macro-fill fat-fill" style="width: 100%"></view>
          </view>
        </view>
      </view>
    </view>

    <!-- 体重记录 -->
    <view class="weight-chart" wx:if="{{weightHistory.length > 0}}">
      <view class="chart-title">体重趋势</view>
      <canvas canvas-id="weightChart" class="chart-canvas"></canvas>
    </view>
    <view class="empty-state weight-empty" wx:else>
      <text class="empty-icon">📊</text>
      <text class="empty-text">还没留下体重印记</text>
      <text class="empty-hint">今天，要记录下自己的蜕变吗？</text>
    </view>
  </view>

  <!-- 我的目标 -->
  <view class="section-card card">
    <view class="card-header">
      <view class="card-title-wrapper">
        <text class="card-icon">🎯</text>
        <text class="card-title">未来进阶地图</text>
      </view>
    </view>
    <view class="goal-cards">
      <view 
        class="goal-card {{userInfo.goal_type === 'lose' ? 'active' : ''}}" 
        bindtap="setGoal"
        data-goal="lose">
        <view class="goal-icon">🔥</view>
        <text class="goal-name">减脂</text>
        <text class="goal-desc">轻盈体态，控制摄入</text>
        <text class="goal-kcal" wx:if="{{userInfo.goal_type === 'lose'}}">{{goalKcal.lose}} kcal</text>
      </view>
      <view 
        class="goal-card {{userInfo.goal_type === 'maintain' ? 'active' : ''}}" 
        bindtap="setGoal"
        data-goal="maintain">
        <view class="goal-icon">⚖️</view>
        <text class="goal-name">维持</text>
        <text class="goal-desc">保持平衡，稳稳的幸福</text>
        <text class="goal-kcal" wx:if="{{userInfo.goal_type === 'maintain'}}">{{goalKcal.maintain}} kcal</text>
      </view>
      <view 
        class="goal-card {{userInfo.goal_type === 'gain' ? 'active' : ''}}" 
        bindtap="setGoal"
        data-goal="gain">
        <view class="goal-icon">💪</view>
        <text class="goal-name">增肌</text>
        <text class="goal-desc">强化力量，塑造线条</text>
        <text class="goal-kcal" wx:if="{{userInfo.goal_type === 'gain'}}">{{goalKcal.gain}} kcal</text>
      </view>
    </view>
    <view class="custom-goal" bindtap="editProfile">
      <text class="custom-goal-text">⚙️ 自定义目标设置</text>
      <text class="custom-goal-arrow">›</text>
    </view>
  </view>

  <!-- 内嵌分组列表（偏好与提醒） -->
  <view class="settings-group">
    <view class="settings-item pressable" bindtap="editTaste" hover-class="press-hover" hover-stay-time="80">
      <view class="settings-item-left">
        <text class="settings-icon">🌶️</text>
        <text class="settings-name">我的味蕾偏好</text>
      </view>
      <view class="settings-item-right">
        <text class="settings-status">{{spicinessLabelText}}</text>
        <text class="settings-arrow">›</text>
      </view>
    </view>
    <view class="settings-item pressable" bindtap="editAllergens" hover-class="press-hover" hover-stay-time="80">
      <view class="settings-item-left">
        <text class="settings-icon">🚫</text>
        <text class="settings-name">饮食避坑指南</text>
      </view>
      <view class="settings-item-right">
        <text class="settings-status">{{allergens.length ? allergens.length + ' 项' : '未设置'}}</text>
        <text class="settings-arrow">›</text>
      </view>
    </view>
    <view class="settings-item pressable" bindtap="openReminderSettings" hover-class="press-hover" hover-stay-time="80">
      <view class="settings-item-left">
        <text class="settings-icon">🔔</text>
        <text class="settings-name">贴心小闹钟</text>
      </view>
      <view class="settings-item-right">
        <text class="settings-status">{{reminders.meal || reminders.log || reminders.weight ? '已开启' : '未开启'}}</text>
        <text class="settings-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 账号与安全：退出登录 / 重新登录 -->
  <view class="section-card card account-section-card">
    <view class="card-header">
      <view class="card-title-wrapper">
        <text class="card-icon">🔐</text>
        <text class="card-title">账号保险箱</text>
      </view>
    </view>
    <view class="account-actions">
      <view
        class="account-row pressable"
        bindtap="onLogoutTap"
        hover-class="press-hover"
        hover-stay-time="80"
      >
        <view class="account-row-main">
          <text class="account-row-title">安全登出</text>
          <text class="account-row-desc">短暂离开，我会在下一餐等你回来</text>
        </view>
        <text class="account-row-arrow">›</text>
      </view>
      <view class="account-row-divider"></view>
      <view
        class="account-row pressable"
        bindtap="onReloginTap"
        hover-class="press-hover"
        hover-stay-time="80"
      >
        <view class="account-row-main">
          <text class="account-row-title">刷新连接</text>
          <text class="account-row-desc">换个状态，重新与世界建立连接</text>
        </view>
        <text class="account-row-arrow">›</text>
      </view>
    </view>
  </view>

  </view>

  <!-- 过敏源选择弹窗 -->
  <view class="modal-mask" wx:if="{{showAllergenModal}}" bindtap="closeAllergenModal">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">选择过敏源</text>
        <text class="modal-close" bindtap="closeAllergenModal">✕</text>
      </view>
      <view class="modal-body">
        <view class="option-grid">
          <view 
            class="option-item {{selectedAllergens.indexOf(item) > -1 ? 'selected' : ''}}"
            wx:for="{{allergenOptions}}" 
            wx:key="*this"
            bindtap="toggleAllergen"
            data-allergen="{{item}}">
            <text>{{item}}</text>
          </view>
        </view>
      </view>
      <view class="modal-footer">
        <button class="modal-button" bindtap="saveAllergens">保存</button>
      </view>
    </view>
  </view>

  <!-- 口味偏好选择弹窗 -->
  <view class="modal-mask" wx:if="{{showTasteModal}}" bindtap="closeTasteModal">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">选择口味偏好</text>
        <text class="modal-close" bindtap="closeTasteModal">✕</text>
      </view>
      <view class="modal-body">
        <view class="option-grid">
          <view 
            class="option-item {{selectedTastes.indexOf(item) > -1 ? 'selected' : ''}}"
            wx:for="{{tasteOptions}}" 
            wx:key="*this"
            bindtap="toggleTaste"
            data-taste="{{item}}">
            <text>{{item}}</text>
          </view>
        </view>
        <view class="spiciness-section">
          <text class="spiciness-label">辣度等级: {{spicinessLevel}}</text>
          <slider 
            class="spiciness-slider"
            min="0" 
            max="5" 
            step="1" 
            value="{{spicinessLevel}}" 
            bindchange="onSpicinessChange"
            activeColor="#FF5252"
            backgroundColor="#E0E0E0"
            block-color="#FF5252"
            block-size="20"/>
          <view class="spiciness-labels">
            <text>不辣</text>
            <text>微辣</text>
            <text>中辣</text>
            <text>重辣</text>
            <text>特辣</text>
            <text>变态辣</text>
          </view>
        </view>
      </view>
      <view class="modal-footer">
        <button class="modal-button" bindtap="saveTaste">保存</button>
      </view>
    </view>
  </view>
</view>
