  background: #F5F5F5;
  border-radius: 22rpx;
  overflow: hidden;
  position: relative;
}

.freshness-bar {
  height: 100%;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding-right: 12rpx;
  transition: width 0.5s ease-out;
  min-width: 60rpx;
}

.freshness-bar-text {
  font-size: 22rpx;
  color: #fff;
  font-weight: bold;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.2);
}

.freshness-label {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 24rpx;
  color: #666;
}

.freshness-color {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.freshness-name {
  flex: 1;
}

.freshness-count {
  color: #999;
  font-size: 22rpx;
}

.statistics-summary {
  margin-top: 24rpx;
  padding: 20rpx;
  background: linear-gradient(135deg, #F5F5F5 0%, #fff 100%);
  border-radius: 12rpx;
}

.summary-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.summary-item {
  display: flex;
  flex-direction: column;
  padding: 16rpx;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 12rpx;
}

.summary-label {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.summary-value {
  font-size: 28rpx;
  font-weight: bold;
  color: #34c759;
}

.summary-value.warning-text {
  color: #ff6b35;
}