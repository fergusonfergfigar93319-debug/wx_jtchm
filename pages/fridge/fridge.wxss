}

.subcategory-tag.active {
  background: linear-gradient(135deg, #FFF3E0 0%, #FFE0B2 100%);
  border-color: #ff6b35;
  color: #ff6b35;
  font-weight: bold;
}

.subcategory-tag:active {
  transform: scale(0.95);
}

/* 食材项子分类显示 */
.item-subcategory {
  margin-top: 6rpx;
}

.subcategory-text {
  font-size: 22rpx;
  color: #999;
  background: #F5F5F5;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  display: inline-block;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 30rpx;
  border-top: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}

