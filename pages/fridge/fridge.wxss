}

.detail-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  text-align: right;
  flex: 1;
}

.detail-value.expired-text {
  color: #FF5252;
  font-weight: bold;
}

.detail-value.expiring-text {
  color: #ff6b35;
  font-weight: bold;
}

.detail-actions {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 0 0;
  border-top: 1rpx solid #F5F5F5;
