}

/* 子分类选择器 */
.subcategory-selector {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #F5F5F5;
}

.subcategory-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.subcategory-tags {
