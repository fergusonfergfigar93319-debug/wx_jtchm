  margin-top: 8rpx;
}

.suggestion-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.protein-text {
  color: #2196F3;
}

.carbs-text {
  color: #ff6b35;
}

/* 空状态样式 */
.empty-state {
  text-align: center;
  padding: 100rpx 40rpx;
  animation: fadeInUp 0.5s ease-out;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
  animation: float 3s ease-in-out infinite;
}

@keyframes float {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-20rpx);
  }
}

.empty-text {
  font-size: 32rpx;
  color: #999;
  margin-bottom: 16rpx;
  display: block;
}

.empty-hint {
  font-size: 26rpx;
  color: #ccc;
  margin-bottom: 40rpx;
  display: block;
}

.mt-20 {
  margin-top: 20rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #34c759 0%, #2e7d32 100%);
  color: #fff;
  border: none;
  border-radius: 999rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.btn-primary:active {
  transform: scale(0.98);
  opacity: 0.95;
}

.btn-secondary {
  background: #f5f5f5;
  color: #666;
  border: none;
  border-radius: 999rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.btn-secondary:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.stat-item {
  cursor: pointer;
  transition: all 0.3s;
  position: relative;
}

.stat-item:active {
  transform: scale(0.95);
  opacity: 0.8;
}

.stat-item::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 0;
  height: 0;
  border-radius: 50%;
  background: rgba(76, 175, 80, 0.1);
  transform: translate(-50%, -50%);
  transition: width 0.4s ease, height 0.4s ease;
}

.stat-item:active::after {
  width: 200rpx;
  height: 200rpx;
}

.smart-tips-container {
  margin: 0 20rpx 20rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #FFF9E6 0%, #fff 100%);
