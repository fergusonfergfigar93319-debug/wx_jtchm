}

.smart-tips-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.smart-tips-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.smart-tips-close {
  font-size: 32rpx;
  color: #999;
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.05);
}

.smart-tips-close:active {
