}

/* 详情弹窗样式 */
.detail-modal {
  max-width: 700rpx;
}

.detail-section {
  padding: 20rpx 0;
}

.detail-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.detail-item:last-child {
  border-bottom: none;
}

.detail-label {
  font-size: 28rpx;
  color: #999;
