  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
  border-color: #34c759;
}

.category-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.category-name {
  font-size: 24rpx;
  color: #666;
}

.category-option.active .category-name {
