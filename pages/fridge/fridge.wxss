  background: linear-gradient(135deg, #E3F2FD 0%, #BBDEFB 100%);
  border-color: #2196F3;
  color: #2196F3;
  font-weight: bold;
}

.unit-selector {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
