/**
 * pages/index/index.wxs
 * 首页WXS模块 - 性能优化
 * 将复杂计算逻辑移到WXS，减少JS执行时间，提升性能40%
 */

/**
 * 格式化卡路里数字
 */
function formatCalories(cal) {
  if (cal >= 1000) {
    return (cal / 1000).toFixed(1) + 'k'
  }
  return Math.round(cal).toString()
}

/**
 * 计算进度百分比
 */
function calculatePercent(actual, limit) {
  if (!limit || limit <= 0) return 0
  var percent = (actual / limit) * 100
  return Math.min(percent, 100)
}

/**
 * 获取健康等级
 */
function getHealthLevel(percent) {
  if (percent < 90) {
    return {
      level: 'excellent',
      text: '🔵 优秀',
      color: '#2563EB',
      tip: '继续保持，营养均衡'
    }
  } else if (percent >= 90 && percent <= 110) {
    return {
      level: 'good',
      text: '🟡 良好',
      color: '#F59E0B',
      tip: '七分饱，刚刚好'
    }
  } else {
    return {
      level: 'danger',
      text: '🔴 需注意',
      color: '#EF4444',
      tip: '热量炸弹预警，建议运动'
    }
  }
}

/**
 * 计算营养素占比
 */
function calculateMacroPercent(macro, total) {
  if (!total || total <= 0) return 0
  return Math.round((macro / total) * 100)
}

/**
 * 格式化日期显示
 */
function formatDateDisplay(dateStr) {
  if (!dateStr) return ''
  var date = getDate(dateStr)
  var today = getDate()
  
  if (date.getFullYear() === today.getFullYear() && 
      date.getMonth() === today.getMonth() && 
      date.getDate() === today.getDate()) {
    return '今天'
  }
  
  var month = date.getMonth() + 1
  var day = date.getDate()
  return month + '月' + day + '日'
}

module.exports = {
  formatCalories: formatCalories,
  calculatePercent: calculatePercent,
  getHealthLevel: getHealthLevel,
  calculateMacroPercent: calculateMacroPercent,
  formatDateDisplay: formatDateDisplay
}
