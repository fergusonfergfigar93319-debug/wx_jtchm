/* pages/index/index.wxss - 课程风格首页 */

.page-index {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  background: linear-gradient(180deg, var(--neo-bg-0) 0%, #ffffff 72%);
}

.page-index::before {
  content: '';
  position: fixed;
  top: -8vh;
  left: -8vw;
  width: 56vw;
  height: 36vh;
  background: radial-gradient(ellipse at 30% 30%, rgba(45, 186, 142, 0.06) 0%, transparent 65%);
  pointer-events: none;
  z-index: 0;
}

.page-index::after {
  content: '';
  position: fixed;
  top: 12vh;
  right: -12vw;
  width: 44vw;
  height: 32vh;
  background: radial-gradient(ellipse at 70% 40%, rgba(99, 102, 241, 0.04) 0%, transparent 68%);
  pointer-events: none;
  z-index: 0;
}

.page-index.lite .header,
.page-index.lite .card,
.page-index.lite .course-card,
.page-index.lite .daily-card,
.page-index.lite .summary-card {
  box-shadow: none !important;
}

.page-index.lite .pressable {
  transition: none !important;
}

.page-index.lite .category-icon-enter {
  animation: none !important;
}

/* 轻量模式：跳过整页进入动画，避免低端机卡顿 */
.page-index.lite {
  animation: none !important;
}

/* 顶部栏 + 搜索 */
.header {
  padding: 16rpx 24rpx 12rpx;
  background: var(--neo-glass);
  box-shadow: var(--neo-shadow-soft);
  border-bottom: 1rpx solid var(--neo-border);
  backdrop-filter: blur(20rpx) saturate(120%);
  -webkit-backdrop-filter: blur(20rpx) saturate(120%);
  position: relative;
  z-index: 10;
}

.status-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 20rpx;
  color: var(--color-text-tertiary);
  margin-bottom: 8rpx;
}

.status-text {
  line-height: 1;
}

.top-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #E0E7FF 0%, #CCFBF1 48%, #F0FDFA 100%);
  flex-shrink: 0;
  overflow: hidden;
  position: relative;
}

.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  display: block;
}

.avatar-placeholder {
  width: 100%;
  height: 100%;
}

.header-icon-wrap {
  padding: 8rpx;
  min-width: 48rpx;
  min-height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.search-box {
  flex: 1;
  margin: 0 16rpx;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.95);
  border: 1rpx solid var(--neo-border);
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: var(--color-text-tertiary);
}

.search-icon {
  margin-right: 8rpx;
}

.search-placeholder {
  max-width: 400rpx;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.header-icons {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 32rpx;
}

.notification-dot {
  position: absolute;
  top: 4rpx;
  right: 2rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #f97316;
}

.pressable {
  transition: transform 0.15s ease-out, opacity 0.15s ease-out;
}

/* 问候与日期 */
.greeting-section {
  padding: 12rpx 24rpx 16rpx;
  background: rgba(255, 255, 255, 0.96);
  border-bottom: 1rpx solid var(--neo-border);
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.greeting-text {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.greeting-icon {
  font-size: 28rpx;
}

.greeting-date {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
}

/* 主体滚动区：在自定义顶栏 + 本页头图之下占满剩余视口，避免与底部 Tab 顶死 */
.main {
  flex: 1;
  min-height: 0;
  height: 0;
  position: relative;
  z-index: 1;
}

/* 首页枢纽：Bento + 进度环 + AI 入口 */
.index-hub {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin: 16rpx 24rpx 20rpx;
  padding: 28rpx 24rpx;
  gap: 24rpx;
  overflow: hidden;
  animation-delay: 0.06s;
}

.index-hub-left {
  flex-shrink: 0;
}

.index-hub-ring {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx -6rpx rgba(0, 0, 0, 0.06);
}

.index-hub-ring-inner {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: #ffffff;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
}

.index-hub-ring-pct {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  line-height: 1.2;
}

.index-hub-ring-sub {
  font-size: 20rpx;
  color: var(--color-text-tertiary);
  margin-top: 4rpx;
}

.index-hub-right {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.index-hub-greet {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  line-height: 1.35;
}

.index-hub-hint {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.45;
}

.index-hub-ai-btn {
  margin-top: 8rpx;
  align-self: flex-start;
  display: inline-flex;
  flex-direction: row;
  align-items: center;
  gap: 10rpx;
  padding: 16rpx 28rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, var(--color-brand, #4ade80) 0%, #34d399 100%);
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(74, 222, 128, 0.35);
}

.index-hub-ai-icon {
  font-size: 30rpx;
  line-height: 1;
}

/* 分类九宫格（对齐老版：高饱和纯色 squircle + 中心插画） */
.category-section {
  background: rgba(255, 255, 255, 0.98);
  border-top: 1rpx solid var(--neo-border);
  border-bottom: 1rpx solid var(--neo-border);
  padding: 0;
  box-sizing: border-box;
}

.category-scroll {
  padding: 0;
}

.category-pages {
  display: flex;
}

.category-page {
  width: 100%;
  padding: 16rpx 12rpx 8rpx;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  box-sizing: border-box;
  flex-shrink: 0;
}

.category-item {
  padding: 12rpx 0 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 功能入口：依次上浮进入（与全站动效曲线一致） */
@keyframes categoryCellIn {
  from {
    opacity: 0;
    transform: translate3d(0, 16rpx, 0) scale(0.94);
  }
  to {
    opacity: 1;
    transform: translate3d(0, 0, 0) scale(1);
  }
}

.category-icon-enter {
  animation: categoryCellIn 0.42s var(--ease-page-enter, cubic-bezier(0.22, 1, 0.36, 1)) both;
}

/* 老版首页：圆角方底（squircle）+ 扁平插画，高饱和纯色 */
.category-icon {
  width: 76rpx;
  height: 76rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
  transition: transform 0.2s ease;
  overflow: hidden;
  position: relative;
  color: #ffffff;
  font-size: 36rpx;
}

.category-icon-img {
  width: 48rpx;
  height: 48rpx;
  display: block;
  position: relative;
  z-index: 1;
}

/* 与 profile 顶部 AI 入口一致：方底内居中机器人 emoji */
.category-icon-emoji {
  font-size: 44rpx;
  line-height: 1;
  display: block;
  position: relative;
  z-index: 1;
}

.category-icon.green {
  background: #2EB88A;
}

.category-icon.orange {
  background: #EA8F5C;
}

.category-icon.blue {
  background: #5B9BD5;
}

.category-icon.pink {
  background: #E88A9E;
}

.category-icon.purple {
  background: #9B8AD4;
}

.category-icon.lavender {
  background: #B8AEE0;
}

/* 拍图识热量：与「点外卖」蓝区分，略浅蓝 */
.category-icon.lightBlue {
  background: #6BB8E8;
}

.category-item:active .category-icon,
.press-hover .category-icon {
  transform: scale(0.94);
}

.category-text {
  font-size: 22rpx;
  color: var(--color-text-primary);
  font-weight: 400;
  text-align: center;
  max-width: 100%;
  padding: 0 2rpx;
  line-height: 1.35;
  letter-spacing: 0.01em;
}

.category-dots {
  padding: 4rpx 0 16rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 8rpx;
}

.dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #e0e0e0;
  transition:
    width 0.28s ease,
    background 0.28s ease,
    border-radius 0.28s ease;
}

.dot.active {
  width: 18rpx;
  border-radius: 999rpx;
  background: var(--color-primary);
}

/* 横幅推广 */
.banner-section {
  padding: 16rpx 24rpx;
  background: transparent;
}

.banner-card {
  position: relative;
  border-radius: 24rpx;
  overflow: hidden;
  min-height: 240rpx;
}

.banner-image {
  width: 100%;
  height: 240rpx;
}

.banner-overlay {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  padding: 24rpx 28rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  background: linear-gradient(135deg, rgba(0, 0, 0, 0.45), rgba(0, 0, 0, 0.1));
  color: #ffffff;
}

.banner-title {
  font-size: 32rpx;
  font-weight: 600;
  max-width: 70%;
  line-height: 1.3;
}

.banner-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  opacity: 0.9;
}

.banner-btn {
  display: inline-flex;
  padding: 12rpx 32rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #ff6b35;
  font-size: 26rpx;
  font-weight: 500;
}

/* 精品课程推荐 */
.course-section {
  margin-top: 12rpx;
  background: #ffffff;
  padding-bottom: 20rpx;
}

.section-header {
  padding: 16rpx 24rpx 8rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
}

.section-more {
  font-size: 22rpx;
  color: #999999;
}

.course-list {
  padding: 8rpx 0 0 24rpx;
  white-space: nowrap;
}

.course-card {
  display: inline-block;
  width: 300rpx;
  margin-right: 20rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
}

.course-img {
  width: 100%;
  height: 180rpx;
}

.course-body {
  padding: 16rpx 16rpx 20rpx;
}

.course-title {
  font-size: 26rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 4rpx;
}

.course-sub {
  font-size: 22rpx;
  color: #999999;
}

/* 底部留白：避免小贴士被 tab 栏遮挡，保证可滚动到底部看全 */
.bottom-gap {
  height: 260rpx;
}

/* 今日概览 */
/* 一键选餐入口（与智能决策助手联动） */
.smart-choice-entry {
  margin: 0 24rpx 16rpx;
  padding: 24rpx 28rpx;
  background: linear-gradient(135deg, rgba(52, 199, 89, 0.12) 0%, rgba(76, 217, 100, 0.08) 100%);
  border: 1rpx solid rgba(52, 199, 89, 0.25);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.smart-choice-entry-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.smart-choice-entry-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(52, 199, 89, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

.smart-choice-entry-text {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.smart-choice-entry-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
}

.smart-choice-entry-desc {
  font-size: 24rpx;
  color: #666;
}

.smart-choice-entry-arrow {
  font-size: 40rpx;
  color: #34c759;
  font-weight: 300;
}

.summary-section {
  margin: 0 24rpx 16rpx;
  padding: 12rpx 20rpx;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
  display: flex;
  justify-content: space-between;
  align-items: stretch;
}

.summary-item {
  flex: 1;
  padding: 4rpx 8rpx;
  border-right: 1rpx solid #f0f0f0;
}

.summary-item:last-child {
  border-right: none;
}

.summary-label {
  display: block;
  font-size: 22rpx;
  color: #999999;
  margin-bottom: 6rpx;
}

.summary-value {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: #333333;
}

.summary-value.positive {
  color: #34c759;
}

.summary-value.negative {
  color: #ff6b6b;
}

/* 健康小贴士 - 精致高级感卡片 */
.tip-section {
  margin: 0 24rpx 28rpx;
  border-radius: 32rpx;
  overflow: hidden;
  animation: tipSectionEnter 0.55s ease-out both;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.04), 0 12rpx 40rpx rgba(194, 140, 90, 0.06);
}

.tip-section-inner {
  padding: 28rpx 28rpx 32rpx;
  background: linear-gradient(168deg, #fffefb 0%, #fffaf3 45%, #fff8ee 100%);
  border: 1rpx solid rgba(210, 170, 120, 0.12);
  border-radius: 32rpx;
  position: relative;
  overflow: hidden;
}

.tip-section-inner::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.9), transparent);
  opacity: 0.8;
}

@keyframes tipSectionEnter {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.tip-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.tip-title-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.tip-icon-badge {
  width: 52rpx;
  height: 52rpx;
  border-radius: 16rpx;
  background: linear-gradient(145deg, #fff9f0 0%, #ffefdc 50%, #ffe8d0 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(210, 150, 90, 0.15), inset 0 1rpx 0 rgba(255, 255, 255, 0.85);
  border: 1rpx solid rgba(230, 190, 140, 0.25);
}

.tip-icon-symbol {
  font-size: 28rpx;
}

.tip-title-block {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.tip-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2c2c2c;
  letter-spacing: 0.8rpx;
}

.tip-subtitle {
  font-size: 22rpx;
  color: #8e8e93;
  letter-spacing: 0.3rpx;
}

.tip-change-btn {
  padding: 14rpx 26rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(200, 160, 110, 0.28);
  background: rgba(255, 255, 255, 0.7);
  transition: transform 0.2s ease, background 0.2s ease, border-color 0.2s ease;
}

.tip-change-hover {
  transform: scale(0.97);
  background: rgba(255, 248, 240, 0.95);
  border-color: rgba(210, 160, 100, 0.35);
}

.tip-change-text {
  font-size: 24rpx;
  color: #b8860b;
  font-weight: 500;
  letter-spacing: 0.5rpx;
}

/* 进度条：5 秒倒计时 - 细线条 */
.tip-progress-wrap {
  margin-bottom: 22rpx;
}

.tip-progress-bg {
  height: 6rpx;
  background: rgba(210, 170, 120, 0.14);
  border-radius: 3rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.tip-progress-fill {
  height: 100%;
  width: 100%;
  border-radius: 3rpx;
  background: linear-gradient(90deg, #e8c9a0, #d4a574);
  transform-origin: left;
  animation: tipCountdown 5s linear forwards;
  box-shadow: 0 0 12rpx rgba(212, 165, 116, 0.25);
}

@keyframes tipCountdown {
  from { transform: scaleX(1); }
  to { transform: scaleX(0); }
}

.tip-progress-hint {
  font-size: 22rpx;
  color: #a0a0a5;
  letter-spacing: 0.2rpx;
}

/* 内容区 - 引用式文案框 */
.tip-box {
  position: relative;
  padding: 28rpx 28rpx 28rpx 40rpx;
  background: rgba(255, 255, 255, 0.65);
  border-radius: 20rpx;
  border: 1rpx solid rgba(220, 200, 170, 0.2);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.9), 0 2rpx 12rpx rgba(0, 0, 0, 0.02);
  overflow: hidden;
}

.tip-box-in {
  animation: tipBoxFadeIn 0.4s ease-out both;
}

@keyframes tipBoxFadeIn {
  from {
    opacity: 0;
    transform: translateY(10rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.tip-quote {
  position: absolute;
  left: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 3rpx;
  height: 56%;
  background: linear-gradient(180deg, transparent, rgba(200, 160, 110, 0.35), transparent);
  border-radius: 2rpx;
}

.tip-text {
  font-size: 28rpx;
  color: #3c3c3e;
  line-height: 1.8;
  letter-spacing: 0.6rpx;
  position: relative;
  z-index: 1;
}
