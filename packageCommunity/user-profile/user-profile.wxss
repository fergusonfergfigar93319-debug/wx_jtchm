.user-profile-page {
  min-height: 100vh;
  background: #f0f2f5;
  padding-bottom: calc(60rpx + env(safe-area-inset-bottom));
}

.user-profile-card {
  background: #fff;
  margin: 24rpx;
  border-radius: 24rpx;
  padding: 36rpx 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06), 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
}

.user-profile-header {
  display: flex;
  align-items: flex-start;
}

.user-profile-avatar-wrap {
  width: 152rpx;
  height: 152rpx;
  flex-shrink: 0;
  margin-right: 28rpx;
  padding: 6rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #a7f3d0 0%, #6BCB77 50%, #4CAF50 100%);
  box-sizing: border-box;
}

.user-profile-avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  display: block;
  background: #f5f5f5;
}

.user-profile-main {
  flex: 1;
  min-width: 0;
}

.user-profile-nickname {
  font-size: 38rpx;
  font-weight: 700;
  color: #1a1a1a;
  display: block;
  margin-bottom: 10rpx;
}

.user-profile-signature-wrap {
  display: flex;
  flex-direction: row;
  align-items: stretch;
  gap: 14rpx;
  margin-bottom: 28rpx;
  padding: 16rpx 18rpx;
  border-radius: 16rpx;
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.95) 0%, #f1f5f9 100%);
  border: 1rpx solid rgba(15, 23, 42, 0.06);
  box-shadow: 0 2rpx 10rpx rgba(15, 23, 42, 0.04);
  box-sizing: border-box;
}

.user-profile-signature-accent {
  width: 6rpx;
  min-height: 36rpx;
  align-self: stretch;
  border-radius: 6rpx;
  background: linear-gradient(180deg, #5eead4 0%, #38bdf8 45%, #22c55e 100%);
  flex-shrink: 0;
}

.user-profile-signature-text {
  flex: 1;
  min-width: 0;
  font-size: 26rpx;
  color: #475569;
  line-height: 1.65;
  word-break: break-word;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 4;
  overflow: hidden;
}

.user-profile-signature.placeholder {
  display: block;
  font-size: 26rpx;
  color: #999;
  line-height: 1.5;
  margin-bottom: 28rpx;
}

.user-profile-stats {
  display: flex;
  gap: 40rpx;
}

.user-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 80rpx;
}

.user-stat:active {
  opacity: 0.8;
}

.user-stat-num {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.user-stat-label {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
}

.user-profile-actions {
  margin-top: 32rpx;
  padding-top: 28rpx;
  border-top: 1rpx solid #f0f0f0;
}

.btn-follow {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #6BCB77 0%, #4CAF50 100%);
  color: #fff;
  border: none;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 6rpx 20rpx rgba(76, 175, 80, 0.35);
}

.btn-follow::after {
  border: none;
}

.btn-follow.followed {
  background: #f0f0f0;
  color: #666;
  box-shadow: none;
}

.btn-follow[disabled] {
  opacity: 0.8;
}

.user-section {
  margin: 24rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06), 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
}

.user-section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
  padding-left: 4rpx;
}

.user-posts-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.user-post-item {
  width: calc(33.333% - 12rpx);
  aspect-ratio: 1;
  border-radius: 14rpx;
  overflow: hidden;
  background: #f0f2f5;
}

.user-post-item:active {
  opacity: 0.9;
}

.user-post-cover,
.user-post-placeholder {
  width: 100%;
  height: 100%;
  display: block;
}

.user-post-desc {
  display: block;
  padding: 8rpx;
  font-size: 22rpx;
  color: #666;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.user-posts-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 72rpx 20rpx;
}

.user-posts-empty .empty-icon {
  font-size: 72rpx;
  margin-bottom: 20rpx;
  opacity: 0.6;
}

.user-posts-empty .empty-text {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.user-posts-empty .empty-desc {
  font-size: 24rpx;
  color: #999;
}

.user-profile-loading,
.user-profile-error {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 120rpx 40rpx;
  font-size: 28rpx;
  color: #666;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid #e8e8e8;
  border-top-color: #6BCB77;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.user-profile-loading .loading-text,
.user-profile-error .error-text {
  font-size: 28rpx;
  color: #999;
}

.btn-retry {
  margin-top: 28rpx;
  background: linear-gradient(135deg, #6BCB77 0%, #4CAF50 100%);
  color: #fff;
  border: none;
  border-radius: 44rpx;
  padding: 20rpx 56rpx;
  font-size: 28rpx;
}

.btn-retry::after {
  border: none;
}
