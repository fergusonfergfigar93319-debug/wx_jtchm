<!--pages/community/community.wxml-->
<view class="community-page">
  <!-- 顶部 Tab 栏 -->
  <view class="community-tabs">
    <view class="community-tab {{currentTab === 'feed' ? 'active' : ''}}" bindtap="switchTab" data-tab="feed">动态</view>
    <view class="community-tab {{currentTab === 'recipe' ? 'active' : ''}}" bindtap="switchTab" data-tab="recipe">菜谱</view>
    <view class="community-tab {{currentTab === 'restaurant' ? 'active' : ''}}" bindtap="switchTab" data-tab="restaurant">商家</view>
    <view class="community-tab-indicator tab-{{currentTab}}"></view>
  </view>

  <!-- 浮动发布按钮 -->
  <view class="community-fab" bindtap="showPublishModal">
    <text class="community-fab-icon">✏️</text>
    <text class="community-fab-text">分享</text>
  </view>

  <!-- 动态列表 -->
  <view class="community-list" wx:if="{{currentTab === 'feed'}}">
    <!-- 搜索与排序 -->
    <view class="feed-toolbar">
      <view class="feed-search-wrap">
        <text class="feed-search-icon">🔍</text>
        <input class="feed-search-input" placeholder="搜索动态、菜谱、商家" value="{{searchKeyword}}" bindinput="onSearchInput" bindconfirm="onSearchConfirm" bindblur="onSearchBlur" />
        <text class="feed-search-clear" wx:if="{{searchKeyword}}" bindtap="clearSearch" catchtap="stopPropagation">×</text>
      </view>
      <view class="feed-sort">
        <text class="feed-sort-item {{feedSortOrder === 'latest' ? 'active' : ''}}" bindtap="setFeedSort" data-order="latest">最新</text>
        <text class="feed-sort-div">|</text>
        <text class="feed-sort-item {{feedSortOrder === 'hot' ? 'active' : ''}}" bindtap="setFeedSort" data-order="hot">最热</text>
      </view>
    </view>
    <!-- 热门标签 -->
    <view class="feed-hot-tags">
      <text class="feed-hot-tag" wx:for="{{hotTags}}" wx:key="id" data-keyword="{{item.keyword}}" bindtap="applyHotTag">{{item.label}}</text>
    </view>
    <view class="feed-list-inner">
      <view class="feed-card" wx:for="{{displayFeedList}}" wx:key="id" bindtap="goToPostDetail" data-id="{{item.id}}">
        <view class="feed-card-header">
          <view class="feed-user-wrap" catchtap="goToUserProfile" data-userid="{{item.user.id}}">
            <image class="feed-avatar" src="{{item.user.avatar || '/images/default-avatar.png'}}" mode="aspectFill"></image>
            <view class="feed-meta">
              <text class="feed-author">{{item.user.nickname}}</text>
              <text class="feed-date">{{item.created_at}}</text>
            </view>
          </view>
          <view class="feed-tag tag-{{item.type}}">
            <text wx:if="{{item.type === 'recipe'}}">菜谱</text>
            <text wx:if="{{item.type === 'restaurant'}}">商家</text>
            <text wx:if="{{item.type === 'meal'}}">饮食</text>
            <text wx:if="{{item.type === 'sport'}}">运动</text>
          </view>
          <view class="feed-more-btn" catchtap="showPostMenu" data-item="{{item}}">⋯</view>
        </view>
        <view class="feed-card-body">
          <text class="feed-desc">{{item.content}}</text>
          <view class="feed-cover" wx:if="{{item.images && item.images.length}}">
            <image class="feed-cover-img" src="{{item.images[0]}}" mode="widthFix"></image>
          </view>
          <view class="feed-cover" wx:elif="{{item.image}}">
            <image class="feed-cover-img" src="{{item.image}}" mode="widthFix"></image>
          </view>
          <view class="feed-attach" wx:if="{{item.related_item}}" catchtap="stopPropagation">
            <image class="feed-attach-thumb" src="{{item.related_item.image}}" mode="aspectFill"></image>
            <view class="feed-attach-info">
              <text class="feed-attach-name">{{item.related_item.name}}</text>
              <text class="feed-attach-extra" wx:if="{{item.type === 'recipe'}}">🔥 {{item.related_item.calories}} 卡</text>
              <text class="feed-attach-extra" wx:if="{{item.type === 'restaurant'}}">⭐ {{item.related_item.rating}}</text>
            </view>
          </view>
          <view class="feed-sport-card" wx:if="{{item.type === 'sport' && item.sport_info}}" catchtap="stopPropagation">
            <text class="feed-sport-type">{{item.sport_info.type_name || '运动'}}</text>
            <view class="feed-sport-meta">
              <text wx:if="{{item.sport_info.duration}}">⏱ {{item.sport_info.duration}}分钟</text>
              <text wx:if="{{item.sport_info.distance}}">📏 {{item.sport_info.distance}}km</text>
              <text wx:if="{{item.sport_info.calories}}">🔥 {{item.sport_info.calories}}千卡</text>
            </view>
          </view>
        </view>
        <view class="feed-card-footer">
          <view class="feed-action {{item.is_liked ? 'liked' : ''}}" bindtap="toggleLike" data-id="{{item.id}}" catchtap="stopPropagation">
            <text class="feed-action-icon">{{item.is_liked ? '❤️' : '🤍'}}</text>
            <text class="feed-action-num">{{item.like_count || 0}}</text>
          </view>
          <view class="feed-action">
            <text class="feed-action-icon">💬</text>
            <text class="feed-action-num">{{item.comment_count || 0}}</text>
          </view>
          <view class="feed-action" bindtap="shareFeed" data-item="{{item}}" catchtap="stopPropagation">
            <text class="feed-action-icon">📤</text>
            <text class="feed-action-num">分享</text>
          </view>
        </view>
      </view>

      <view class="community-empty" wx:if="{{displayFeedList.length === 0 && !loading}}">
        <text class="community-empty-icon">{{searchKeyword ? '🔍' : '✨'}}</text>
        <text class="community-empty-title">{{searchKeyword ? '未找到相关动态' : '暂无动态'}}</text>
        <text class="community-empty-desc">{{searchKeyword ? '换个关键词试试' : '分享你的健康饮食，让更多人看见'}}</text>
      </view>

      <view class="community-load" wx:if="{{hasMore && loading}}"><text>加载中...</text></view>
      <view class="community-load" wx:if="{{!hasMore && displayFeedList.length > 0}}"><text>— 没有更多了 —</text></view>
    </view>
  </view>

  <!-- 菜谱分享列表 -->
  <view class="recipe-list" wx:if="{{currentTab === 'recipe'}}">
    <view class="recipe-item" wx:for="{{recipeList}}" wx:key="id" bindtap="goToRecipeDetail" data-id="{{item.recipe_id}}">
      <image class="recipe-image" src="{{item.recipe.image}}" mode="aspectFill"></image>
      <view class="recipe-info">
        <text class="recipe-name">{{item.recipe.name}}</text>
        <view class="recipe-meta">
          <text>🔥 {{item.recipe.calories}} 卡</text>
          <text>⏱️ {{item.recipe.cooking_time}}分钟</text>
        </view>
        <view class="recipe-user">
          <image class="user-avatar-small" src="{{item.user.avatar}}" mode="aspectFill"></image>
          <text class="user-name-small">{{item.user.nickname}}</text>
          <text class="share-time">{{item.created_at}}</text>
        </view>
      </view>
    </view>
    <view class="community-empty recipe-empty" wx:if="{{recipeList.length === 0 && !loading}}">
      <text class="community-empty-icon">🍲</text>
      <text class="community-empty-title">暂无菜谱分享</text>
      <text class="community-empty-desc">去动态里看看大家分享了什么菜谱</text>
    </view>
  </view>

  <!-- 商家分享列表 -->
  <view class="restaurant-list" wx:if="{{currentTab === 'restaurant'}}">
    <view class="restaurant-item" wx:for="{{restaurantList}}" wx:key="id" bindtap="goToRestaurantDetail" data-id="{{item.restaurant_id}}">
      <image class="restaurant-image" src="{{item.restaurant.image}}" mode="aspectFill"></image>
      <view class="restaurant-info">
        <text class="restaurant-name">{{item.restaurant.name}}</text>
        <view class="restaurant-meta">
          <text>⭐ {{item.restaurant.rating}}</text>
          <text>📍 {{item.restaurant.distance}}m</text>
        </view>
        <view class="restaurant-user">
          <image class="user-avatar-small" src="{{item.user.avatar}}" mode="aspectFill"></image>
          <text class="user-name-small">{{item.user.nickname}}</text>
          <text class="share-time">{{item.created_at}}</text>
        </view>
      </view>
    </view>
    <view class="community-empty restaurant-empty" wx:if="{{restaurantList.length === 0 && !loading}}">
      <text class="community-empty-icon">🏪</text>
      <text class="community-empty-title">暂无商家分享</text>
      <text class="community-empty-desc">发现好吃的店，分享给更多人</text>
    </view>
  </view>

  <!-- 发布分享弹窗 -->
  <view class="publish-modal {{showPublishModal ? 'show' : ''}}" bindtap="hidePublishModal">
    <view class="publish-modal-content" catch:tap="stopPropagation">
      <view class="publish-modal-header">
        <text class="publish-modal-title">分享到社区</text>
        <view class="publish-modal-close" bindtap="hidePublishModal">✕</view>
      </view>
      <scroll-view class="publish-modal-body" scroll-y>
        <!-- 1. 分享内容 -->
        <view class="publish-section">
          <text class="publish-section-label">分享内容</text>
          <textarea class="publish-textarea" placeholder="说说你的健康生活、美食心得…可输入文字、添加表情" value="{{publishContent}}" bindinput="onContentInput" maxlength="500"></textarea>
          <view class="publish-toolbar">
            <view class="publish-emoji-btn {{showEmojiPanel ? 'active' : ''}}" catchtap="toggleEmojiPanel">😀 表情</view>
            <text class="publish-char-count">{{publishContentLength}}/500</text>
          </view>
        </view>
        <!-- 2. 表情面板（展开时显示）；横向用 view+overflow 替代 scroll-x，减少真机点击被滚动层吞掉 -->
        <view class="publish-emoji-panel" wx:if="{{showEmojiPanel}}">
          <view class="emoji-scroll">
            <view class="emoji-list">
              <text class="emoji-item" wx:for="{{emojiList}}" wx:key="*this" data-index="{{index}}" catchtap="insertEmoji">{{item}}</text>
            </view>
          </view>
        </view>
        <!-- 3. 添加图片 -->
        <view class="publish-section">
          <text class="publish-section-label">添加图片</text>
          <view class="publish-images-list">
            <view class="publish-image-item" wx:for="{{publishImages || []}}" wx:key="*this">
              <image class="publish-image-preview" src="{{item}}" mode="aspectFill"></image>
              <view class="publish-image-del" bindtap="removePublishImage" data-index="{{index}}" catchtap="stopPropagation">×</view>
            </view>
            <button class="publish-image-add" wx:if="{{canAddMoreImages}}" bindtap="choosePublishImage" hover-class="publish-image-add-hover">+</button>
          </view>
        </view>
        <!-- 4. 分享类型 -->
        <view class="publish-section">
          <text class="publish-section-label">分享类型</text>
          <view class="publish-options">
            <view class="publish-option {{publishType === 'recipe' ? 'active' : ''}}" bindtap="selectShareType" data-type="recipe">
              <text class="publish-option-icon">🍲</text>
              <text class="publish-option-text">菜谱</text>
            </view>
            <view class="publish-option {{publishType === 'restaurant' ? 'active' : ''}}" bindtap="selectShareType" data-type="restaurant">
              <text class="publish-option-icon">🏪</text>
              <text class="publish-option-text">商家</text>
            </view>
            <view class="publish-option {{publishType === 'meal' ? 'active' : ''}}" bindtap="selectShareType" data-type="meal">
              <text class="publish-option-icon">🍽️</text>
              <text class="publish-option-text">饮食</text>
            </view>
            <view class="publish-option {{publishType === 'sport' ? 'active' : ''}}" bindtap="selectShareType" data-type="sport">
              <text class="publish-option-icon">🏃</text>
              <text class="publish-option-text">运动</text>
            </view>
          </view>
          <!-- 运动记录信息（仅当类型为运动时显示） -->
          <view class="publish-sport-section" wx:if="{{publishType === 'sport'}}">
            <view class="publish-sport-row">
              <text class="publish-section-label">运动类型</text>
              <view class="publish-sport-types">
                <text class="publish-sport-type {{sportType === 'run' ? 'active' : ''}}" data-type="run" bindtap="setSportType">跑步</text>
                <text class="publish-sport-type {{sportType === 'fitness' ? 'active' : ''}}" data-type="fitness" bindtap="setSportType">健身</text>
                <text class="publish-sport-type {{sportType === 'cycle' ? 'active' : ''}}" data-type="cycle" bindtap="setSportType">骑行</text>
                <text class="publish-sport-type {{sportType === 'swim' ? 'active' : ''}}" data-type="swim" bindtap="setSportType">游泳</text>
                <text class="publish-sport-type {{sportType === 'other' ? 'active' : ''}}" data-type="other" bindtap="setSportType">其他</text>
              </view>
            </view>
            <view class="publish-sport-row">
              <text class="publish-section-label">时长（分钟）</text>
              <input class="publish-sport-input" type="number" placeholder="如 30" value="{{sportDuration}}" bindinput="onSportDurationInput" />
            </view>
            <view class="publish-sport-row">
              <text class="publish-section-label">距离（公里，选填）</text>
              <input class="publish-sport-input" type="digit" placeholder="如 5" value="{{sportDistance}}" bindinput="onSportDistanceInput" />
            </view>
            <view class="publish-sport-row">
              <text class="publish-section-label">消耗约（千卡，选填）</text>
              <input class="publish-sport-input" type="number" placeholder="如 200" value="{{sportCalories}}" bindinput="onSportCaloriesInput" />
            </view>
          </view>
          <view class="publish-link-row" wx:if="{{(publishType === 'recipe' || publishType === 'restaurant') && shareName}}">
            <text class="publish-link-done">已选：{{shareName}}</text>
          </view>
          <view class="publish-link-row" wx:if="{{(publishType === 'recipe' || publishType === 'restaurant') && !shareName}}">
            <text class="publish-link" wx:if="{{publishType === 'recipe'}}" bindtap="goPickRecipe" catchtap="stopPropagation">选择要分享的菜谱</text>
            <text class="publish-link" wx:if="{{publishType === 'restaurant'}}" bindtap="goPickRestaurant" catchtap="stopPropagation">选择要分享的商家</text>
          </view>
        </view>
      </scroll-view>
      <!-- 5. 发布按钮（固定在底部） -->
      <view class="publish-footer">
        <button class="publish-btn {{hasContentToPublish && !publishing ? '' : 'disabled'}}" bindtap="submitPublish" disabled="{{!hasContentToPublish || publishing}}">
          {{publishing ? '发布中...' : '发布'}}
        </button>
      </view>
    </view>
  </view>

  <!-- 评论弹窗 -->
  <view class="comments-modal {{showCommentsModal ? 'show' : ''}}" bindtap="hideCommentsModal">
    <view class="modal-content comments-content" catch:tap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">评论 ({{currentComments.length}})</text>
        <text class="modal-close" bindtap="hideCommentsModal">✕</text>
      </view>
      <scroll-view class="comments-list" scroll-y>
        <view class="comment-item" wx:for="{{currentComments}}" wx:key="id">
          <image class="comment-avatar" src="{{item.user.avatar}}" mode="aspectFill"></image>
          <view class="comment-content">
            <text class="comment-user">{{item.user.nickname}}</text>
            <text class="comment-text">{{item.content}}</text>
            <text class="comment-time">{{item.created_at}}</text>
          </view>
        </view>
      </scroll-view>
      <view class="comment-input-area">
        <input class="comment-input" placeholder="写评论..." value="{{commentText}}" bindinput="onCommentInput" />
        <button class="comment-submit" bindtap="submitComment" disabled="{{!commentText || commenting}}">
          发送
        </button>
      </view>
    </view>
  </view>
</view>
