/* pages/community-post/community-post.wxss - 帖子详情与讨论 */
.post-page {
  min-height: 100vh;
  background: #f0f2f5;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.post-card {
  background: #fff;
  margin: 24rpx;
  border-radius: 24rpx;
  padding: 28rpx 26rpx;
  box-shadow: 0 6rpx 18rpx rgba(15, 23, 42, 0.06);
}

.post-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.post-user-wrap {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.post-header .user-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.post-header .user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.post-header .user-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 6rpx;
}

.post-time {
  font-size: 24rpx;
  color: #999;
}

.post-type-badge {
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.post-type-badge.type-recipe {
  background: #F0F7F4;
  color: #6BCB77;
}

.post-type-badge.type-restaurant {
  background: #FFF7ED;
  color: #F59E0B;
}

.post-type-badge.type-meal {
  background: #EFF6FF;
  color: #3B82F6;
}

.post-type-badge.type-sport {
  background: #FDF4FF;
  color: #a855f7;
}

.post-sport-card {
  margin-top: 16rpx;
  padding: 18rpx 20rpx;
  background: #faf5ff;
  border-radius: 14rpx;
  border: 1rpx solid #ede9fe;
}

.post-sport-type {
  font-size: 28rpx;
  font-weight: 600;
  color: #6d28d9;
  display: block;
  margin-bottom: 8rpx;
}

.post-sport-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
  font-size: 26rpx;
  color: #666;
}

.post-body {
  margin-bottom: 24rpx;
}

.post-text {
  font-size: 30rpx;
  color: #1a202c;
  line-height: 1.75;
  display: block;
  margin-bottom: 16rpx;
}

.post-media {
  margin: 16rpx 0;
  border-radius: 12rpx;
  overflow: hidden;
}

.post-media-multi .post-image {
  margin-bottom: 12rpx;
}

.post-media-multi .post-image:last-child {
  margin-bottom: 0;
}

.post-image {
  width: 100%;
  border-radius: 12rpx;
  max-height: 560rpx;
  display: block;
}

.related-card {
  display: flex;
  background: #f7fafc;
  border-radius: 16rpx;
  padding: 18rpx 20rpx;
  margin-top: 16rpx;
  border: 1rpx solid #e2e8f0;
}

.related-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
}

.related-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.related-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.related-meta {
  font-size: 24rpx;
  color: #666;
}

.post-actions {
  display: flex;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid #F0F0F0;
}

.post-actions .action-item {
  display: flex;
  align-items: center;
  margin-right: 48rpx;
  padding: 10rpx 0;
}

.post-actions .action-item.liked .action-icon {
  animation: heartBeat 0.3s;
}

@keyframes heartBeat {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.2); }
}

.post-actions .action-icon {
  font-size: 36rpx;
  margin-right: 8rpx;
}

.post-actions .action-count,
.post-actions .action-text {
  font-size: 26rpx;
  color: #666;
}

.post-actions .share-btn {
  background: none;
  border: none;
  margin: 0;
  padding: 10rpx 0;
  line-height: 1.2;
}

.post-actions .share-btn::after {
  border: none;
}

/* 讨论区 */
.section-title {
  padding: 24rpx 28rpx 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.comments-list {
  padding: 0 28rpx 40rpx;
}

.comment-item {
  display: flex;
  margin-bottom: 28rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx 22rpx;
  box-shadow: 0 2rpx 12rpx rgba(15, 23, 42, 0.04);
}

.comment-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.comment-body {
  flex: 1;
  min-width: 0;
}

.comment-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.comment-user {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.comment-time {
  font-size: 22rpx;
  color: #999;
}

.comment-text {
  font-size: 28rpx;
  color: #555;
  line-height: 1.55;
}

.empty-comments {
  text-align: center;
  padding: 60rpx 20rpx;
  font-size: 28rpx;
  color: #999;
}

.loading-wrap,
.error-wrap {
  text-align: center;
  padding: 120rpx 40rpx;
  font-size: 28rpx;
  color: #666;
}

.error-wrap .retry-btn {
  margin-top: 24rpx;
  background: #6BCB77;
  color: #fff;
  border: none;
  border-radius: 50rpx;
  padding: 16rpx 48rpx;
  font-size: 28rpx;
}

/* 底部回复栏 */
.reply-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #E5E5E5;
  display: flex;
  align-items: center;
  gap: 20rpx;
  z-index: 100;
}

.reply-input {
  flex: 1;
  height: 72rpx;
  padding: 0 24rpx;
  background: #F5F5F5;
  border-radius: 36rpx;
  font-size: 28rpx;
}

.reply-submit {
  flex-shrink: 0;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 36rpx;
  background: linear-gradient(135deg, #6BCB77 0%, #4CAF50 100%);
  color: #fff;
  border: none;
  border-radius: 36rpx;
  font-size: 28rpx;
}

.reply-submit[disabled] {
  background: #E5E5E5;
  color: #999;
}
