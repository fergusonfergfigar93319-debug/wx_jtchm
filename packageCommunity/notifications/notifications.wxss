.page {
  min-height: 100vh;
  background: #f7f7f7;
  padding: 24rpx 24rpx 40rpx;
  box-sizing: border-box;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.header-left {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #0f172a;
}

.header-sub {
  font-size: 24rpx;
  color: #94a3b8;
}

.header-right .mark-read-btn {
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(15, 23, 42, 0.06);
  font-size: 24rpx;
  color: #0f172a;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 20rpx 18rpx;
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 2rpx 10rpx rgba(15, 23, 42, 0.04);
  position: relative;
}

.item.is-read {
  opacity: 0.7;
}

.item-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(148, 163, 184, 0.12);
  flex-shrink: 0;
}

.item-icon.warning,
.item-icon.alert {
  background: rgba(248, 113, 113, 0.15);
}

.item-icon.ai {
  background: rgba(96, 165, 250, 0.15);
}

.item-main {
  flex: 1;
  min-width: 0;
}

.item-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 6rpx;
}

.item-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #0f172a;
  margin-right: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-time {
  font-size: 22rpx;
  color: #94a3b8;
  flex-shrink: 0;
}

.item-content {
  font-size: 24rpx;
  color: #475569;
  line-height: 1.6;
}

.item-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #f97316;
  position: absolute;
  top: 18rpx;
  right: 18rpx;
}

.empty {
  margin-top: 120rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  color: #94a3b8;
}

.empty-icon {
  font-size: 80rpx;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #475569;
}

.empty-desc {
  font-size: 24rpx;
  text-align: center;
  padding: 0 40rpx;
}

