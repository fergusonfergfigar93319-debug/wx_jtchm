<view class="page">
  <view class="header">
    <view class="header-left">
      <text class="header-title">消息通知</text>
      <text class="header-sub">健康提醒 · AI 建议 · 系统消息</text>
    </view>
    <view class="header-right" wx:if="{{unreadCount > 0}}">
      <view class="mark-read-btn" bindtap="markAllRead">
        <text>全部已读</text>
      </view>
    </view>
  </view>

  <view class="list" wx:if="{{notifications.length > 0}}">
    <block wx:for="{{notifications}}" wx:key="id">
      <view class="item {{item.read ? 'is-read' : ''}}" bindtap="openDetail" data-id="{{item.id}}">
        <view class="item-icon {{item.type}}">
          <text wx:if="{{item.type === 'warning' || item.type === 'alert'}}">⚠️</text>
          <text wx:elif="{{item.type === 'ai'}}">🤖</text>
          <text wx:else>🔔</text>
        </view>
        <view class="item-main">
          <view class="item-row">
            <text class="item-title">{{item.title}}</text>
            <text class="item-time">{{item.displayTime}}</text>
          </view>
          <text class="item-content">{{item.content}}</text>
        </view>
        <view class="item-dot" wx:if="{{!item.read}}"></view>
      </view>
    </block>
  </view>

  <view class="empty" wx:if="{{notifications.length === 0}}">
    <text class="empty-icon">🕊️</text>
    <text class="empty-title">暂无消息通知</text>
    <text class="empty-desc">AI 营养师的健康提醒、挑战提醒等会出现在这里</text>
  </view>
</view>

