/* pages/ai-nutritionist/ai-nutritionist.wxss */

.chat-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #F6FBFF 0%, #EEF6FF 48%, #FFFFFF 100%);
  overflow: hidden;
  position: relative;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
}

/* ===== Bright clean AI chat theme (local) ===== */
.chat-page {
  --neo-bg-0: #F6FBFF;
  --neo-bg-1: #EEF6FF;
  --neo-glass: rgba(255, 255, 255, 0.78);
  --neo-glass-2: rgba(255, 255, 255, 0.62);
  --neo-border: rgba(37, 99, 235, 0.12);
  --neo-text: rgba(15, 23, 42, 0.92);
  --neo-text-2: rgba(15, 23, 42, 0.72);
  --neo-text-3: rgba(15, 23, 42, 0.52);
  --neo-neon-a: #60A5FA;
  --neo-neon-b: #93C5FD;
  --neo-neon-c: #A78BFA;
  --neo-shadow: 0 18rpx 60rpx rgba(37, 99, 235, 0.16);
  --neo-shadow-soft: 0 12rpx 36rpx rgba(37, 99, 235, 0.12);

  /* 兼容本文件里少量旧变量命名（用于更干净的“精致”排版） */
  --color-accent: var(--neo-neon-a);
  --color-text-primary: var(--neo-text);
  --color-text-secondary: var(--neo-text-2);
  --color-text-tertiary: var(--neo-text-3);
  --shadow-sm: 0 10rpx 28rpx rgba(37, 99, 235, 0.12);
}

/* 页面顶部右侧：历史 / 新建（常驻可见，不随滚动消失） */
.page-header-actions {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 12rpx;
  padding: 8rpx 20rpx 10rpx;
  background: rgba(255, 255, 255, 0.94);
  border-bottom: 1rpx solid rgba(15, 23, 42, 0.06);
  box-shadow: 0 6rpx 22rpx rgba(15, 23, 42, 0.05);
  z-index: 2;
}

.header-action-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.95);
  border: 1rpx solid rgba(37, 99, 235, 0.1);
  box-shadow: 0 2rpx 12rpx rgba(37, 99, 235, 0.06);
  transition: transform 0.18s ease;
}

.header-action-hover {
  transform: scale(0.96);
}

.header-action-primary {
  background: linear-gradient(145deg, var(--neo-neon-b) 0%, var(--neo-neon-a) 100%);
  border-color: rgba(255,255,255,0.45);
  color: #fff;
  box-shadow: 0 6rpx 20rpx rgba(96, 165, 250, 0.25);
}

.header-action-icon {
  font-size: 28rpx;
  line-height: 1;
}

.header-action-label {
  font-size: 24rpx;
  color: inherit;
  font-weight: 500;
}

.header-action-primary .header-action-label {
  color: #fff;
}

.chat-page::before {
  content: '';
  position: fixed;
  inset: -18vh -18vw auto -18vw;
  width: 130vw;
  height: 55vh;
  background:
    radial-gradient(closest-side at 18% 18%, rgba(96, 165, 250, 0.12), rgba(96, 165, 250, 0) 58%),
    radial-gradient(closest-side at 82% 22%, rgba(167, 139, 250, 0.1), rgba(167, 139, 250, 0) 56%),
    linear-gradient(180deg, rgba(248, 250, 252, 0) 0%, rgba(246, 251, 255, 1) 70%);
  pointer-events: none;
  z-index: 0;
  filter: blur(18rpx);
}

/* scroll-view 在 flex 子项中必须限制高度，否则会随内容无限增高、无法纵向滚动 */
.chat-scroll {
  flex: 1;
  min-height: 0;
  height: 0;
  padding: 12rpx 0 8rpx;
  padding-bottom: calc(260rpx + env(safe-area-inset-bottom));
  position: relative;
  z-index: 1;
  box-sizing: border-box;
}

/* 顶部三键：独立一层，略浮于内容区 */
.actions-section {
  margin: 0 20rpx 8rpx;
  padding: 0;
  box-sizing: border-box;
}

/* 无消息：整块「内容台」，层次在状态卡 / 三键之下、对话之上 */
.home-panel {
  margin: 0 20rpx 14rpx;
  padding: 14rpx 14rpx 16rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.55);
  border: 1rpx solid rgba(37, 99, 235, 0.08);
  box-shadow:
    0 1rpx 0 rgba(255, 255, 255, 0.92) inset,
    0 12rpx 40rpx rgba(15, 23, 42, 0.06);
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  position: relative;
  z-index: 1;
}

.panel-section-label {
  font-size: 22rpx;
  font-weight: 700;
  color: var(--neo-text-2);
  letter-spacing: 0.02em;
  padding: 2rpx 4rpx 0;
  margin-top: 2rpx;
}

.panel-section-label--faq {
  margin-top: 6rpx;
}

/* 区块（用于减少卡片堆叠） */
.section {
  margin-bottom: 12rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
}

/* 顶部状态卡 */
.status-card {
  width: 100%;
  box-sizing: border-box;
  display: flex;
  gap: 0;
  background: rgba(255, 255, 255, 0.9);
  border: 1rpx solid rgba(15, 23, 42, 0.06);
  border-radius: 20rpx;
  padding: 14rpx 16rpx 12rpx;
  box-shadow: 0 6rpx 28rpx rgba(15, 23, 42, 0.06);
  margin: 0 20rpx 12rpx;
  backdrop-filter: blur(22rpx) saturate(160%);
  -webkit-backdrop-filter: blur(22rpx) saturate(160%);
  position: relative;
  overflow: hidden;
  transition: box-shadow 0.22s ease, border-color 0.22s ease, background 0.22s ease;
}

/* 精简 + 吸顶态 */
.status-card.is-compact {
  padding: 10rpx 14rpx 10rpx;
  margin: 0 20rpx 8rpx;
  position: sticky;
  top: 0rpx;
  z-index: 50;
}

/* 展开态：上标题行 + 圆环与宏量并排 + 底部一句提示 */
.status-expanded {
  width: 100%;
}

.status-expanded-inner {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.status-card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.status-remain-head {
  font-size: 26rpx;
  font-weight: 800;
  color: #2563EB;
  flex-shrink: 0;
  text-align: right;
  max-width: 52%;
  line-height: 1.35;
}

.status-remain-head.exceed {
  color: #fb7185;
}

.status-card-body {
  display: flex;
  flex-direction: row;
  align-items: stretch;
  gap: 18rpx;
  width: 100%;
}

.status-hint-line {
  margin-top: 4rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid rgba(37, 99, 235, 0.1);
}

.status-hint-line.is-compact {
  margin-top: 0;
  padding-top: 10rpx;
  border-top: none;
}

.status-hint-text {
  font-size: 22rpx;
  color: var(--neo-text-3);
  line-height: 1.5;
  font-weight: 500;
  display: block;
}

/* 精简态 */
.status-compact {
  width: 100%;
}

.status-compact-inner {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.status-compact-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.status-compact-row {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 14rpx;
}

.status-ring-compact {
  width: 68rpx;
  height: 68rpx;
}

.status-ring-center-compact {
  width: 50rpx;
  height: 50rpx;
}

.status-ring-center-compact .status-ring-value {
  font-size: 22rpx;
}

.status-ring-center-compact .status-ring-unit {
  font-size: 16rpx;
}

.status-title-compact {
  font-size: 22rpx;
}

.status-sub-compact {
  font-size: 18rpx;
  color: var(--neo-text-3);
}

.status-card::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: inherit;
  background: linear-gradient(135deg, rgba(96, 165, 250, 0.22), rgba(167, 139, 250, 0.16), rgba(244, 114, 182, 0.08));
  pointer-events: none;
  opacity: 1;
}

.status-card::after {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: inherit;
  opacity: 0; /* 纹理网格减法：让卡片更“干净” */
  pointer-events: none;
}

.status-left {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  align-self: center;
}

.status-ring {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  position: relative;
  overflow: hidden;
  box-shadow: 0 14rpx 34rpx rgba(37, 99, 235, 0.18);
}

.status-ring.status-ring-compact {
  width: 76rpx;
  height: 76rpx;
}

.status-ring-bg {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.status-ring-center {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.84);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 1rpx solid var(--neo-border);
  box-shadow: 0 14rpx 34rpx rgba(37, 99, 235, 0.12);
  backdrop-filter: blur(18rpx);
  -webkit-backdrop-filter: blur(18rpx);
}

.status-ring-center.status-ring-center-compact {
  width: 56rpx;
  height: 56rpx;
}

.status-ring-center.status-ring-center-compact .status-ring-value {
  font-size: 22rpx;
}

.status-ring-center.status-ring-center-compact .status-ring-unit {
  font-size: 16rpx;
}

.status-ring-value {
  font-size: 22rpx;
  font-weight: 800;
  color: var(--neo-text);
  line-height: 1.1;
  text-shadow: 0 0 16rpx rgba(167, 139, 250, 0.25);
}

.status-ring-unit {
  font-size: 18rpx;
  color: var(--neo-text-3);
}

.status-title {
  font-size: 28rpx;
  font-weight: 800;
  color: var(--neo-text);
  flex: 1;
  min-width: 0;
  line-height: 1.3;
}

.status-title.status-title-compact {
  font-size: 20rpx;
}

.status-sub {
  font-size: 22rpx;
  color: var(--neo-text-3);
  line-height: 1.35;
}

.status-sub.status-sub-compact {
  font-size: 18rpx;
}

.status-remain-head.status-remain-compact {
  font-size: 22rpx;
  max-width: 55%;
}

.status-macros {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  justify-content: center;
}

.macro-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.macro-name {
  width: 44rpx;
  font-size: 18rpx;
  color: var(--neo-text-3);
  flex-shrink: 0;
}

.macro-bar {
  flex: 1;
  height: 8rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 999rpx;
  overflow: hidden;
}

.macro-fill {
  height: 100%;
  border-radius: 999rpx;
  transition: width 0.2s ease;
}

.macro-fill.protein {
  background: linear-gradient(90deg, rgba(244, 114, 182, 1) 0%, rgba(167, 139, 250, 1) 60%, rgba(34, 211, 238, 1) 100%);
}

.macro-fill.carb {
  background: linear-gradient(90deg, rgba(34, 211, 238, 1) 0%, rgba(99, 102, 241, 1) 55%, rgba(167, 139, 250, 1) 100%);
}

.macro-fill.fat {
  background: linear-gradient(90deg, rgba(167, 139, 250, 1) 0%, rgba(244, 114, 182, 1) 100%);
}

.macro-val {
  font-size: 16rpx;
  color: var(--neo-text-2);
  flex-shrink: 0;
}

.macro-right {
  width: 104rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 2rpx;
  flex-shrink: 0;
}

.macro-pct {
  font-size: 16rpx;
  color: var(--neo-text-3);
}

/* 容错：防止右侧数值在窄屏被裁切 */
.macro-right {
  min-width: 0;
  max-width: 104rpx;
  overflow: hidden;
}

.macro-val {
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.macro-pct {
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 小屏优化：防止顶部概览卡信息挤压溢出 */
@media (max-width: 750rpx) {
  .status-card {
    gap: 8rpx;
  }

  .status-ring {
    width: 78rpx;
    height: 78rpx;
  }

  .status-ring-center {
    width: 56rpx;
    height: 56rpx;
  }

  .status-ring-center .status-ring-value {
    font-size: 20rpx;
  }

  .status-ring-center .status-ring-unit {
    font-size: 16rpx;
  }

  .status-title {
    font-size: 22rpx;
  }

  .status-remain-head {
    font-size: 22rpx;
  }

  .status-hint-text {
    font-size: 20rpx;
  }

  .macro-name {
    width: 42rpx;
    font-size: 16rpx;
  }

  .macro-right {
    width: 98rpx;
  }

  .macro-val {
    font-size: 16rpx;
  }

  .macro-pct {
    font-size: 14rpx;
  }
}

/* 更窄屏：例如 390~430px 对应的小屏，进一步保证不被裁切 */
@media (max-width: 430rpx) {
  .status-card {
    margin: 0 18rpx 14rpx;
    padding: 14rpx 14rpx 12rpx;
  }

  .status-ring {
    width: 72rpx;
    height: 72rpx;
  }

  .status-ring-center {
    width: 52rpx;
    height: 52rpx;
  }

  .status-ring-center .status-ring-value {
    font-size: 18rpx;
  }

  .status-ring-center .status-ring-unit {
    font-size: 14rpx;
  }

  .status-title {
    font-size: 20rpx;
  }

  .status-sub {
    font-size: 16rpx;
  }

  .status-remain-head {
    font-size: 20rpx;
  }

  .status-hint-text {
    font-size: 18rpx;
  }

  .macro-name {
    width: 36rpx;
    font-size: 14rpx;
  }

  .macro-right {
    width: 86rpx;
    max-width: 86rpx;
  }

  .macro-val {
    font-size: 12rpx;
  }

  .macro-pct {
    font-size: 10rpx;
  }
}

/* 核心入口（更轻的行动区） */
.actions-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8rpx;
  width: 100%;
  box-sizing: border-box;
}

.action-item {
  background: rgba(255, 255, 255, 0.78);
  border: 1rpx solid var(--neo-border);
  border-radius: 14rpx;
  padding: 10rpx 6rpx;
  box-shadow: 0 4rpx 18rpx rgba(15, 23, 42, 0.05);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 3rpx;
  min-width: 0;
  overflow: hidden;
  transition: transform 0.15s ease-out, opacity 0.15s ease-out, background 0.2s ease, border-color 0.2s ease;
  backdrop-filter: blur(18rpx) saturate(160%);
  -webkit-backdrop-filter: blur(18rpx) saturate(160%);
  position: relative;
}

.action-item::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: inherit;
  padding: 1rpx;
  background: linear-gradient(135deg, rgba(34, 211, 238, 0.45), rgba(167, 139, 250, 0.35), rgba(244, 114, 182, 0.25));
  -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
  pointer-events: none;
  opacity: 0.65;
}

.action-icon {
  font-size: 28rpx;
  filter: none;
  line-height: 1;
}

.action-text {
  font-size: 22rpx;
  color: var(--neo-text);
  font-weight: 700;
  line-height: 1.15;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 100%;
}

.smart-chips {
  width: 100%;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.chip.chip-soft {
  background: var(--neo-glass);
  border: 1rpx solid var(--neo-border);
  color: var(--neo-text);
  box-shadow: 0 0 0 1rpx rgba(167, 139, 250, 0.10);
}

/* 历史 .welcome 已并入 .home-panel，保留类名兼容若其它处引用 */

.welcome-title {
  font-size: 34rpx;
  font-weight: 800;
  color: var(--color-text-primary);
  margin-bottom: 10rpx;
}

.welcome-desc {
  font-size: 26rpx;
  color: var(--color-text-tertiary);
  line-height: 1.7;
  padding: 0 30rpx;
  margin-bottom: 22rpx;
}

.prompt-title {
  width: 100%;
  text-align: left;
  font-size: 26rpx;
  font-weight: 700;
  color: #0f172a;
  margin: 6rpx 0 14rpx;
  padding: 0 6rpx;
}

.prompt-chips {
  width: 100%;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.chip {
  padding: 14rpx 22rpx;
  background: rgba(255, 107, 53, 0.08);
  border: 1rpx solid rgba(255, 107, 53, 0.18);
  border-radius: 999rpx;
  font-size: 26rpx;
  color: #ff6b35;
  font-weight: 600;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.04);
  transition: transform 0.15s ease-out, opacity 0.15s ease-out;
}

.chip-hover {
  transform: scale(0.96);
  opacity: 0.9;
}

/* 消息列表 */
.msg-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  padding: 4rpx 20rpx 0;
  box-sizing: border-box;
}

.msg-row {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
}

.msg-row.is-user {
  flex-direction: row-reverse;
}

.msg-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  flex-shrink: 0;
}

.avatar-ai {
  background: linear-gradient(135deg, rgba(34, 211, 238, 0.95) 0%, rgba(167, 139, 250, 0.95) 55%, rgba(244, 114, 182, 0.90) 100%);
  box-shadow: 0 0 18rpx rgba(167, 139, 250, 0.18), 0 10rpx 28rpx rgba(37, 99, 235, 0.12);
}

.avatar-user {
  background: rgba(37, 99, 235, 0.12);
  border: 1rpx solid rgba(37, 99, 235, 0.18);
  box-shadow: 0 14rpx 34rpx rgba(37, 99, 235, 0.12);
  backdrop-filter: blur(18rpx);
  -webkit-backdrop-filter: blur(18rpx);
}

.msg-bubble {
  max-width: 72%;
  border-radius: 24rpx;
  padding: 18rpx 20rpx;
  box-shadow: var(--neo-shadow-soft);
  border: 1rpx solid rgba(37, 99, 235, 0.14);
  background: rgba(255, 255, 255, 0.86);
  backdrop-filter: blur(18rpx) saturate(160%);
  -webkit-backdrop-filter: blur(18rpx) saturate(160%);
  overflow: hidden;
  position: relative;
  transition: box-shadow 0.22s ease, transform 0.18s ease, background 0.22s ease;
}

.msg-bubble::after {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: inherit;
  opacity: 0; /* 纹理减法：让消息内容更“轻” */
  pointer-events: none;
}

.bubble-ai {
  border-radius: 24rpx 24rpx 24rpx 8rpx;
}

.bubble-user {
  background: linear-gradient(155deg, rgba(186, 210, 255, 0.55) 0%, rgba(142, 173, 255, 0.42) 45%, rgba(167, 139, 250, 0.2) 100%);
  border: 1rpx solid rgba(37, 99, 235, 0.2);
  box-shadow: 0 18rpx 52rpx rgba(37, 99, 235, 0.12);
  border-radius: 24rpx 24rpx 8rpx 24rpx;
}

.bubble-user::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: inherit;
  padding: 1rpx;
  background: linear-gradient(135deg, rgba(96, 165, 250, 0.55), rgba(167, 139, 250, 0.35), rgba(244, 114, 182, 0.18));
  -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
  pointer-events: none;
  opacity: 0.75;
}

.msg-text-row {
  display: inline-block;
  max-width: 100%;
  vertical-align: top;
  line-height: 1.8;
}

.msg-text {
  font-size: 30rpx;
  line-height: 1.8;
  color: var(--neo-text);
  word-break: break-word;
  white-space: pre-wrap;
  display: inline;
}

.stream-cursor {
  font-size: 28rpx;
  line-height: 1.8;
  color: var(--neo-neon-a);
  font-weight: 300;
  animation: streamBlink 0.95s ease-in-out infinite;
  display: inline;
  vertical-align: baseline;
  margin-left: 2rpx;
}

@keyframes streamBlink {
  0%,
  45% {
    opacity: 1;
  }
  50%,
  100% {
    opacity: 0.12;
  }
}

.bubble-ai.is-streaming {
  box-shadow: 0 14rpx 44rpx rgba(37, 99, 235, 0.14);
}

.bubble-user .msg-text {
  color: rgba(15, 23, 42, 0.92);
  font-weight: 600;
}

.msg-meta {
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid rgba(37, 99, 235, 0.12);
  display: flex;
  justify-content: flex-start;
}

.bubble-user .msg-meta {
  border-top-color: rgba(37, 99, 235, 0.16);
}

.msg-time {
  font-size: 20rpx;
  color: rgba(15, 23, 42, 0.48);
}

.bubble-user .msg-time {
  color: rgba(15, 23, 42, 0.58);
}

/* 追问 chips */
.follow-up {
  margin-top: 14rpx;
}

.follow-scroll {
  white-space: nowrap;
}

.follow-chip {
  display: inline-block;
  margin-right: 12rpx;
  padding: 12rpx 18rpx;
  background: var(--neo-glass);
  border: 1rpx solid var(--neo-border);
  border-radius: 999rpx;
  font-size: 24rpx;
  color: rgba(15, 23, 42, 0.78);
  font-weight: 600;
  transition: transform 0.15s ease-out, opacity 0.15s ease-out;
}

/* 思考中（嵌入气泡内） */
.thinking-inline {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  min-height: 40rpx;
  position: relative;
  overflow: hidden;
  border-radius: 16rpx;
}

.thinking-inline::after {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: inherit;
  background: linear-gradient(
    110deg,
    rgba(96, 165, 250, 0) 0%,
    rgba(96, 165, 250, 0.18) 28%,
    rgba(96, 165, 250, 0) 56%
  );
  transform: translateX(-80%);
  animation: neoShimmer 1.2s ease-in-out infinite;
  pointer-events: none;
  opacity: 0.4;
}

.thinking {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
}

.thinking::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(
    110deg,
    rgba(96, 165, 250, 0.00) 0%,
    rgba(96, 165, 250, 0.22) 28%,
    rgba(96, 165, 250, 0.00) 56%
  );
  transform: translateX(-80%);
  animation: neoShimmer 1.2s ease-in-out infinite;
  pointer-events: none;
  opacity: 0.45; /* 减弱“正在思考”特效 */
}

.dots {
  display: flex;
  gap: 8rpx;
  align-items: center;
}

.dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--neo-neon-a) 0%, var(--neo-neon-b) 55%, var(--neo-neon-c) 100%);
  animation: dotBounce 1.3s ease-in-out infinite;
  opacity: 0.7;
  box-shadow: 0 0 14rpx rgba(34, 211, 238, 0.18);
}

.dot:nth-child(2) {
  animation-delay: 0.15s;
}

.dot:nth-child(3) {
  animation-delay: 0.3s;
}

@keyframes dotBounce {
  0%, 60%, 100% {
    transform: translateY(0);
    opacity: 0.5;
  }
  30% {
    transform: translateY(-10rpx);
    opacity: 1;
  }
}

.thinking-text {
  font-size: 24rpx;
  color: var(--neo-text-3);
  font-weight: 600;
}

@keyframes neoShimmer {
  0% { transform: translateX(-90%); opacity: 0.0; }
  15% { opacity: 0.9; }
  60% { opacity: 0.6; }
  100% { transform: translateX(120%); opacity: 0.0; }
}

.scroll-anchor {
  height: 2rpx;
}

/* 底部输入栏（含历史/新建工具栏） */
.composer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 12rpx 16rpx;
  padding-bottom: calc(12rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, rgba(248, 250, 252, 0.72) 0%, rgba(255, 255, 255, 0.97) 40%);
  border-top: 1rpx solid rgba(15, 23, 42, 0.07);
  box-shadow: 0 -10rpx 36rpx rgba(15, 23, 42, 0.07);
  z-index: 10;
}

.attach-preview {
  margin: 0 0 14rpx;
}

.attach-scroll {
  white-space: nowrap;
}

.attach-item {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  background: rgba(255, 255, 255, 0.78);
  border: 1rpx solid rgba(37, 99, 235, 0.12);
  border-radius: 18rpx;
  padding: 10rpx 12rpx;
  margin-right: 12rpx;
  position: relative;
  backdrop-filter: blur(16rpx);
  -webkit-backdrop-filter: blur(16rpx);
}

.attach-thumb {
  width: 84rpx;
  height: 84rpx;
  border-radius: 14rpx;
  overflow: hidden;
  background: rgba(37, 99, 235, 0.08);
}

.attach-img {
  width: 100%;
  height: 100%;
  display: block;
}

.attach-file {
  max-width: 360rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 6rpx 4rpx;
}

.attach-file-icon {
  font-size: 30rpx;
}

.attach-file-name {
  font-size: 24rpx;
  color: rgba(15, 23, 42, 0.86);
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.attach-remove {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: rgba(37, 99, 235, 0.10);
  color: rgba(15, 23, 42, 0.78);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  line-height: 1;
}

.composer-box {
  display: flex;
  align-items: flex-end;
  gap: 14rpx;
  background: rgba(255, 255, 255, 0.78);
  border: 1rpx solid rgba(37, 99, 235, 0.14);
  border-radius: 999rpx;
  padding: 12rpx 12rpx 12rpx 22rpx;
  box-shadow: var(--neo-shadow);
  backdrop-filter: blur(22rpx) saturate(160%);
  -webkit-backdrop-filter: blur(22rpx) saturate(160%);
  position: relative;
  overflow: hidden;
  transition: box-shadow 0.22s ease, transform 0.22s ease, border-color 0.22s ease, background 0.22s ease;
}

.composer-box::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: inherit;
  padding: 1rpx;
  background: linear-gradient(135deg, rgba(96, 165, 250, 0.36), rgba(167, 139, 250, 0.26), rgba(244, 114, 182, 0.10));
  -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
  pointer-events: none;
  opacity: 0.6;
}

.composer-attach {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.78);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: transform 0.15s ease-out, opacity 0.15s ease-out;
  border: 1rpx solid rgba(37, 99, 235, 0.14);
}

.attach-icon {
  font-size: 30rpx;
  color: rgba(15, 23, 42, 0.72);
  filter: none;
}

.composer-input {
  flex: 1;
  min-height: 72rpx;
  max-height: 200rpx;
  padding: 18rpx 0;
  background: transparent;
  border: none;
  font-size: 30rpx;
  color: rgba(15, 23, 42, 0.92);
  line-height: 1.5;
  box-sizing: border-box;
}

.composer-send {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(37, 99, 235, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.15s ease-out, opacity 0.15s ease-out;
  flex-shrink: 0;
  border: 1rpx solid rgba(37, 99, 235, 0.16);
}

.composer-send.active {
  background: linear-gradient(135deg, rgba(96, 165, 250, 0.95) 0%, rgba(167, 139, 250, 0.70) 55%, rgba(244, 114, 182, 0.28) 100%);
  box-shadow: 0 0 22rpx rgba(96, 165, 250, 0.22), 0 18rpx 60rpx rgba(37, 99, 235, 0.14);
  border-color: rgba(37, 99, 235, 0.20);
}

.send-hover {
  transform: scale(0.95);
  opacity: 0.9;
}

.send-icon {
  font-size: 32rpx;
  color: rgba(15, 23, 42, 0.55);
}

.composer-send.active .send-icon {
  color: rgba(10, 12, 24, 0.85);
}

.composer-hint {
  margin-top: 8rpx;
  text-align: center;
  font-size: 20rpx;
  color: rgba(15, 23, 42, 0.36);
}

/* 对话历史弹层（轻量） */
.conversation-overlay {
  position: fixed;
  inset: 0;
  background: rgba(15, 23, 42, 0.18);
  z-index: 999;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  padding-top: 120rpx;
}

.conversation-sheet {
  width: calc(100vw - 40rpx);
  max-width: 650rpx;
  max-height: calc(100vh - 200rpx);
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(37, 99, 235, 0.14);
  box-shadow: 0 18rpx 60rpx rgba(37, 99, 235, 0.18);
  overflow: hidden;
  backdrop-filter: blur(18rpx) saturate(160%);
  -webkit-backdrop-filter: blur(18rpx) saturate(160%);
  display: flex;
  flex-direction: column;
}

.conversation-header {
  padding: 18rpx 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid rgba(37, 99, 235, 0.10);
}

.conversation-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #0f172a;
}

.conversation-close {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: rgba(15, 23, 42, 0.65);
}

.conversation-list {
  padding: 14rpx 14rpx;
  overflow: hidden;
  flex: 1;
}

.conversation-item {
  padding: 16rpx 16rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(37, 99, 235, 0.10);
  background: rgba(255, 255, 255, 0.65);
  margin-bottom: 12rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.conversation-item.active {
  border-color: rgba(37, 99, 235, 0.30);
  box-shadow: 0 10rpx 28rpx rgba(37, 99, 235, 0.14);
}

.conversation-item-title {
  font-size: 26rpx;
  font-weight: 750;
  color: #0f172a;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.conversation-item-time {
  font-size: 20rpx;
  color: rgba(15, 23, 42, 0.45);
}

.empty-history {
  padding: 28rpx 0;
  text-align: center;
  color: rgba(15, 23, 42, 0.45);
}

.empty-text {
  font-size: 24rpx;
}

.conversation-footer {
  border-top: 1rpx solid rgba(37, 99, 235, 0.10);
  padding: 14rpx 14rpx 18rpx;
}

.conversation-new-btn {
  width: 100%;
  background: linear-gradient(135deg, rgba(96, 165, 250, 0.95) 0%, rgba(167, 139, 250, 0.80) 55%, rgba(244, 114, 182, 0.45) 100%);
  border: 1rpx solid rgba(37, 99, 235, 0.20);
  border-radius: 999rpx;
  padding: 16rpx 0;
  text-align: center;
  font-size: 26rpx;
  font-weight: 800;
  color: #ffffff;
}


/* AI 身份条（紧凑横幅，弱于顶部状态卡一层） */
.ai-identity-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 18rpx 18rpx;
  background: linear-gradient(120deg, rgba(96, 165, 250, 0.88) 0%, rgba(167, 139, 250, 0.78) 52%, rgba(244, 114, 182, 0.45) 100%);
  border-radius: 16rpx;
  box-shadow: 0 6rpx 22rpx rgba(96, 165, 250, 0.2);
}

.ai-identity-card--compact {
  padding: 14rpx 16rpx;
  border-radius: 14rpx;
}

.ai-identity-avatar {
  position: relative;
  width: 72rpx;
  height: 72rpx;
  background: rgba(255, 255, 255, 0.22);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.ai-identity-card--compact .ai-identity-avatar {
  width: 64rpx;
  height: 64rpx;
}

.ai-identity-emoji {
  font-size: 36rpx;
}

.ai-identity-card--compact .ai-identity-emoji {
  font-size: 32rpx;
}

.ai-identity-dot {
  position: absolute;
  bottom: 2rpx;
  right: 2rpx;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #4ade80;
  border: 2rpx solid rgba(255, 255, 255, 0.85);
}

.ai-identity-info {
  flex: 1;
  min-width: 0;
}

.ai-identity-name {
  display: block;
  font-size: 30rpx;
  font-weight: 800;
  color: #fff;
  margin-bottom: 4rpx;
}

.ai-identity-card--compact .ai-identity-name {
  font-size: 28rpx;
}

.ai-identity-desc {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.88);
  line-height: 1.4;
}

/* 2×2 能力格：与外圈 action-item 同级阴影，更紧凑 */
.quick-actions-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8rpx;
}

.quick-action-item {
  background: rgba(255, 255, 255, 0.85);
  border: 1rpx solid rgba(37, 99, 235, 0.1);
  border-radius: 14rpx;
  padding: 14rpx 14rpx 16rpx;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  box-shadow: 0 4rpx 16rpx rgba(15, 23, 42, 0.05);
  transition: transform 0.15s ease, opacity 0.15s ease;
}

.quick-action-item.chip-hover {
  transform: scale(0.98);
  opacity: 0.92;
}

.quick-action-icon-wrap {
  width: 56rpx;
  height: 56rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 2rpx;
}

.qa-blue { background: rgba(96, 165, 250, 0.14); }
.qa-orange { background: rgba(251, 146, 60, 0.14); }
.qa-green { background: rgba(74, 222, 128, 0.14); }
.qa-purple { background: rgba(167, 139, 250, 0.14); }

.quick-action-icon {
  font-size: 30rpx;
}

.quick-action-name {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--neo-text);
}

.quick-action-desc {
  font-size: 20rpx;
  color: var(--neo-text-3);
  line-height: 1.35;
}

/* FAQ：嵌入面板内，无重复大标题条 */
.faq-card {
  background: rgba(255, 255, 255, 0.82);
  border: 1rpx solid var(--neo-border);
  border-radius: 14rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(15, 23, 42, 0.04);
}

.faq-card--in-panel {
  background: rgba(255, 255, 255, 0.92);
  border-color: rgba(37, 99, 235, 0.08);
}

.faq-card-title {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: var(--neo-text);
  padding: 20rpx 24rpx 14rpx;
  border-bottom: 1rpx solid var(--neo-border);
}

.faq-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 18rpx;
  border-bottom: 1rpx solid rgba(37, 99, 235, 0.06);
  transition: background 0.15s ease;
}

.faq-item:last-child {
  border-bottom: none;
}

.faq-item.chip-hover {
  background: rgba(37, 99, 235, 0.04);
}

.faq-item-icon {
  font-size: 24rpx;
  flex-shrink: 0;
}

.faq-item-text {
  flex: 1;
  font-size: 26rpx;
  color: var(--neo-text-2);
  line-height: 1.45;
  min-width: 0;
}

.faq-item-arrow {
  font-size: 28rpx;
  color: var(--neo-text-3);
  flex-shrink: 0;
}
