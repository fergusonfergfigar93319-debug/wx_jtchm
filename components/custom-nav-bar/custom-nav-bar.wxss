/* 沉浸式顶栏：仅 Tab 页使用；与 #F1F5F9 与全局 Bento 一致 */
.cnb-root {
  position: relative;
  z-index: 1000;
}

.cnb-fixed {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  box-sizing: border-box;
}

.nav-container {
  background: transparent;
  transition: background 0.3s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.3s ease, box-shadow 0.3s ease;
}

.nav-scrolled {
  background: rgba(241, 245, 249, 0.88);
  -webkit-backdrop-filter: blur(20px);
  backdrop-filter: blur(20px);
  border-bottom: 1rpx solid rgba(15, 23, 42, 0.06);
  box-shadow: 0 4rpx 20rpx -8rpx rgba(15, 23, 42, 0.06);
}

.nav-content {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 32rpx;
  box-sizing: border-box;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
  max-width: 60%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  transition: opacity 0.3s ease;
  text-align: center;
}

.text-hide {
  opacity: 0;
  pointer-events: none;
}

.text-show {
  opacity: 1;
}

.cnb-spacer {
  width: 100%;
  flex-shrink: 0;
}
