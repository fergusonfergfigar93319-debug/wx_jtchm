<!--components/skeleton/skeleton.wxml-->
<!-- 数据驱动型骨架屏组件 - 2025设计规范 -->
<view class="skeleton-container {{visible ? 'show' : 'hide'}}" wx:if="{{visible || loading}}">
  <view class="skeleton-item" wx:for="{{items}}" wx:key="index" style="animation-delay: {{index * 0.1}}s">
    <!-- 矩形骨架 -->
    <view wx:if="{{item.type === 'rect'}}" 
          class="skeleton-rect" 
          style="width: {{item.width || '100%'}}; height: {{item.height || '60rpx'}}; border-radius: {{item.radius || '12rpx'}}; margin: {{item.margin || '0 0 24rpx 0'}};">
    </view>
    
    <!-- 圆形骨架 -->
    <view wx:elif="{{item.type === 'circle'}}" 
          class="skeleton-circle" 
          style="width: {{item.diameter || '120rpx'}}; height: {{item.diameter || '120rpx'}}; margin: {{item.margin || '0 0 24rpx 0'}};">
    </view>
    
    <!-- 文本行骨架 -->
    <view wx:elif="{{item.type === 'text'}}" 
          class="skeleton-text-line" 
          style="width: {{item.width || '100%'}}; height: {{item.height || '32rpx'}}; margin: {{item.margin || '0 0 16rpx 0'}};">
    </view>
    
    <!-- 卡片骨架 -->
    <view wx:elif="{{item.type === 'card'}}" 
          class="skeleton-card" 
          style="width: {{item.width || '100%'}}; margin: {{item.margin || '0 0 24rpx 0'}};">
      <view class="skeleton-card-image" style="width: {{item.imageWidth || '100%'}}; height: {{item.imageHeight || '300rpx'}};"></view>
      <view class="skeleton-card-content">
        <view class="skeleton-text-line" style="width: 70%; height: 32rpx; margin-bottom: 16rpx;"></view>
        <view class="skeleton-text-line" style="width: 100%; height: 24rpx; margin-bottom: 8rpx;"></view>
        <view class="skeleton-text-line" style="width: 80%; height: 24rpx;"></view>
      </view>
    </view>
    
    <!-- 列表项骨架 -->
    <view wx:elif="{{item.type === 'list-item'}}" 
          class="skeleton-list-item" 
          style="margin: {{item.margin || '0 0 24rpx 0'}};">
      <view class="skeleton-circle" style="width: {{item.avatarSize || '80rpx'}}; height: {{item.avatarSize || '80rpx'}}; margin-right: 24rpx;"></view>
      <view class="skeleton-list-content">
        <view class="skeleton-text-line" style="width: 60%; height: 32rpx; margin-bottom: 12rpx;"></view>
        <view class="skeleton-text-line" style="width: 90%; height: 24rpx;"></view>
      </view>
    </view>
  </view>
</view>

<!-- 实际内容 -->
<view class="skeleton-content {{!loading ? 'show' : 'hide'}}">
  <slot></slot>
</view>
