/* components/skeleton/skeleton.wxss */
/* 骨架屏组件 - 2025设计规范（SVG路径动画） */

.skeleton-container {
  width: 100%;
  opacity: 1;
  transition: opacity 0.3s ease;
}

.skeleton-container.hide {
  opacity: 0;
  pointer-events: none;
}

.skeleton-content {
  width: 100%;
  opacity: 1;
  transition: opacity 0.3s ease;
}

.skeleton-content.hide {
  opacity: 0;
  pointer-events: none;
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
}

/* 骨架屏基础样式 - 使用SVG路径动画 */
.skeleton-item {
  animation: skeletonFadeIn 0.4s ease-out;
  animation-fill-mode: both;
}

@keyframes skeletonFadeIn {
  from {
    opacity: 0;
    transform: translateY(10rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 矩形骨架 */
.skeleton-rect {
  background: linear-gradient(90deg, 
    #f0f0f0 0%, 
    #e8e8e8 25%, 
    #f0f0f0 50%, 
    #e8e8e8 75%, 
    #f0f0f0 100%
  );
  background-size: 200% 100%;
  animation: skeletonLoading 1.5s ease-in-out infinite;
  border-radius: 12rpx;
  position: relative;
  overflow: hidden;
}

/* 圆形骨架 */
.skeleton-circle {
  background: linear-gradient(90deg, 
    #f0f0f0 0%, 
    #e8e8e8 25%, 
    #f0f0f0 50%, 
    #e8e8e8 75%, 
    #f0f0f0 100%
  );
  background-size: 200% 100%;
  animation: skeletonLoading 1.5s ease-in-out infinite;
  border-radius: 50%;
  position: relative;
  overflow: hidden;
}

/* 文本行骨架 */
.skeleton-text-line {
  background: linear-gradient(90deg, 
    #f0f0f0 0%, 
    #e8e8e8 25%, 
    #f0f0f0 50%, 
    #e8e8e8 75%, 
    #f0f0f0 100%
  );
  background-size: 200% 100%;
  animation: skeletonLoading 1.5s ease-in-out infinite;
  border-radius: 8rpx;
  position: relative;
  overflow: hidden;
}

/* 卡片骨架 */
.skeleton-card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.skeleton-card-image {
  background: linear-gradient(90deg, 
    #f0f0f0 0%, 
    #e8e8e8 25%, 
    #f0f0f0 50%, 
    #e8e8e8 75%, 
    #f0f0f0 100%
  );
  background-size: 200% 100%;
  animation: skeletonLoading 1.5s ease-in-out infinite;
}

.skeleton-card-content {
  padding: 32rpx;
}

/* 列表项骨架 */
.skeleton-list-item {
  display: flex;
  align-items: center;
}

.skeleton-list-content {
  flex: 1;
}

/* 加载动画 - SVG路径动画风格 */
@keyframes skeletonLoading {
  0% {
    background-position: 200% 0;
  }
  100% {
    background-position: -200% 0;
  }
}

/* 脉冲效果 - 科技蓝主题 */
.skeleton-rect::before,
.skeleton-circle::before,
.skeleton-text-line::before,
.skeleton-card-image::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(37, 99, 235, 0.05) 50%, 
    transparent 100%
  );
  animation: skeletonPulse 2s ease-in-out infinite;
  pointer-events: none;
}

@keyframes skeletonPulse {
  0%, 100% {
    opacity: 0.3;
  }
  50% {
    opacity: 0.6;
  }
}

/* 光泽效果 */
.skeleton-rect::after,
.skeleton-circle::after,
.skeleton-text-line::after,
.skeleton-card-image::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(255, 255, 255, 0.5) 50%, 
    transparent 100%
  );
  animation: skeletonShine 1.5s ease-in-out infinite;
  pointer-events: none;
}

@keyframes skeletonShine {
  0% {
    transform: translateX(-100%);
    opacity: 0;
  }
  50% {
    opacity: 1;
  }
  100% {
    transform: translateX(100%);
    opacity: 0;
  }
}
