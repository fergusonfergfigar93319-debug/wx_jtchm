/* packageHealth/remedy/remedy.wxss — Bento 与全局 #f1f5f9 对齐 */

@keyframes slideUpFade {
  from {
    opacity: 0;
    transform: translateY(28rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 全局底色与动画复用 */
.page-remedy {
  background: #f1f5f9;
  min-height: 100vh;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* === Bento 基础规范 === */
.bento-item {
  background: #ffffff;
  border-radius: 36rpx;
  box-shadow: 0 4rpx 20rpx -6rpx rgba(0, 0, 0, 0.03);
  animation: slideUpFade 0.5s cubic-bezier(0.16, 1, 0.3, 1) both;
}
.bento-grid {
  display: grid;
  gap: 24rpx;
  padding: 0 32rpx;
}
.card-hover {
  transform: scale(0.97);
  opacity: 0.9;
  transition: all 0.2s;
}

/* === 1. 顶部 Hero 卡片 === */
.hero-banner {
  margin: 32rpx 32rpx 24rpx;
  padding: 36rpx 32rpx;
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #ffffff 0%, #f0fdf4 100%);
  border: 1rpx solid rgba(74, 222, 128, 0.2);
  animation-delay: 0.1s;
}
.hero-icon-wrap {
  font-size: 64rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}
.hero-text-wrap {
  flex: 1;
  min-width: 0;
}
.hero-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #166534;
  margin-bottom: 8rpx;
}
.hero-desc {
  font-size: 24rpx;
  color: #4ade80;
  font-weight: 500;
}

/* === 2. 快捷操作区 === */
.action-grid {
  grid-template-columns: repeat(2, 1fr);
  margin-bottom: 32rpx;
}
.action-card {
  padding: 28rpx;
  display: flex;
  align-items: center;
  animation-delay: 0.2s;
}
.action-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}
.action-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
}
.action-desc {
  font-size: 22rpx;
  color: #94a3b8;
  margin-top: 4rpx;
}

/* === 3. 常见症状网格 (2列布局) === */
.section-header {
  padding: 0 40rpx;
  margin-bottom: 24rpx;
  animation: slideUpFade 0.5s both;
  animation-delay: 0.3s;
}
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.symptom-grid {
  grid-template-columns: repeat(2, 1fr);
  padding-bottom: 32rpx;
}
.symptom-card {
  padding: 32rpx 24rpx;
  display: flex;
  flex-direction: column;
  animation-delay: 0.4s;
}
.symptom-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}
.symptom-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}
.symptom-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  flex: 1;
  min-width: 0;
}
.symptom-desc {
  font-size: 22rpx;
  color: #64748b;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* === 4. 底部弹窗规范统一 === */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  -webkit-backdrop-filter: blur(4px);
  backdrop-filter: blur(4px);
  z-index: 1000;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}
.detail-modal {
  background: #ffffff;
  border-radius: 40rpx 40rpx 0 0;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
  animation: slideUpFade 0.3s ease-out;
}
.modal-header {
  padding: 36rpx 40rpx 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid #f1f5f9;
  flex-shrink: 0;
}
.modal-title-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
  min-width: 0;
}
.modal-icon {
  font-size: 40rpx;
  flex-shrink: 0;
}
.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1a1a1a;
  flex: 1;
  min-width: 0;
}
.modal-close {
  font-size: 40rpx;
  color: #94a3b8;
  padding: 10rpx;
  flex-shrink: 0;
}

.modal-scroll {
  padding: 0 40rpx;
  max-height: 60vh;
  box-sizing: border-box;
  flex: 1;
  min-height: 0;
}
.detail-section {
  margin: 32rpx 0;
}
.section-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}
.tip-item {
  font-size: 28rpx;
  color: #475569;
  line-height: 1.6;
  background: #f8fafc;
  padding: 20rpx;
  border-radius: 16rpx;
  margin-bottom: 12rpx;
}
.tip-item:last-child {
  margin-bottom: 0;
}
.science-text {
  font-size: 28rpx;
  color: #475569;
  line-height: 1.6;
  background: #f8fafc;
  padding: 20rpx;
  border-radius: 16rpx;
  margin-bottom: 0;
}

/* 弹窗底部操作区 */
.modal-footer {
  padding: 24rpx 40rpx calc(24rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #f1f5f9;
  flex-shrink: 0;
}
.modal-footer-actions {
  display: flex;
  gap: 24rpx;
  align-items: stretch;
}
.btn-secondary {
  flex: 1;
  background: #f1f5f9;
  color: #475569;
  font-weight: 500;
  border-radius: 24rpx;
  margin: 0;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 28rpx;
  padding: 0;
}
.btn-secondary::after {
  border: none;
}
.btn-footer-full {
  width: 100%;
  flex: none;
}
.btn-copy-in-detail {
  flex: 1.5;
  background: #4ade80;
  color: #fff;
  font-weight: 600;
  text-align: center;
  line-height: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
}
.btn-copy-in-detail:active {
  opacity: 0.8;
  transform: scale(0.98);
}

/* 急救记录列表 */
.history-modal {
  max-height: 75vh;
}
.history-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding-bottom: 16rpx;
}
.history-item {
  padding: 24rpx;
  background: #f8fafc;
  border-radius: 20rpx;
  border-left: 6rpx solid #4ade80;
}
.history-item:active {
  opacity: 0.92;
  transform: scale(0.99);
}
.history-item-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
  gap: 16rpx;
}
.history-remedy-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
  flex: 1;
  min-width: 0;
}
.history-date {
  font-size: 22rpx;
  color: #94a3b8;
  flex-shrink: 0;
}
.history-symptom {
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.5;
}
.empty-history {
  padding: 80rpx 24rpx;
  text-align: center;
}
.empty-text {
  font-size: 28rpx;
  color: #94a3b8;
}
