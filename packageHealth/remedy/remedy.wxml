<view class="page-remedy page-container">

  <view class="bento-item hero-banner">
    <view class="hero-icon-wrap">🩹</view>
    <view class="hero-text-wrap">
      <view class="hero-title">急救养生舱</view>
      <view class="hero-desc">针对「作死」行为的暖心补救方案</view>
    </view>
  </view>

  <view class="bento-grid action-grid">
    <view class="bento-item action-card" bindtap="goToTriage" hover-class="card-hover" hover-stay-time="80">
      <view class="action-icon">🤖</view>
      <view class="action-info">
        <view class="action-title">AI 对症下药</view>
        <view class="action-desc">智能分诊排雷</view>
      </view>
    </view>
    <view class="bento-item action-card" bindtap="toggleHistory" hover-class="card-hover" hover-stay-time="80">
      <view class="action-icon">📜</view>
      <view class="action-info">
        <view class="action-title">急救记录</view>
        <view class="action-desc">{{usageHistory.length > 0 ? usageHistory.length + '次施救' : '暂无记录'}}</view>
      </view>
    </view>
  </view>

  <view class="section-header">
    <text class="section-title">常见急救场景</text>
  </view>

  <view class="bento-grid symptom-grid">
    <view
      class="bento-item symptom-card"
      wx:for="{{symptoms}}"
      wx:key="id"
      bindtap="selectSymptom"
      data-symptom="{{item}}"
      hover-class="card-hover"
      hover-stay-time="80"
    >
      <view class="symptom-header">
        <view class="symptom-icon-wrap" style="background: {{item.color}}15; color: {{item.color}};">
          <text class="symptom-icon">{{item.icon}}</text>
        </view>
        <text class="symptom-name">{{item.name}}</text>
      </view>
      <view class="symptom-desc">{{item.desc}}</view>
    </view>
  </view>

  <!-- 急救记录：底部抽屉，与详情弹层同一套蒙层规范 -->
  <view class="modal-mask" wx:if="{{showHistory}}" catchtap="toggleHistory">
    <view class="detail-modal history-modal" catchtap="stopPropagation">
      <view class="modal-header">
        <view class="modal-title-wrap">
          <text class="modal-title">急救记录</text>
        </view>
        <view class="modal-close" bindtap="toggleHistory">✕</view>
      </view>
      <scroll-view class="modal-scroll" scroll-y>
        <view wx:if="{{usageHistory.length === 0}}" class="empty-history">
          <text class="empty-text">暂无使用记录</text>
        </view>
        <view wx:else class="history-list">
          <view
            wx:for="{{usageHistory}}"
            wx:key="id"
            class="history-item"
            data-item="{{item}}"
            bindtap="selectFromHistory"
          >
            <view class="history-item-header">
              <text class="history-remedy-name">{{item.remedyName}}</text>
              <text class="history-date">{{item.displayTime || item.timestamp}}</text>
            </view>
            <text class="history-symptom">症状：{{item.symptom}}</text>
          </view>
        </view>
      </scroll-view>
      <view class="modal-footer">
        <button class="btn-secondary btn-footer-full" bindtap="toggleHistory">关闭</button>
      </view>
    </view>
  </view>

  <!-- 方案详情（从其他入口仍可能打开时保留） -->
  <view class="modal-mask" wx:if="{{showDetail && selectedRemedy}}" bindtap="closeDetail">
    <view class="detail-modal" catchtap="stopPropagation">
      <view class="modal-header">
        <view class="modal-title-wrap">
          <text class="modal-icon">{{selectedRemedy.icon}}</text>
          <text class="modal-title">{{selectedRemedy.name}}急救指南</text>
        </view>
        <view class="modal-close" bindtap="closeDetail">✕</view>
      </view>
      <scroll-view class="modal-scroll" scroll-y>
        <view class="detail-section" wx:if="{{selectedRemedy.tips && selectedRemedy.tips.length}}">
          <view class="section-label">💡 小贴士</view>
          <view class="tips-list">
            <view wx:for="{{selectedRemedy.tips}}" wx:key="*this" class="tip-item">• {{item}}</view>
          </view>
        </view>
        <view class="detail-section" wx:if="{{selectedRemedy.science}}">
          <view class="section-label">🔬 科学依据</view>
          <view class="science-text">{{selectedRemedy.science}}</view>
        </view>
      </scroll-view>
      <view class="modal-footer">
        <view class="modal-footer-actions">
          <button class="btn-secondary" bindtap="closeDetail">关闭</button>
          <view class="btn-copy-in-detail" bindtap="copyRecipe" data-remedy="{{selectedRemedy}}">一键复制方案</view>
        </view>
      </view>
    </view>
  </view>

</view>
