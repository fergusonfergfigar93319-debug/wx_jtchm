/* 饮水页：清爽青蓝 #26C2C9 + 淡底 #E6F7F8 */

page {
  background: #e6f7f8;
}

.page {
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: linear-gradient(180deg, #e6f7f8 0%, #dff5f7 32%, #f0fdff 68%, #ffffff 100%);
  position: relative;
}

.page::before {
  content: '';
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 42vh;
  background: radial-gradient(ellipse 120% 80% at 50% -10%, rgba(38, 194, 201, 0.14) 0%, transparent 55%);
  pointer-events: none;
  z-index: 0;
}

.header-card,
.actions-card,
.list-card {
  background: rgba(255, 255, 255, 0.92);
  border-radius: 28rpx;
  box-shadow: 0 10rpx 32rpx rgba(38, 194, 201, 0.08);
  border: 1rpx solid rgba(38, 194, 201, 0.14);
  padding: 28rpx;
  margin-bottom: 22rpx;
  backdrop-filter: blur(16rpx) saturate(150%);
  -webkit-backdrop-filter: blur(16rpx) saturate(150%);
  position: relative;
  z-index: 1;
  animation: fadeInUp 0.45s ease-out both;
}

.header-card  { animation-delay: 0.04s; }
.actions-card { animation-delay: 0.10s; }
.list-card    { animation-delay: 0.16s; }

.header-card {
  background: linear-gradient(165deg, rgba(255, 255, 255, 0.96) 0%, rgba(230, 247, 248, 0.55) 100%);
  border-color: rgba(38, 194, 201, 0.18);
  box-shadow: 0 14rpx 40rpx rgba(38, 194, 201, 0.1);
}

.title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.title-left {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.icon {
  font-size: 32rpx;
}

.title {
  font-size: 30rpx;
  font-weight: 800;
  color: #333333;
}

.date-pill {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(38, 194, 201, 0.12);
  font-size: 22rpx;
  color: #555555;
  white-space: nowrap;
  border: 1rpx solid rgba(38, 194, 201, 0.2);
}

.amount-row {
  display: flex;
  align-items: baseline;
  gap: 10rpx;
  margin: 12rpx 0 18rpx;
}

.amount {
  font-size: 56rpx;
  font-weight: 900;
  color: #26c2c9;
  line-height: 1;
  letter-spacing: -1rpx;
  animation: numberRoll 0.5s cubic-bezier(0.22, 1, 0.36, 1) both;
  animation-delay: 0.12s;
}

.unit {
  font-size: 24rpx;
  color: #999999;
}

.progress {
  margin-top: 4rpx;
}

.progress-bg {
  height: 12rpx;
  background: rgba(38, 194, 201, 0.15);
  border-radius: 999rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  max-width: 100%;
  background: linear-gradient(90deg, #5dd4db 0%, #26c2c9 55%, #1fb8bf 100%);
  border-radius: 999rpx;
  box-shadow: 0 0 16rpx rgba(38, 194, 201, 0.45);
  transition: width 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  animation: waterWave 2.4s ease-in-out infinite;
}

@keyframes waterWave {
  0%   { box-shadow: 0 0 16rpx rgba(38, 194, 201, 0.45); }
  50%  { box-shadow: 0 0 28rpx rgba(38, 194, 201, 0.7); }
  100% { box-shadow: 0 0 16rpx rgba(38, 194, 201, 0.45); }
}

.subline {
  margin-top: 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx 20rpx;
  align-items: center;
}

.sub-pill {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.sub-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.sub-dot--manual {
  background: #26c2c9;
  box-shadow: 0 0 0 3rpx rgba(38, 194, 201, 0.25);
}

.sub-dot--food {
  background: #5cb87a;
  box-shadow: 0 0 0 3rpx rgba(92, 184, 122, 0.22);
}

.subtext {
  font-size: 22rpx;
  color: #666666;
}

.actions-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #333333;
  margin-bottom: 16rpx;
}

.btn-row {
  display: flex;
  gap: 12rpx;
  flex-wrap: nowrap;
  margin-bottom: 18rpx;
}

.quick-btn {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  padding: 14rpx 6rpx;
  min-height: 112rpx;
  border-radius: 20rpx;
  background: rgba(38, 194, 201, 0.1);
  border: 1rpx solid rgba(38, 194, 201, 0.28);
  box-sizing: border-box;
  transition: transform var(--duration-tap, 220ms) var(--ease-tap, cubic-bezier(0.34, 1.56, 0.64, 1)),
              background 0.15s ease,
              box-shadow 0.15s ease;
}

.quick-btn:active {
  transform: scale(0.92);
  background: rgba(38, 194, 201, 0.22);
  box-shadow: 0 4rpx 16rpx rgba(38, 194, 201, 0.25);
}

.quick-icon {
  font-size: 34rpx;
  line-height: 1;
}

.quick-ml {
  font-size: 24rpx;
  font-weight: 800;
  color: #26c2c9;
}

.custom-row {
  display: flex;
  gap: 12rpx;
  align-items: stretch;
}

.custom-input {
  flex: 1;
  min-height: 80rpx;
  background: #f8fafb;
  border: 1rpx solid rgba(38, 194, 201, 0.2);
  border-radius: 20rpx;
  padding: 0 20rpx;
  font-size: 26rpx;
  color: #333333;
}

.custom-placeholder {
  color: #999999;
  font-size: 26rpx;
}

.btn-add {
  flex-shrink: 0;
  min-width: 132rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #ffffff;
  background: linear-gradient(145deg, #5dd4db 0%, #26c2c9 48%, #1fb0b7 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.35);
  box-shadow: 0 8rpx 24rpx rgba(38, 194, 201, 0.32);
  transition: transform 0.15s ease, opacity 0.15s ease;
}

.btn-add:active {
  transform: scale(0.98);
  opacity: 0.95;
}

.tool-row {
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  gap: 8rpx 16rpx;
  padding-top: 8rpx;
  border-top: 1rpx solid rgba(38, 194, 201, 0.08);
}

.tool-btn {
  flex: 1;
  text-align: center;
  padding: 12rpx 12rpx;
  border-radius: 14rpx;
  font-size: 22rpx;
  transition: opacity 0.15s ease, transform 0.15s ease;
}

.tool-btn:active {
  transform: scale(0.98);
}

.tool-btn text {
  font-size: 22rpx;
}

.tool-btn.text-only {
  color: #94a3b8;
  background: transparent;
  border: none;
}

.tool-btn.outline {
  color: #64748b;
  background: #f1f5f9;
  border: 1rpx solid #e2e8f0;
}

.list-header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 12rpx;
}

.list-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #333333;
}

.list-sub {
  font-size: 22rpx;
  color: #999999;
}

.item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
}

.item:last-child {
  border-bottom: none;
}

.item-left {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.item-time {
  font-size: 26rpx;
  font-weight: 700;
  color: #333333;
}

.item-desc {
  font-size: 22rpx;
  color: #999999;
}

.item-ml {
  font-size: 26rpx;
  font-weight: 800;
  color: #26c2c9;
}

.empty {
  padding: 24rpx 0 16rpx;
  text-align: center;
}

.empty-illus {
  width: 128rpx;
  height: 128rpx;
  margin: 0 auto 20rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, rgba(38, 194, 201, 0.12) 0%, rgba(38, 194, 201, 0.04) 100%);
  border: 1rpx solid rgba(38, 194, 201, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-illus-icon {
  font-size: 64rpx;
  line-height: 1;
  opacity: 0.92;
}

.empty-text {
  display: block;
  font-size: 28rpx;
  color: #555555;
  font-weight: 600;
  margin-bottom: 10rpx;
}

.empty-hint {
  display: block;
  font-size: 24rpx;
  color: #999999;
  line-height: 1.5;
  padding: 0 24rpx;
}
