/* packageHealth/triage/triage.wxss */
.container {
  padding: 32rpx 24rpx 40rpx;
  min-height: 100vh;
  background: #F7F6FF;
}

.header {
  margin-bottom: 28rpx;
  padding: 24rpx 24rpx 28rpx;
  background: linear-gradient(135deg, #FDE7F3 0%, #E4D6FF 45%, #D2F1FF 100%);
  border-radius: 20rpx;
  box-shadow: 0 10rpx 30rpx rgba(102, 77, 255, 0.16);
}

.header-tag {
  display: flex;
  align-items: center;
}

.header-tag-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 20rpx;
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.06);
}

.header-texts {
  flex: 1;
}

.header-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #222;
  margin-bottom: 8rpx;
}

.header-desc {
  font-size: 26rpx;
  color: #665F8F;
  line-height: 1.6;
}

.triage-card,
.result-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx 24rpx 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid rgba(95, 92, 255, 0.10);
  margin-bottom: 24rpx;
}

.triage-field {
  margin-bottom: 20rpx;
}

.triage-label {
  font-size: 26rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 12rpx;
}

.triage-textarea {
  width: 100%;
  min-height: 120rpx;
  padding: 20rpx 18rpx;
  box-sizing: border-box;
  background: #F8F9FA;
  border-radius: 16rpx;
  border: 2rpx solid rgba(0,0,0,0.06);
  font-size: 28rpx;
  color: #333;
  line-height: 1.7;
}

.triage-counter {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #AAA;
  text-align: right;
}

.triage-chip-scroll {
  width: 100%;
  margin-bottom: 14rpx;
}

.triage-chip-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding-bottom: 2rpx;
}

.triage-chip {
  --chipColor: #5F5CFF;
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: #fff;
  border: 2rpx solid rgba(0,0,0,0.08);
  color: #444;
  white-space: nowrap;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.04);
}

.triage-chip-ico {
  font-size: 28rpx;
  line-height: 1;
}

.triage-chip-txt {
  font-size: 26rpx;
  font-weight: 650;
}

.triage-chip.active {
  border-color: var(--chipColor);
  background: rgba(95, 92, 255, 0.08);
  color: #2D2B66;
}

.triage-input {
  height: 72rpx;
  padding: 0 18rpx;
  background: #F8F9FA;
  border-radius: 16rpx;
  border: 2rpx solid rgba(0,0,0,0.06);
  font-size: 28rpx;
  color: #333;
}

.triage-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 10rpx;
}

.triage-btn-primary,
.triage-btn-ghost {
  flex: 1;
  margin: 0;
  border-radius: 16rpx;
  padding: 22rpx 0;
  font-size: 28rpx;
  font-weight: 700;
}

.triage-btn-primary {
  background: linear-gradient(135deg, #5F5CFF 0%, #7C79FF 100%);
  color: #fff;
  border: none;
}

.triage-btn-ghost {
  background: #fff;
  color: #5F5CFF;
  border: 2rpx solid rgba(95, 92, 255, 0.55);
}

.result-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #222;
  margin-bottom: 18rpx;
}

.matched-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.matched-item {
  padding: 20rpx 18rpx;
  background: #fff;
  border-radius: 18rpx;
  border: 3rpx solid rgba(0,0,0,0.08);
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.06);
}

.matched-ico {
  font-size: 54rpx;
  margin-bottom: 10rpx;
}

.matched-name {
  font-size: 28rpx;
  font-weight: 800;
  color: #222;
  margin-bottom: 6rpx;
}

.matched-score {
  font-size: 22rpx;
  color: #777;
  margin-bottom: 14rpx;
}

.matched-actions {
  display: flex;
  gap: 12rpx;
}

.matched-actions .btn-secondary,
.matched-actions .btn-primary {
  flex: 1;
  margin: 0;
  font-size: 24rpx;
  padding: 16rpx 0;
  border-radius: 14rpx;
}

.matched-actions .btn-primary {
  background: linear-gradient(135deg, #5F5CFF 0%, #7C79FF 100%);
  color: #fff;
  border: none;
}

.matched-actions .btn-secondary {
  background: #fff;
  color: #5F5CFF;
  border: 2rpx solid #5F5CFF;
}

.result-hint {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #888;
  line-height: 1.6;
}

.triage-empty {
  padding: 44rpx 24rpx;
  text-align: center;
  background: #F8F9FA;
  border-radius: 18rpx;
}

.triage-empty-icon {
  font-size: 72rpx;
  display: block;
  margin-bottom: 14rpx;
  opacity: 0.75;
}

.triage-empty-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.triage-empty-hint {
  font-size: 24rpx;
  color: #888;
  line-height: 1.6;
  display: block;
}

