/* pages/intake-edit/index.wxss */

.container {
  min-height: 100vh;
  background: var(--color-bg-page);
  padding: 24rpx;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.section-card {
  margin-bottom: 24rpx;
}

.card-header {
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.form-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.form-item {
  display: flex;
  align-items: center;
  min-height: 96rpx;
}

.form-item-note {
  align-items: flex-start;
}

.form-label {
  width: 180rpx;
  font-size: 28rpx;
  color: var(--color-text-secondary);
  flex-shrink: 0;
  line-height: 1.5;
}

.form-row {
  flex: 1;
  display: flex;
  gap: 16rpx;
}

.form-input-half {
  flex: 1;
}

.form-picker {
  flex: 1;
  min-height: 88rpx;
  font-size: 30rpx;
  color: var(--color-text-primary);
  padding: 26rpx 24rpx;
  background: var(--color-bg-muted);
  border-radius: 12rpx;
  box-sizing: border-box;
  line-height: 1.5;
  display: flex;
  align-items: center;
}

.form-textarea {
  flex: 1;
  font-size: 30rpx;
  color: var(--color-text-primary);
  padding: 26rpx 24rpx;
  background: var(--color-bg-muted);
  border-radius: 12rpx;
  min-height: 140rpx;
  line-height: 1.5;
  box-sizing: border-box;
}

.btn-wrap {
  margin-top: 40rpx;
  padding: 0 8rpx;
  padding-bottom: env(safe-area-inset-bottom);
}

.btn-full {
  width: 100%;
}

.btn-outline {
  background: transparent;
  color: var(--color-danger);
  border: 2rpx solid var(--color-danger);
  border-radius: 12rpx;
  font-size: 32rpx;
  height: 96rpx;
  line-height: 96rpx;
  padding: 0;
}

.mt-16 {
  margin-top: 24rpx;
}
