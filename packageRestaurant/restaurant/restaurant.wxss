/* pages/restaurant/restaurant.wxss */
.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  position: relative;
  z-index: 1;
}

.header {
  margin: 20rpx;
  padding: 24rpx;
}

.location-info {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  padding: 16rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
}

.location-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.location-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.location-arrow {
  font-size: 32rpx;
  color: #999;
}

.search-section {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  gap: 12rpx;
}

.search-box {
  flex: 1;
  display: flex;
  align-items: center;
  background: #F5F5F5;
  border-radius: 24rpx;
  padding: 12rpx 20rpx;
  transition: all 0.3s ease;
}

.search-box.active {
  background: #fff;
  border: 2rpx solid #4CAF50;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
  color: #333;
}

.search-clear {
  font-size: 24rpx;
  color: #999;
  padding: 0 8rpx;
}

.search-toggle {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #4CAF50;
  border-radius: 50%;
  transition: all 0.3s ease;
}

.search-toggle:active {
  transform: scale(0.95);
  background: #45a049;
}

.search-icon {
  font-size: 32rpx;
  color: #fff;
}

.health-filter-scroll,
.nutrition-filter-scroll {
  white-space: nowrap;
  margin-bottom: 16rpx;
}

.health-filter-list,
.nutrition-filter-list {
  display: flex;
}

.health-filter-tag {
  display: inline-block;
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  background: #F5F5F5;
  color: #666;
  margin-right: 12rpx;
  white-space: nowrap;
}

.health-filter-tag.active {
  background: #E8F5E9;
  color: #4CAF50;
  font-weight: bold;
}

.nutrition-filter-tag {
  display: inline-block;
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  background: #F5F5F5;
  color: #666;
  margin-right: 12rpx;
  white-space: nowrap;
  transition: all 0.3s ease;
}

.nutrition-filter-tag.active {
  background: linear-gradient(135deg, #E3F2FD 0%, #BBDEFB 100%);
  color: #1976D2;
  font-weight: bold;
  border: 2rpx solid #2196F3;
  box-shadow: 0 2rpx 8rpx rgba(33, 150, 243, 0.2);
}

/* 饥饿程度选择器 */
.hunger-selector {
  margin: 0 20rpx 16rpx;
  padding: 20rpx;
  background: #FFF9C4;
  border: 2rpx solid #FFC107;
}

.hunger-selector-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #F57C00;
  margin-bottom: 16rpx;
}

.hunger-options {
  display: flex;
  gap: 12rpx;
}

.hunger-option {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx;
  background: #fff;
  border-radius: 12rpx;
  border: 2rpx solid #E0E0E0;
  transition: all 0.3s ease;
}

.hunger-option.active {
  background: #FFF3E0;
  border-color: #FF9800;
  box-shadow: 0 2rpx 8rpx rgba(255, 152, 0, 0.2);
}

.hunger-icon {
  font-size: 40rpx;
}

.hunger-label {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
}

.hunger-desc {
  font-size: 22rpx;
  color: #999;
}

.hunger-tip {
  margin: 0 20rpx 16rpx;
  padding: 16rpx 20rpx;
  background: linear-gradient(135deg, #FFF3E0 0%, #FFE0B2 100%);
  border: 2rpx solid #FF9800;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.hunger-tip-icon {
  font-size: 32rpx;
}

.hunger-tip-text {
  flex: 1;
  font-size: 26rpx;
  color: #E65100;
}

.hunger-tip-arrow {
  font-size: 32rpx;
  color: #FF9800;
}

.hunger-match-tip {
  margin-top: 8rpx;
  padding: 8rpx 12rpx;
  background: #E8F5E9;
  border-radius: 8rpx;
  border-left: 3rpx solid #4CAF50;
}

.hunger-match-text {
  font-size: 22rpx;
  color: #2E7D32;
}

.filter-scroll {
  white-space: nowrap;
}

.filter-list {
  display: flex;
}

.filter-tag {
  display: inline-block;
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  background: #F5F5F5;
  color: #666;
  margin-right: 16rpx;
}

.filter-tag.active {
  background: #4CAF50;
  color: #fff;
}

.restaurant-list {
  flex: 1;
  height: 0;
}

.restaurant-card {
  display: flex;
  margin: 20rpx;
  padding: 0;
  overflow: hidden;
  animation: slideInRight 0.4s ease-out;
  animation-fill-mode: both;
  transition: all 0.3s ease;
  position: relative;
}

.restaurant-card:active {
  transform: translateY(-2rpx) scale(0.98);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.12);
}

.restaurant-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, #4CAF50 0%, #45a049 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.restaurant-card:active::before {
  opacity: 1;
}

.restaurant-card:nth-child(1) { animation-delay: 0.05s; }
.restaurant-card:nth-child(2) { animation-delay: 0.1s; }
.restaurant-card:nth-child(3) { animation-delay: 0.15s; }
.restaurant-card:nth-child(4) { animation-delay: 0.2s; }
.restaurant-card:nth-child(5) { animation-delay: 0.25s; }

@keyframes slideInRight {
  from {
    opacity: 0;
    transform: translateX(30rpx);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

.restaurant-image-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #E1F5FE 0%, #B3E5FC 100%);
}

.restaurant-icon {
  font-size: 60rpx;
  opacity: 0.8;
}

.restaurant-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx 0 0 16rpx;
  flex-shrink: 0;
  object-fit: cover;
  background: #F5F5F5;
  transition: transform 0.3s ease;
}

.restaurant-card:active .restaurant-image {
  transform: scale(1.05);
}

.restaurant-info {
  flex: 1;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.restaurant-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.restaurant-meta {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.rating {
  font-size: 24rpx;
  color: #FF9800;
  margin-right: 20rpx;
}

.distance {
  font-size: 24rpx;
  color: #999;
}

.restaurant-tags {
  margin-bottom: 12rpx;
}

.restaurant-footer {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 8rpx;
  flex-wrap: wrap;
}

.health-indicator {
  flex-shrink: 0;
}

.restaurant-price {
  flex-shrink: 0;
}

.price-text {
  font-size: 22rpx;
  color: #FF9800;
  background: #FFF3E0;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.restaurant-hours {
  flex-shrink: 0;
}

.hours-text {
  font-size: 22rpx;
  color: #999;
}

.health-badge {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
}

.health-badge.health-green {
  background: #E8F5E9;
  color: #4CAF50;
}

.health-badge.health-yellow {
  background: #FFF9C4;
  color: #F57C00;
}

.health-badge.health-red {
  background: #FFEBEE;
  color: #FF5252;
}

/* 红绿灯避雷针样式 */
.health-traffic-light {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  border: 2rpx solid;
  transition: all 0.3s ease;
}

.health-traffic-light.green {
  background: #E8F5E9;
  border-color: #4CAF50;
  box-shadow: 0 2rpx 8rpx rgba(76, 175, 80, 0.2);
}

.health-traffic-light.yellow {
  background: #FFF9C4;
  border-color: #F57C00;
  box-shadow: 0 2rpx 8rpx rgba(245, 124, 0, 0.2);
}

.health-traffic-light.red {
  background: #FFEBEE;
  border-color: #FF5252;
  box-shadow: 0 2rpx 8rpx rgba(255, 82, 82, 0.2);
}

.traffic-light-icon {
  font-size: 28rpx;
  line-height: 1;
}

.health-desc {
  font-size: 20rpx;
  color: #666;
  margin-left: 4rpx;
}

.retry-btn {
  margin-top: 40rpx;
  padding: 16rpx 48rpx;
  background: #4CAF50;
  color: #fff;
  border-radius: 24rpx;
  font-size: 28rpx;
  border: none;
}

.retry-btn:active {
  background: #45a049;
  transform: scale(0.95);
}

.load-more-tip {
  padding: 30rpx;
  text-align: center;
}

.load-more-text {
  font-size: 26rpx;
  color: #999;
}

.no-more-tip {
  padding: 30rpx;
  text-align: center;
}

.no-more-text {
  font-size: 24rpx;
  color: #ccc;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
  color: #999;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
  animation: float 3s ease-in-out infinite;
}

@keyframes float {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-20rpx);
  }
}

.empty-text {
  font-size: 32rpx;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #ccc;
}

/* 深夜食堂负罪感缓冲弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
  opacity: 0;
  pointer-events: none;
  transition: all 0.3s ease;
}

.modal.show {
  opacity: 1;
  pointer-events: auto;
}

.night-remedy-modal {
  width: 90%;
  max-width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 0;
  overflow: hidden;
  animation: modalSlideUp 0.3s ease-out;
}

@keyframes modalSlideUp {
  from {
    opacity: 0;
    transform: translateY(50rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 24rpx 24rpx;
  border-bottom: 1rpx solid #E0E0E0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  font-size: 36rpx;
  color: #999;
  padding: 8rpx;
}

.night-remedy-content {
  padding: 24rpx;
}

.night-remedy-message {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 24rpx;
}

.remedy-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.remedy-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx;
  background: #FFF3E0;
  border-radius: 12rpx;
  border-left: 4rpx solid #FF9800;
}

.remedy-icon {
  font-size: 40rpx;
}

.remedy-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.remedy-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #E65100;
}

.remedy-desc {
  font-size: 24rpx;
  color: #F57C00;
}

.night-remedy-tip {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 16rpx;
  background: #E3F2FD;
  border-radius: 12rpx;
  border-left: 4rpx solid #2196F3;
}

.tip-icon {
  font-size: 32rpx;
}

.tip-text {
  flex: 1;
  font-size: 24rpx;
  color: #1565C0;
  line-height: 1.5;
}

.night-remedy-actions {
  display: flex;
  gap: 16rpx;
  padding: 24rpx;
  border-top: 1rpx solid #E0E0E0;
}

.btn-secondary, .btn-primary {
  flex: 1;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  border: none;
  text-align: center;
}

.btn-secondary {
  background: #F5F5F5;
  color: #666;
}

.btn-primary {
  background: #FF9800;
  color: #fff;
}

/* 骨架屏样式 */
.skeleton-list {
  padding: 20rpx;
}

.skeleton-card {
  display: flex;
  margin-bottom: 20rpx;
  padding: 0;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.skeleton {
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: loading 1.5s ease-in-out infinite;
}

@keyframes loading {
  0% {
    background-position: 200% 0;
  }
  100% {
    background-position: -200% 0;
  }
}

.skeleton-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx 0 0 16rpx;
}

.skeleton-text {
  height: 32rpx;
  width: 60%;
  margin: 12rpx 20rpx;
  border-radius: 8rpx;
}

.skeleton-text-short {
  height: 24rpx;
  width: 40%;
  margin: 8rpx 20rpx;
  border-radius: 8rpx;
}
