/* pages/group-order/group-order.wxss */
.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.content {
  flex: 1;
  height: 0;
  box-sizing: border-box;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.header {
  margin: 20rpx;
  padding: 24rpx;
}

.restaurant-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.restaurant-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.restaurant-subtitle {
  font-size: 24rpx;
  color: #999;
}

.distribution-mode {
  margin: 0 20rpx 20rpx;
  padding: 24rpx;
}

.mode-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.mode-options {
  display: flex;
  gap: 16rpx;
}

.mode-option {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 20rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
  border: 2rpx solid #E0E0E0;
  transition: all 0.3s ease;
}

.mode-option.active {
  background: linear-gradient(135deg, #E3F2FD 0%, #BBDEFB 100%);
  border-color: #2196F3;
  box-shadow: 0 4rpx 12rpx rgba(33, 150, 243, 0.2);
}

.mode-icon {
  font-size: 36rpx;
  line-height: 1.25;
}

.mode-label {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.mode-option.active .mode-label {
  color: #1976D2;
}

.mode-desc {
  font-size: 22rpx;
  color: #999;
}

.members-section,
.dishes-section,
.summary-section {
  margin: 0 20rpx 20rpx;
  padding: 24rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 20rpx;
  min-height: 56rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.btn-add {
  flex-shrink: 0;
  margin: 0;
  padding: 0 20rpx;
  min-width: 0;
  line-height: 52rpx;
  height: 52rpx;
  background: #fff;
  color: #2e7d32;
  border: 2rpx solid #81c784;
  border-radius: 26rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.btn-add::after {
  border: none;
}

.dishes-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48rpx 24rpx 32rpx;
  background: #fafafa;
  border-radius: 12rpx;
  border: 1rpx dashed #e0e0e0;
}

.dishes-empty-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
  opacity: 0.85;
}

.dishes-empty-text {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.dishes-empty-hint {
  font-size: 24rpx;
  color: #9e9e9e;
  text-align: center;
  line-height: 1.5;
}

.members-list,
.dishes-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.member-item,
.dish-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
}

.member-info,
.dish-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.member-name,
.dish-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.member-stats,
.dish-stats {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.member-calories,
.dish-calories {
  font-size: 24rpx;
  color: #FF9800;
}

.member-price,
.dish-price {
  font-size: 24rpx;
  color: #FF5252;
}

.member-dishes {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 8rpx;
}

.dish-tag {
  font-size: 22rpx;
  color: #666;
  background: #E0E0E0;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.dish-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.quantity-control {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: #fff;
  border-radius: 8rpx;
  padding: 4rpx;
}

.quantity-btn {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #4CAF50;
  color: #fff;
  border-radius: 6rpx;
  font-size: 24rpx;
  font-weight: bold;
}

.quantity-value {
  font-size: 26rpx;
  color: #333;
  min-width: 40rpx;
  text-align: center;
}

.delete-btn {
  font-size: 32rpx;
  color: #999;
  padding: 8rpx;
}

.summary-section {
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
  border: 2rpx solid #4CAF50;
}

.summary-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #2E7D32;
  margin-bottom: 16rpx;
}

.summary-stats {
  display: flex;
  justify-content: space-around;
}

.summary-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.summary-label {
  font-size: 24rpx;
  color: #666;
}

.summary-value {
  font-size: 32rpx;
  font-weight: bold;
}

.summary-value.calories {
  color: #FF9800;
}

.summary-value.price {
  color: #455a64;
}

.summary-value.avg {
  color: #4CAF50;
}

.action-bar {
  padding: 20rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #E0E0E0;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.btn-primary {
  width: 100%;
  padding: 24rpx;
  background: #4CAF50;
  color: #fff;
  border-radius: 12rpx;
  font-size: 32rpx;
  border: none;
}

.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
  opacity: 0;
  pointer-events: none;
  transition: all 0.3s ease;
}

.modal.show {
  opacity: 1;
  pointer-events: auto;
}

.modal-content {
  width: 90%;
  max-width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  animation: modalSlideUp 0.3s ease-out;
}

@keyframes modalSlideUp {
  from {
    opacity: 0;
    transform: translateY(50rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 24rpx 24rpx;
  border-bottom: 1rpx solid #E0E0E0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  font-size: 36rpx;
  color: #999;
  padding: 8rpx;
}

.modal-body {
  padding: 24rpx;
  max-height: 60vh;
}

.modal-input {
  width: 100%;
  padding: 16rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.dish-list {
  max-height: 400rpx;
}

.modal-empty {
  padding: 40rpx 24rpx;
  font-size: 26rpx;
  color: #888;
  line-height: 1.6;
  text-align: center;
}

.dish-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx;
  margin-bottom: 12rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.dish-option.selected {
  background: #E3F2FD;
  border-color: #2196F3;
}

.dish-option-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.dish-option-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.dish-option-meta {
  display: flex;
  gap: 16rpx;
}

.dish-option-cal {
  font-size: 24rpx;
  color: #FF9800;
}

.dish-option-price {
  font-size: 24rpx;
  color: #FF5252;
}

.dish-option-check {
  font-size: 32rpx;
  color: #2196F3;
  font-weight: bold;
}

.modal-actions {
  display: flex;
  gap: 16rpx;
  padding: 24rpx;
  border-top: 1rpx solid #E0E0E0;
}

.btn-secondary {
  flex: 1;
  padding: 20rpx;
  background: #F5F5F5;
  color: #666;
  border-radius: 12rpx;
  font-size: 28rpx;
  border: none;
}

.modal-actions .btn-primary {
  flex: 1;
  padding: 20rpx;
  background: #4CAF50;
  color: #fff;
  border-radius: 12rpx;
  font-size: 28rpx;
  border: none;
}
