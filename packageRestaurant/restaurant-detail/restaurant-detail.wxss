/* pages/restaurant-detail/restaurant-detail.wxss */
.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  position: relative;
  z-index: 1;
}

.content {
  flex: 1;
  height: 0;
  box-sizing: border-box;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

.header {
  margin: 20rpx;
  padding: 0;
  overflow: hidden;
}

.header-image-wrap {
  width: 100%;
  border-radius: 16rpx;
  overflow: hidden;
  background: linear-gradient(160deg, #eceff1 0%, #f5f5f5 100%);
}

.header-image {
  width: 100%;
  height: 400rpx;
  object-fit: cover;
  background: #eceff1;
  display: block;
}

.header-image-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-sizing: border-box;
}

.header-image-placeholder-emoji {
  font-size: 72rpx;
  line-height: 1;
  opacity: 0.85;
}

.header-image-placeholder-text {
  font-size: 26rpx;
  color: #9e9e9e;
}

.header-info {
  padding: 24rpx;
}

.restaurant-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.restaurant-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  margin-bottom: 16rpx;
}

.rating {
  font-size: 28rpx;
  color: #FF9800;
}

.meta-sep {
  font-size: 28rpx;
  color: #bdbdbd;
  margin: 0 12rpx;
}

.distance {
  font-size: 28rpx;
  color: #999;
}

.health-badge {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
}

/* 健康评分卡片 */
.health-section {
  margin: 20rpx;
  padding: 32rpx 24rpx;
}

.health-score-info {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.health-score-main {
  display: flex;
  align-items: baseline;
}

.health-score-value {
  font-size: 72rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #FF6B35 0%, #FF8C42 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  line-height: 1;
}

.health-score-total {
  font-size: 32rpx;
  color: #999;
  margin-left: 8rpx;
}

.health-score-desc {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.health-tips {
  font-size: 24rpx;
  color: #666;
  max-width: 300rpx;
  text-align: right;
}

.health-indicators {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #F0F0F0;
}

.indicator-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.indicator-label {
  width: 120rpx;
  font-size: 26rpx;
  color: #666;
  flex-shrink: 0;
}

.indicator-bar {
  flex: 1;
  height: 8rpx;
  background: #E0E0E0;
  border-radius: 4rpx;
  overflow: hidden;
}

.indicator-fill {
  height: 100%;
  background: linear-gradient(90deg, #FF6B35 0%, #FF8C42 100%);
  border-radius: 4rpx;
  transition: width 0.6s ease;
}

.indicator-value {
  width: 60rpx;
  font-size: 24rpx;
  color: #999;
  text-align: right;
  flex-shrink: 0;
}

.info-section {
  margin: 20rpx;
}

.delivery-info {
  display: flex;
  gap: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #F0F0F0;
  margin-top: 16rpx;
}

.delivery-info .info-item {
  flex: 1;
  flex-direction: column;
  align-items: flex-start;
  padding: 0;
  border-bottom: none;
  gap: 8rpx;
}

.delivery-info .info-label {
  width: auto;
  font-size: 24rpx;
}

.delivery-info .info-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #FF6B35;
}

.info-item {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #E0E0E0;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  width: 160rpx;
  font-size: 28rpx;
  color: #666;
}

.info-value {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.info-action {
  font-size: 24rpx;
  color: #FF6B35;
  margin-left: 12rpx;
}

.menu-section {
  margin: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #FF6B35;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-subtitle {
  font-size: 24rpx;
  font-weight: normal;
  color: #999;
  margin-left: 16rpx;
}

.menu-list {
  display: flex;
  flex-direction: column;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  margin-bottom: 16rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
  transition: all 0.3s ease;
  animation: listItemSlideIn 0.4s ease-out;
  animation-fill-mode: both;
  position: relative;
  overflow: hidden;
}

.menu-item:nth-child(1) { animation-delay: 0.05s; }
.menu-item:nth-child(2) { animation-delay: 0.1s; }
.menu-item:nth-child(3) { animation-delay: 0.15s; }

.menu-item:active {
  transform: translateX(4rpx) scale(0.98);
  background: #FFF3E0;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 53, 0.15);
}

.menu-item::after {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 0;
  background: linear-gradient(90deg, rgba(76, 175, 80, 0.1) 0%, transparent 100%);
  transition: width 0.3s ease;
}

.menu-item:active::after {
  width: 100%;
}

.dish-info {
  flex: 1;
}

.dish-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.dish-desc {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.dish-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 8rpx;
}

.dish-cal {
  font-size: 24rpx;
  color: #FF9800;
}

.dish-price {
  font-size: 24rpx;
  color: #FF5252;
  font-weight: bold;
}

.dish-arrow {
  font-size: 32rpx;
  color: #999;
}

.action-bar {
  padding: 20rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #E0E0E0;
  display: flex;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.action-left {
  display: flex;
  align-items: center;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx;
  border-radius: 12rpx;
  transition: all 0.3s ease;
}

.action-btn:active {
  background: #F5F5F5;
  transform: scale(0.95);
}

.action-icon {
  font-size: 40rpx;
  margin-bottom: 4rpx;
}

.action-text {
  font-size: 22rpx;
  color: #666;
}

.action-right {
  flex: 1;
  display: flex;
  gap: 16rpx;
}

.order-btn {
  flex: 0 0 auto;
  min-width: 140rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.order-icon {
  font-size: 28rpx;
}

.action-right .btn-primary {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.group-icon {
  font-size: 28rpx;
}

.record-icon {
  font-size: 28rpx;
}

/* 平台选择弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.modal.show {
  opacity: 1;
  visibility: visible;
}

.modal-content {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  margin: 40rpx;
  max-width: 600rpx;
  width: 100%;
  max-height: 80vh;
  overflow-y: auto;
  transform: scale(0.9) translateY(30rpx);
  transition: all 0.3s cubic-bezier(0.68, -0.55, 0.265, 1.55);
}

.modal.show .modal-content {
  transform: scale(1) translateY(0);
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
  text-align: center;
}

.platform-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 30rpx;
}

.platform-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
  transition: all 0.3s ease;
}

.platform-item:active {
  background: #E8F5E9;
  transform: translateX(4rpx);
}

.platform-info {
  display: flex;
  align-items: center;
  flex: 1;
}

.platform-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.platform-details {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.platform-name {
  font-size: 30rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 4rpx;
}

.platform-desc {
  font-size: 24rpx;
  color: #999;
}

.platform-arrow {
  font-size: 32rpx;
  color: #999;
}

.modal-actions {
  display: flex;
  gap: 16rpx;
}

.modal-actions button {
  flex: 1;
}

/* 菜品详情弹窗 */
.dish-modal-content {
  max-width: 680rpx;
  padding: 0;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 40rpx 40rpx 30rpx;
  border-bottom: 1rpx solid #E0E0E0;
}

.modal-close {
  font-size: 36rpx;
  color: #999;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: all 0.3s ease;
}

.modal-close:active {
  background: #F5F5F5;
}

.dish-detail-content {
  padding: 30rpx 40rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.dish-detail-section {
  margin-bottom: 30rpx;
}

.dish-detail-section:last-child {
  margin-bottom: 0;
}

.dish-detail-label {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.dish-detail-value {
  font-size: 30rpx;
  color: #333;
  line-height: 1.6;
}

.price-value {
  font-size: 36rpx;
  color: #FF5252;
  font-weight: bold;
}

.nutrition-info {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.nutrition-item {
  font-size: 26rpx;
  color: #666;
  background: #F5F5F5;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.protein-ratio-info {
  margin-top: 16rpx;
}

.protein-ratio-card {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 16rpx;
  background: linear-gradient(135deg, #E3F2FD 0%, #BBDEFB 100%);
  border-radius: 12rpx;
  border: 2rpx solid #2196F3;
}

.protein-ratio-label {
  font-size: 26rpx;
  font-weight: bold;
  color: #1976D2;
}

.protein-ratio-value {
  font-size: 36rpx;
  font-weight: 800;
  color: #0D47A1;
}

.protein-ratio-desc {
  font-size: 22rpx;
  color: #1565C0;
}

/* 黑榜标记弹窗 */
.blacklist-modal {
  width: 90%;
  max-width: 600rpx;
}

.blacklist-content {
  padding: 24rpx;
}

.blacklist-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 24rpx;
}

.reasons-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.reason-option {
  padding: 12rpx 20rpx;
  background: #F5F5F5;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #666;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.reason-option.selected {
  background: #FFEBEE;
  border-color: #EF5350;
  color: #C62828;
  font-weight: bold;
}

.note-section {
  margin-top: 24rpx;
}

.note-label {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.note-input {
  width: 100%;
  min-height: 120rpx;
  padding: 26rpx 24rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
  box-sizing: border-box;
}

.blacklist-actions {
  display: flex;
  gap: 16rpx;
  padding: 24rpx;
  border-top: 1rpx solid #E0E0E0;
}

.dish-modal-actions {
  padding: 20rpx 40rpx 40rpx;
  border-top: 1rpx solid #E0E0E0;
  margin-top: 0;
}
