/* 不使用 @import tokens：组件 wxss 不能包含 tokens 中的 :root / 部分选择器，会触发告警 */
.tabbar-wrapper {
  --tabbar-glass: rgba(255, 255, 255, 0.96);
  --duration-tap: 220ms;
  --ease-tap: cubic-bezier(0.34, 1.56, 0.64, 1);
  --tabbar-active: #0f9b7a;
  --tabbar-active-bg: rgba(15, 155, 122, 0.12);
  --tabbar-active-ring: rgba(15, 155, 122, 0.14);

  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: 120rpx;
  padding-bottom: env(safe-area-inset-bottom);
  display: flex;
  justify-content: space-around;
  align-items: center;
  background: var(--tabbar-glass);
  box-shadow: 0 -1rpx 0 rgba(15, 23, 42, 0.06), 0 -16rpx 48rpx rgba(15, 23, 42, 0.04);
  border-top: 1rpx solid rgba(15, 23, 42, 0.06);
  backdrop-filter: blur(24rpx) saturate(120%);
  -webkit-backdrop-filter: blur(24rpx) saturate(120%);
  z-index: 999;
}

.tabbar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #94a3b8;
  font-size: 22rpx;
  border-radius: 20rpx;
  margin: 0 6rpx;
  padding: 8rpx 0 4rpx;
  transition:
    transform var(--duration-tap, 220ms) var(--ease-tap, cubic-bezier(0.34, 1.56, 0.64, 1)),
    background-color 0.25s ease,
    color 0.25s ease;
}

.tabbar-item:active {
  transform: scale(0.94);
}

.tabbar-item-hover {
  opacity: 0.92;
}

.tabbar-item.active {
  color: var(--tabbar-active, #0f9b7a);
  font-weight: 600;
  background: var(--tabbar-active-bg, rgba(15, 155, 122, 0.12));
  border-radius: 24rpx;
  box-shadow:
    0 0 0 1rpx var(--tabbar-active-ring, rgba(15, 155, 122, 0.14)),
    0 4rpx 20rpx rgba(15, 155, 122, 0.1);
}

.tabbar-item.active .tabbar-text {
  color: var(--tabbar-active, #0f9b7a);
  font-weight: 600;
}

/* 双图层：灰 / 绿 交叉淡化，切换 Tab 时更顺滑 */
.tabbar-icon-wrap {
  position: relative;
  width: 52rpx;
  height: 52rpx;
  margin-bottom: 4rpx;
  transition: transform var(--duration-tap, 220ms) var(--ease-tap, cubic-bezier(0.34, 1.56, 0.64, 1));
}

.tabbar-item.active .tabbar-icon-wrap {
  transform: translateY(-4rpx) scale(1.12);
}

.tabbar-icon-layer {
  position: absolute;
  left: 0;
  top: 0;
  width: 52rpx;
  height: 52rpx;
  opacity: 0;
  transition: opacity 0.26s cubic-bezier(0.4, 0, 0.2, 1);
  pointer-events: none;
}

.tabbar-icon-layer.is-on {
  opacity: 1;
}

.tabbar-lottie-canvas {
  width: 52rpx;
  height: 52rpx;
  margin-bottom: 4rpx;
}

.tabbar-text {
  font-size: 22rpx;
  color: inherit;
  transition: color 0.22s ease;
}
