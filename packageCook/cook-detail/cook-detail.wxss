/* pages/cook-detail/cook-detail.wxss */
.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  position: relative;
  z-index: 1;
}

.content {
  flex: 1;
  height: 0;
  padding-bottom: 160rpx; /* 预留底部操作栏空间，避免内容被遮挡 */
}

.header-image-wrapper {
  position: relative;
  width: 100%;
  height: 500rpx;
  overflow: hidden;
  animation: imageFadeIn 0.8s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
}

.header-image-wrapper::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(52, 211, 153, 0.1) 0%, transparent 100%);
  z-index: 1;
  pointer-events: none;
}

.header-image-wrapper::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: 
    radial-gradient(circle at 30% 30%, rgba(255, 255, 255, 0.2) 0%, transparent 50%),
    radial-gradient(circle at 70% 70%, rgba(52, 211, 153, 0.1) 0%, transparent 50%);
  z-index: 1;
  pointer-events: none;
  animation: imageOverlayShine 4s ease-in-out infinite;
}

@keyframes imageOverlayShine {
  0%, 100% {
    opacity: 0.5;
  }
  50% {
    opacity: 0.8;
  }
}

@keyframes imageFadeIn {
  from {
    opacity: 0;
    transform: scale(1.15) translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: scale(1) translateY(0);
  }
}

.header-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  flex-shrink: 0;
  background: linear-gradient(135deg, var(--color-bg-muted) 0%, var(--color-border-light) 100%);
  transition: transform 0.8s cubic-bezier(0.4, 0, 0.2, 1);
  filter: brightness(1.05) contrast(1.05);
}

.header-image-wrapper:active .header-image {
  transform: scale(1.08);
  filter: brightness(1.1) contrast(1.1);
}

.image-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 250rpx;
  background: linear-gradient(to top, rgba(0,0,0,0.5) 0%, rgba(0,0,0,0.2) 50%, transparent 100%);
  z-index: 2;
  pointer-events: none;
}

.header-info {
  margin: 20rpx;
}

.recipe-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.recipe-tags {
  display: flex;
  flex-wrap: wrap;
}

.ingredients-section,
.steps-section {
  margin: 20rpx;
  animation: sectionFadeIn 0.6s ease-out;
  animation-fill-mode: both;
}

.ingredients-section {
  animation-delay: 0.1s;
}

.steps-section {
  animation-delay: 0.2s;
}

@keyframes sectionFadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #4CAF50;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.shopping-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.section-action {
  font-size: 24rpx;
  color: #4CAF50;
  font-weight: normal;
  padding: 8rpx 16rpx;
  background: #E8F5E9;
  border-radius: 16rpx;
  transition: all 0.3s ease;
}

.section-action:active {
  background: #C8E6C9;
  transform: scale(0.95);
}

.section-action.action-all {
  color: #FF6B35;
  background: #FFF3E0;
}

.section-action.action-all:active {
  background: #FFE0B2;
}

.match-score-badge {
  font-size: 20rpx;
  color: #4CAF50;
  background: #fff;
  padding: 2rpx 8rpx;
  border-radius: 8rpx;
  margin-left: 8rpx;
  font-weight: bold;
}

.match-score-tip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 16rpx;
  background: #FFF3E0;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
  border-left: 3rpx solid #FF9800;
}

.match-score-tip .tip-icon {
  font-size: 24rpx;
}

.match-score-tip .tip-text {
  flex: 1;
  font-size: 24rpx;
  color: #F57C00;
  line-height: 1.4;
}

.ingredients-list {
  display: flex;
  flex-direction: column;
}

.ingredient-item {
  display: flex;
  align-items: flex-start;
  padding: 20rpx;
  margin-bottom: 12rpx;
  border-radius: 12rpx;
  background: #F5F5F5;
  animation: slideInRight 0.4s ease-out;
  animation-fill-mode: both;
  transition: all 0.3s ease;
}

.ingredient-item:active {
  transform: translateX(10rpx);
  background: #E8F5E9;
}

.ingredient-item:nth-child(1) { animation-delay: 0.05s; }
.ingredient-item:nth-child(2) { animation-delay: 0.1s; }
.ingredient-item:nth-child(3) { animation-delay: 0.15s; }
.ingredient-item:nth-child(4) { animation-delay: 0.2s; }
.ingredient-item:nth-child(5) { animation-delay: 0.25s; }

@keyframes slideInRight {
  from {
    opacity: 0;
    transform: translateX(30rpx);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

.ingredient-item.in-fridge {
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
  border-left: 4rpx solid #4CAF50;
  box-shadow: 
    0 2rpx 8rpx rgba(76, 175, 80, 0.15),
    inset 0 1rpx 2rpx rgba(255, 255, 255, 0.5);
}

.ingredient-item.in-fridge::before {
  content: '✓';
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: #4CAF50;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: bold;
  box-shadow: 0 2rpx 6rpx rgba(76, 175, 80, 0.3);
  animation: checkMarkPop 0.4s ease-out both;
}

@keyframes checkMarkPop {
  from {
    opacity: 0;
    transform: translateY(-50%) scale(0);
  }
  to {
    opacity: 1;
    transform: translateY(-50%) scale(1);
  }
}

.ingredient-item.missing {
  background: linear-gradient(135deg, #FFEBEE 0%, #FFCDD2 100%);
  opacity: 0.85;
  border-left: 4rpx solid #FF5252;
  box-shadow: 0 2rpx 8rpx rgba(255, 82, 82, 0.1);
}

.ingredient-item.missing::before {
  content: '!';
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: #FF5252;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: bold;
  box-shadow: 0 2rpx 6rpx rgba(255, 82, 82, 0.3);
  animation: exclamationPop 0.4s ease-out both;
}

@keyframes exclamationPop {
  from {
    opacity: 0;
    transform: translateY(-50%) scale(0) rotate(-180deg);
  }
  to {
    opacity: 1;
    transform: translateY(-50%) scale(1) rotate(0deg);
  }
}

.ingredient-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.ingredient-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.ingredient-main {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.ingredient-name {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.ingredient-amount {
  font-size: 26rpx;
  color: #999;
}

/* 替代建议样式 */
.substitute-section {
  margin-top: 8rpx;
  padding: 12rpx;
  background: #FFF9C4;
  border-radius: 8rpx;
  border-left: 3rpx solid #FFC107;
}

.substitute-label {
  font-size: 24rpx;
  color: #F57C00;
  font-weight: bold;
  margin-bottom: 8rpx;
  display: block;
}

.substitute-list {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.substitute-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
}

.substitute-name {
  color: #E65100;
  font-weight: bold;
  background: #FFE082;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.substitute-impact {
  color: #F57C00;
  font-size: 22rpx;
}

/* 步骤进度条 */
.steps-progress {
  margin-bottom: 20rpx;
  padding: 16rpx 0;
}

.progress-bar {
  height: 12rpx;
  background: #E0E0E0;
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #4CAF50, #81C784);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.progress-text {
  font-size: 24rpx;
  color: #999;
}

/* 倒计时进行中 */
.timer-running {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 20rpx;
  background: linear-gradient(135deg, #FFF3E0 0%, #FFE0B2 100%);
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  border: 2rpx solid #FF9800;
}

.timer-display {
  font-size: 36rpx;
  font-weight: bold;
  color: #E65100;
}

.timer-stop {
  font-size: 28rpx;
  color: #FF9800;
  padding: 8rpx 20rpx;
  background: #fff;
  border-radius: 20rpx;
}

.steps-list {
  display: flex;
  flex-direction: column;
}

.step-item {
  display: flex;
  margin-bottom: 30rpx;
  animation: slideInRight 0.4s ease-out;
  animation-fill-mode: both;
}

.step-item.step-done .step-text {
  color: #999;
  text-decoration: line-through;
}

.step-left {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 16rpx;
}

.step-checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #4CAF50;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
  transition: all 0.2s ease;
}

.step-checkbox.checked {
  background: #4CAF50;
}

.check-icon {
  color: #fff;
  font-size: 24rpx;
  font-weight: bold;
}

.step-body {
  flex: 1;
  display: flex;
  align-items: flex-start;
}

.step-item:nth-child(1) { animation-delay: 0.1s; }
.step-item:nth-child(2) { animation-delay: 0.15s; }
.step-item:nth-child(3) { animation-delay: 0.2s; }
.step-item:nth-child(4) { animation-delay: 0.25s; }
.step-item:nth-child(5) { animation-delay: 0.3s; }

@keyframes slideInRight {
  from {
    opacity: 0;
    transform: translateX(30rpx);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

.step-number {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4CAF50 0%, #66BB6A 50%, #81C784 100%);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  margin-right: 24rpx;
  flex-shrink: 0;
  box-shadow: 
    0 4rpx 12rpx rgba(76, 175, 80, 0.3),
    0 2rpx 6rpx rgba(0, 0, 0, 0.1),
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.3);
  position: relative;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  animation: stepNumberPop 0.5s ease-out both;
}

.step-item:nth-child(1) .step-number { animation-delay: 0.1s; }
.step-item:nth-child(2) .step-number { animation-delay: 0.15s; }
.step-item:nth-child(3) .step-number { animation-delay: 0.2s; }
.step-item:nth-child(4) .step-number { animation-delay: 0.25s; }
.step-item:nth-child(5) .step-number { animation-delay: 0.3s; }

@keyframes stepNumberPop {
  from {
    opacity: 0;
    transform: scale(0) rotate(-180deg);
  }
  to {
    opacity: 1;
    transform: scale(1) rotate(0deg);
  }
}

.step-number::before {
  content: '';
  position: absolute;
  top: -4rpx;
  left: -4rpx;
  right: -4rpx;
  bottom: -4rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(76, 175, 80, 0.3), rgba(129, 199, 132, 0.3));
  z-index: -1;
  opacity: 0;
  transition: opacity 0.3s ease;
  animation: stepNumberGlow 2s ease-in-out infinite;
}

@keyframes stepNumberGlow {
  0%, 100% {
    opacity: 0.3;
    transform: scale(1);
  }
  50% {
    opacity: 0.6;
    transform: scale(1.1);
  }
}

.step-item:active .step-number {
  transform: scale(1.1) rotate(5deg);
  box-shadow: 
    0 6rpx 16rpx rgba(76, 175, 80, 0.4),
    0 3rpx 8rpx rgba(0, 0, 0, 0.15),
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.4);
}

.step-item:active .step-number::before {
  opacity: 0.8;
}

.step-content {
  flex: 1;
  padding-top: 0;
}

.step-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 8rpx;
}

.step-time {
  font-size: 24rpx;
  color: #FF9800;
}

.step-expand-btn {
  font-size: 24rpx;
  color: #2196F3;
  padding: 4rpx 12rpx;
  background: #E3F2FD;
  border-radius: 12rpx;
}

.step-expand-btn.expanded {
  background: #BBDEFB;
}

.step-detail {
  margin-top: 12rpx;
  padding: 16rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
  border-left: 4rpx solid #4CAF50;
}

.detail-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.7;
  display: block;
}

.detail-tips {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #FF9800;
}

.step-timer-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 12rpx;
  padding: 10rpx 16rpx;
  background: #FFF3E0;
  border-radius: 12rpx;
  width: fit-content;
}

.step-timer-btn .timer-icon {
  font-size: 24rpx;
}

.step-timer-btn .timer-text {
  font-size: 24rpx;
  color: #F57C00;
}

.step-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
}

.step-item.current-step {
  background: #E3F2FD;
  border-radius: 12rpx;
  padding: 16rpx;
  border: 2rpx solid #2196F3;
}

.step-play-icon {
  font-size: 32rpx;
  margin-left: 12rpx;
  animation: voicePulse 1s ease-in-out infinite;
}

@keyframes voicePulse {
  0%, 100% {
    opacity: 1;
    transform: scale(1);
  }
  50% {
    opacity: 0.7;
    transform: scale(1.1);
  }
}

.step-timer {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 8rpx;
  padding: 8rpx 12rpx;
  background: #FFF3E0;
  border-radius: 8rpx;
}

.timer-icon {
  font-size: 24rpx;
}

.timer-text {
  font-size: 22rpx;
  color: #F57C00;
}

/* 语音助手控制 */
.voice-assistant-toggle {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  background: #E3F2FD;
  border-radius: 16rpx;
  border: 2rpx solid #2196F3;
}

.voice-icon {
  font-size: 24rpx;
}

.voice-label {
  font-size: 24rpx;
  color: #1976D2;
  font-weight: bold;
}

.voice-controls {
  display: flex;
  justify-content: space-around;
  padding: 20rpx;
  background: linear-gradient(135deg, #E3F2FD 0%, #BBDEFB 100%);
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  border: 2rpx solid #2196F3;
}

.voice-control-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  background: #fff;
  border-radius: 12rpx;
  transition: all 0.3s ease;
}

.voice-control-item:active {
  background: #BBDEFB;
  transform: scale(0.95);
}

.control-icon {
  font-size: 36rpx;
}

.control-label {
  font-size: 24rpx;
  color: #1976D2;
  font-weight: bold;
}

.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 20rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-top: 1rpx solid #E0E0E0;
  box-shadow: 0 -4rpx 16rpx rgba(15, 23, 42, 0.08);
  animation: slideInUp 0.4s ease-out;
  gap: 20rpx;
  box-sizing: border-box;
  z-index: 10;
}

@keyframes slideInUp {
  from {
    transform: translateY(100%);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

.action-left {
  display: flex;
  flex: 1;
  gap: 12rpx;
  overflow-x: auto;
}

.action-confirm {
  flex: 0 0 260rpx;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 600;
}

/* 底部次级操作：胶囊按钮风格 */
.action-pill {
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: #F5F5F7;
  color: #666;
  font-size: 24rpx;
  gap: 6rpx;
  border: 1rpx solid #E0E0E0;
}

.action-pill.favorite.active {
  background: #FFF1F2;
  border-color: #FB7185;
  color: #E11D48;
}

.action-pill.danger {
  background: #FFF7ED;
  border-color: #FED7AA;
  color: #EA580C;
}

.action-pill-icon {
  font-size: 28rpx;
}

.action-pill-text {
  font-size: 24rpx;
}

/* 弹窗样式 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s;
}

.modal.show {
  opacity: 1;
  visibility: visible;
}

.modal-content {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  margin: 40rpx;
  max-width: 600rpx;
  width: 100%;
  transform: scale(0.9);
  transition: transform 0.3s;
}

.modal.show .modal-content {
  transform: scale(1);
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
  text-align: center;
}

.portion-options {
  margin-bottom: 30rpx;
}

.portion-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border: 2rpx solid #E0E0E0;
  border-radius: 12rpx;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  animation: slideInRight 0.3s ease-out;
  animation-fill-mode: both;
}

.portion-item:nth-child(1) { animation-delay: 0.05s; }
.portion-item:nth-child(2) { animation-delay: 0.1s; }
.portion-item:nth-child(3) { animation-delay: 0.15s; }

.portion-item.active {
  border-color: #4CAF50;
  background: #E8F5E9;
  transform: scale(1.02);
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.2);
}

@keyframes slideInRight {
  from {
    opacity: 0;
    transform: translateX(30rpx);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

.portion-label {
  font-size: 32rpx;
  color: #333;
}

.portion-cal {
  font-size: 28rpx;
  color: #999;
}

.modal-actions {
  display: flex;
  gap: 20rpx;
}

.modal-actions button {
  flex: 1;
}

.deduct-list {
  margin-bottom: 30rpx;
  padding: 20rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
}

/* 营养信息 */
.nutrition-section {
  margin: 20rpx;
  animation: sectionFadeIn 0.6s ease-out;
  animation-delay: 0.15s;
  animation-fill-mode: both;
}

.nutrition-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.nutrition-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  background: linear-gradient(135deg, #F5F5F5 0%, #E8F5E9 100%);
  border-radius: 16rpx;
  transition: all 0.3s ease;
}

.nutrition-item:active {
  transform: scale(0.95);
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
}

.nutrition-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #4CAF50;
  margin-bottom: 8rpx;
}

.nutrition-label {
  font-size: 24rpx;
  color: #666;
}

/* 成本对比 */
.cost-comparison {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 24rpx;
  background: linear-gradient(135deg, #FFF3E0 0%, #FFE0B2 100%);
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.cost-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.cost-label {
  font-size: 24rpx;
  color: #666;
}

.cost-value {
  font-size: 48rpx;
  font-weight: 800;
  color: #E65100;
}

.home-cost .cost-value {
  color: #4CAF50;
}

.takeout-cost .cost-value {
  color: #FF5252;
}

.cost-desc {
  font-size: 22rpx;
  color: #999;
}

.cost-arrow {
  font-size: 36rpx;
  color: #FF9800;
  font-weight: bold;
}

.saved-amount {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 16rpx;
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
  border-radius: 12rpx;
  border: 2rpx solid #4CAF50;
}

.saved-icon {
  font-size: 32rpx;
}

.saved-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #2E7D32;
}

.saved-desc {
  font-size: 22rpx;
  color: #4CAF50;
}

/* 小贴士 */
.tips-section {
  margin: 20rpx;
  animation: sectionFadeIn 0.6s ease-out;
  animation-delay: 0.2s;
  animation-fill-mode: both;
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tip-item {
  display: flex;
  align-items: flex-start;
  padding: 16rpx;
  background: linear-gradient(135deg, #FFF9C4 0%, #FFF59D 100%);
  border-radius: 12rpx;
  border-left: 4rpx solid #FFC107;
  animation: slideInRight 0.4s ease-out;
  animation-fill-mode: both;
}

.tip-item:nth-child(1) { animation-delay: 0.05s; }
.tip-item:nth-child(2) { animation-delay: 0.1s; }
.tip-item:nth-child(3) { animation-delay: 0.15s; }

.tip-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.tip-text {
  flex: 1;
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

/* 相关推荐 */
.related-section {
  margin: 20rpx;
  animation: sectionFadeIn 0.6s ease-out;
  animation-delay: 0.25s;
  animation-fill-mode: both;
}

.related-scroll {
  white-space: nowrap;
}

.related-list {
  display: inline-flex;
  gap: 20rpx;
  padding: 0 0 20rpx 0;
}

.related-item {
  display: inline-flex;
  flex-direction: column;
  width: 200rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
}

.related-item:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.related-image {
  width: 100%;
  height: 150rpx;
  object-fit: cover;
  background: linear-gradient(135deg, #F5F5F5 0%, #E0E0E0 100%);
}

.related-name {
  padding: 12rpx;
  font-size: 26rpx;
  color: #333;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.related-cal {
  padding: 0 12rpx 12rpx;
  font-size: 22rpx;
  color: #FF6F00;
}
