/* pages/ingredient-recognize/ingredient-recognize.wxss */
.container {
  padding: 20rpx;
  min-height: 100vh;
  background: #F5F5F5;
  padding-bottom: calc(100rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.image-section {
  margin-bottom: 30rpx;
}

.image-wrapper {
  position: relative;
  border-radius: 20rpx;
  overflow: hidden;
  background: #fff;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.preview-image {
  width: 100%;
  height: 500rpx;
  display: block;
}

.scanning-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(4rpx);
}

.scanning-text {
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
}

.result-section {
  margin-bottom: 30rpx;
}

.result-card {
  animation: resultSlideIn 0.5s ease-out;
}

@keyframes resultSlideIn {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.ingredient-header {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #E0E0E0;
}

.ingredient-icon {
  font-size: 80rpx;
  margin-right: 20rpx;
  animation: iconBounce 0.6s ease-out;
}

@keyframes iconBounce {
  0% {
    transform: scale(0);
  }
  50% {
    transform: scale(1.2);
  }
  100% {
    transform: scale(1);
  }
}

.ingredient-info {
  flex: 1;
}

.ingredient-name {
  font-size: 40rpx;
  font-weight: 800;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.ingredient-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.ingredient-category {
  font-size: 24rpx;
  color: #666;
  background: #F0F0F0;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.confidence-badge {
  font-size: 22rpx;
  color: #4CAF50;
  background: #E8F5E9;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}

.section-title::before {
  content: '';
  width: 6rpx;
  height: 24rpx;
  background: linear-gradient(135deg, #4CAF50 0%, #2196F3 100%);
  border-radius: 3rpx;
  margin-right: 12rpx;
}

.nutrition-section {
  margin-bottom: 30rpx;
  padding-bottom: 30rpx;
  border-bottom: 1rpx solid #E0E0E0;
}

.nutrition-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.nutrition-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  background: #F8F9FA;
  border-radius: 12rpx;
}

.nutrition-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.nutrition-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
}

.functions-section {
  margin-bottom: 30rpx;
  padding-bottom: 30rpx;
  border-bottom: 1rpx solid #E0E0E0;
}

.functions-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.function-item {
  display: flex;
  align-items: flex-start;
  padding: 16rpx;
  background: #F8F9FA;
  border-radius: 12rpx;
}

.function-icon {
  color: #4CAF50;
  font-size: 24rpx;
  margin-right: 12rpx;
  margin-top: 4rpx;
}

.function-text {
  flex: 1;
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.tips-section {
  margin-bottom: 30rpx;
  padding-bottom: 30rpx;
  border-bottom: 1rpx solid #E0E0E0;
}

.tips-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
  padding: 16rpx;
  background: #F8F9FA;
  border-radius: 12rpx;
}

.cooking-tips-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.cooking-tip {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  padding: 12rpx 16rpx;
  background: #F8F9FA;
  border-radius: 12rpx;
  border-left: 4rpx solid #4CAF50;
}

.action-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.action-buttons button {
  flex: 1;
}

.loading-section {
  margin-top: 100rpx;
}

.loading-card {
  text-align: center;
  padding: 60rpx 40rpx;
}

.loading-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 20rpx;
  animation: loadingPulse 2s ease-in-out infinite;
}

@keyframes loadingPulse {
  0%, 100% {
    transform: scale(1);
    opacity: 1;
  }
  50% {
    transform: scale(1.1);
    opacity: 0.7;
  }
}

.loading-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
}

.loading-hint {
  font-size: 24rpx;
  color: #999;
}

/* 模态框样式 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.modal.show {
  opacity: 1;
  visibility: visible;
}

.modal-content {
  width: 85%;
  max-width: 600rpx;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  transform: scale(0.9);
  transition: transform 0.3s ease;
}

.modal.show .modal-content {
  transform: scale(1);
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #E0E0E0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

.modal-close {
  font-size: 36rpx;
  color: #999;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-body {
  padding: 30rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 16rpx;
}

.form-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.form-input {
  width: 100%;
  min-height: 88rpx;
  padding: 26rpx 24rpx;
  background: #F8F9FA;
  border-radius: 12rpx;
  font-size: 30rpx;
  line-height: 1.5;
  box-sizing: border-box;
}

.unit-selector {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.unit-option {
  padding: 16rpx 32rpx;
  background: #F8F9FA;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #666;
  transition: all 0.3s ease;
}

.unit-option.active {
  background: linear-gradient(135deg, #4CAF50 0%, #2196F3 100%);
  color: #fff;
  font-weight: 600;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 30rpx;
  border-top: 1rpx solid #E0E0E0;
}

.modal-footer button {
  flex: 1;
}

/* 通用样式 */
.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.btn-primary {
  background: linear-gradient(135deg, #4CAF50 0%, #2196F3 100%);
  color: #fff;
  border: none;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.btn-secondary {
  background: #F8F9FA;
  color: #666;
  border: none;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
}

button[disabled] {
  opacity: 0.5;
}
