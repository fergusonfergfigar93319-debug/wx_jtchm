<!--pages/challenge/challenge.wxml-->
<view class="container page-container">
  <!-- 顶部提醒开关 -->
  <view class="reminder-bar">
    <text class="reminder-text">每日提醒</text>
    <switch 
      class="reminder-switch" 
      checked="{{reminderEnabled}}" 
      bindchange="toggleReminder"
      color="#FF6B35"
    />
  </view>

  <!-- 标签栏 -->
  <view class="tabs">
    <view 
      class="tab {{currentTab === index ? 'active' : ''}}"
      wx:for="{{tabs}}" 
      wx:key="index"
      data-index="{{index}}"
      bindtap="switchTab"
    >
      {{item}}
    </view>
  </view>

  <!-- 进行中的挑战 -->
  <view class="challenge-list" wx:if="{{currentTab === 0}}">
    <view 
      class="challenge-card active"
      wx:for="{{activeChallenges}}" 
      wx:key="id"
      data-challenge="{{item}}"
      bindtap="viewDetail"
    >
      <view class="challenge-header">
        <text class="challenge-icon">{{item.icon}}</text>
        <view class="challenge-info">
          <text class="challenge-name">{{item.name}}</text>
          <text class="challenge-desc">{{item.description}}</text>
        </view>
      </view>
      <view class="challenge-progress">
        <view class="progress-bar">
          <view 
            class="progress-fill" 
            style="width: {{myProgress[item.id] ? ((myProgress[item.id].currentDays || 0) / item.duration * 100) : 0}}%"
          ></view>
        </view>
        <text class="progress-text">
          {{myProgress[item.id] ? myProgress[item.id].currentDays : 0}} / {{item.duration}} 天
        </text>
      </view>
      <view class="challenge-reward">
        <text class="reward-label">奖励：</text>
        <text class="reward-points">+{{item.reward.points}}积分</text>
        <text class="reward-badge">{{item.reward.badgeIcon}} {{item.reward.badge}}</text>
      </view>
      <view class="challenge-actions">
        <view class="action-btn check-btn" catchtap="checkProgress" data-challenge="{{item}}">检查进度</view>
        <view class="action-btn abandon-btn" catchtap="abandonChallenge" data-challenge="{{item}}">退出</view>
      </view>
    </view>

    <view class="empty-state" wx:if="{{activeChallenges.length === 0}}">
      <text class="empty-icon">🎯</text>
      <text class="empty-text">暂无进行中的挑战</text>
      <text class="empty-hint">去"可加入"标签页看看有什么挑战吧~</text>
    </view>
  </view>

  <!-- 可加入的挑战 -->
  <view class="challenge-list" wx:if="{{currentTab === 1}}">
    <view 
      class="challenge-card"
      wx:for="{{availableChallenges}}" 
      wx:key="id"
      data-challenge="{{item}}"
      bindtap="joinChallenge"
    >
      <view class="challenge-header">
        <text class="challenge-icon">{{item.icon}}</text>
        <view class="challenge-info">
          <text class="challenge-name">{{item.name}}</text>
          <text class="challenge-desc">{{item.description}}</text>
        </view>
      </view>
      <view class="challenge-duration">
        <text class="duration-label">挑战时长：</text>
        <text class="duration-value">{{item.duration}}天</text>
      </view>
      <view class="challenge-reward">
        <text class="reward-label">奖励：</text>
        <text class="reward-points">+{{item.reward.points}}积分</text>
        <text class="reward-badge">{{item.reward.badgeIcon}} {{item.reward.badge}}</text>
      </view>
      <view class="join-btn">立即加入</view>
    </view>

    <view class="empty-state" wx:if="{{availableChallenges.length === 0}}">
      <text class="empty-icon">🎉</text>
      <text class="empty-text">太棒了！所有挑战都已完成</text>
      <view class="join-btn" bindtap="resetChallenges">重置挑战</view>
    </view>
  </view>

  <!-- 已完成的挑战 -->
  <view class="challenge-list" wx:if="{{currentTab === 2}}">
    <view 
      class="challenge-card completed"
      wx:for="{{completedChallenges}}" 
      wx:key="id"
      data-challenge="{{item}}"
      bindtap="viewDetail"
    >
      <view class="challenge-header">
        <text class="challenge-icon">{{item.icon}}</text>
        <view class="challenge-info">
          <text class="challenge-name">{{item.name}}</text>
          <text class="challenge-desc">{{item.description}}</text>
        </view>
        <text class="completed-badge">✓ 已完成</text>
      </view>
      <view class="challenge-reward">
        <text class="reward-label">已获得：</text>
        <text class="reward-points">+{{item.reward.points}}积分</text>
        <text class="reward-badge">{{item.reward.badgeIcon}} {{item.reward.badge}}</text>
      </view>
    </view>

    <view class="empty-state" wx:if="{{completedChallenges.length === 0}}">
      <text class="empty-icon">📋</text>
      <text class="empty-text">暂无已完成的挑战</text>
      <text class="empty-hint">完成挑战可以获得积分和徽章哦~</text>
    </view>
  </view>

  <!-- 加入挑战确认弹窗 -->
  <view class="modal {{showJoinModal ? 'show' : ''}}" bindtap="cancelJoin">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">加入挑战</text>
        <text class="modal-close" bindtap="cancelJoin">×</text>
      </view>
      <view class="modal-body" wx:if="{{selectedChallenge}}">
        <view class="challenge-preview">
          <text class="preview-icon">{{selectedChallenge.icon}}</text>
          <text class="preview-name">{{selectedChallenge.name}}</text>
          <text class="preview-desc">{{selectedChallenge.description}}</text>
        </view>
        <view class="reward-preview">
          <text class="preview-label">完成奖励：</text>
          <text class="preview-reward">
            +{{selectedChallenge.reward.points}}积分 + {{selectedChallenge.reward.badgeIcon}} {{selectedChallenge.reward.badge}}
          </text>
        </view>
      </view>
      <view class="modal-actions">
        <view class="modal-btn cancel" bindtap="cancelJoin">取消</view>
        <view class="modal-btn confirm" bindtap="confirmJoin">确认加入</view>
      </view>
    </view>
  </view>
</view>