/* pages/challenge-detail/challenge-detail.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
}

.loading-container {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100vh;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

.content {
  padding: 30rpx;
}

/* 挑战头部 */
.challenge-header {
  background: linear-gradient(135deg, #ff9f66 0%, #ff6b35 45%, #ffb347 100%);
  border-radius: 28rpx;
  padding: 40rpx 30rpx 34rpx;
  margin-bottom: 26rpx;
  text-align: left;
  box-shadow: 0 10rpx 26rpx rgba(255, 107, 53, 0.35);
  color: #fff;
  position: relative;
  overflow: hidden;
}

.challenge-icon {
  font-size: 100rpx;
  display: block;
  margin-bottom: 20rpx;
}

.challenge-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  display: block;
  margin-bottom: 12rpx;
}

.challenge-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.88);
  line-height: 1.7;
  display: block;
}

/* 通用卡片 */
.card {
  background: white;
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

/* 元信息/标签 */
.meta-row {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-top: 26rpx;
  flex-wrap: wrap;
}

.meta-chip {
  background: rgba(255, 255, 255, 0.12);
  border: 1rpx solid rgba(255, 255, 255, 0.24);
  border-radius: 999rpx;
  padding: 10rpx 18rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.meta-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
}

.meta-value {
  font-size: 24rpx;
  color: #ffe1d0;
  font-weight: 600;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  justify-content: center;
  margin-top: 18rpx;
}

.tag {
  font-size: 22rpx;
  color: #666;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #f6f6f6;
}

/* 列表样式 */
.bullet-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.bullet-item {
  display: flex;
  gap: 14rpx;
  align-items: flex-start;
}

.bullet-dot {
  color: #FF6B35;
  font-size: 30rpx;
  line-height: 1.2;
}

.bullet-index {
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  background: #fff3e0;
  color: #FF6B35;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 600;
  flex: 0 0 auto;
}

.bullet-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.7;
  flex: 1;
}

/* 适合人群 pill */
.pill-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.pill {
  font-size: 24rpx;
  color: #333;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #f7fbff;
  border: 1rpx solid rgba(74, 144, 226, 0.18);
}

/* 建议卡片 */
.tips-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.tip-item {
  background: #fafafa;
  border-radius: 16rpx;
  padding: 22rpx;
  border: 1rpx solid #f0f0f0;
}

.tip-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.tip-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.tip-content {
  font-size: 26rpx;
  color: #666;
  line-height: 1.7;
}

/* 示例计划 */
.plan-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.plan-item {
  display: flex;
  gap: 16rpx;
  background: #f9fbff;
  border: 1rpx solid rgba(74, 144, 226, 0.14);
  border-radius: 16rpx;
  padding: 22rpx;
}

.plan-left {
  width: 120rpx;
  flex: 0 0 auto;
}

.plan-day {
  display: inline-block;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(74, 144, 226, 0.12);
  color: #2f6bb2;
  font-size: 22rpx;
  font-weight: 600;
}

.plan-right {
  flex: 1;
}

.plan-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 6rpx;
}

.plan-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.7;
  display: block;
}

/* FAQ */
.faq-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.faq-item {
  background: #fafafa;
  border: 1rpx solid #f0f0f0;
  border-radius: 16rpx;
  padding: 22rpx;
}

.faq-q, .faq-a {
  display: flex;
  gap: 12rpx;
  align-items: flex-start;
}

.faq-q {
  margin-bottom: 10rpx;
}

.faq-q-prefix {
  width: 40rpx;
  height: 40rpx;
  border-radius: 10rpx;
  background: rgba(255, 107, 53, 0.12);
  color: #FF6B35;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
}

.faq-a-prefix {
  width: 40rpx;
  height: 40rpx;
  border-radius: 10rpx;
  background: rgba(76, 175, 80, 0.12);
  color: #4CAF50;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
}

.faq-q-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  font-weight: 600;
  flex: 1;
}

.faq-a-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.7;
  flex: 1;
}

/* 进度展示 */
.progress-section {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 30rpx 26rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 14rpx rgba(0, 0, 0, 0.05);
}

.progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.progress-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
}

.progress-days {
  font-size: 28rpx;
  color: #FF6B35;
  font-weight: 500;
}

.progress-bar-wrapper {
  margin-bottom: 20rpx;
}

.progress-bar {
  height: 16rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 10rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #FF6B35 0%, #FF8C5A 100%);
  transition: width 0.5s ease;
  border-radius: 8rpx;
}

.progress-percent {
  font-size: 24rpx;
  color: #999;
  text-align: right;
  display: block;
}

.progress-dates {
  display: flex;
  justify-content: space-between;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.date-item {
  font-size: 24rpx;
  color: #999;
}

/* 完成状态 */
.completed-section {
  background: linear-gradient(135deg, #4CAF50 0%, #45a049 100%);
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  margin-bottom: 30rpx;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.3);
}

.completed-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 20rpx;
}

.completed-text {
  font-size: 36rpx;
  font-weight: 600;
  color: white;
  display: block;
  margin-bottom: 10rpx;
}

.completed-date {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  display: block;
}

/* 章节标题 */
.section-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
}

/* 挑战要求 */
.requirements-section {
  background: white;
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.requirements-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.requirement-item {
  display: flex;
  align-items: center;
  gap: 15rpx;
}

.requirement-icon {
  font-size: 28rpx;
  color: #4CAF50;
  font-weight: 600;
}

.requirement-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  flex: 1;
}

/* 每日记录 */
.daily-records-section {
  background: white;
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.daily-records-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.daily-record-item {
  padding: 20rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
  border-left: 4rpx solid #ddd;
}

.daily-record-item.completed {
  background: #f0f9f4;
  border-left-color: #4CAF50;
}

.daily-record-item.pending {
  background: #fff9e6;
  border-left-color: #ffc107;
}

.record-date {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.date-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.status-icon {
  font-size: 32rpx;
  color: #4CAF50;
  font-weight: 600;
}

.status-icon.pending {
  color: #ffc107;
}

.record-data {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 8rpx;
}

.data-label {
  font-size: 24rpx;
  color: #999;
}

.data-value {
  font-size: 24rpx;
  color: #666;
  font-weight: 500;
}

/* 奖励展示 */
.reward-section {
  background: linear-gradient(135deg, #fff3e0 0%, #ffe0b2 100%);
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 183, 77, 0.2);
}

.reward-content {
  display: flex;
  gap: 30rpx;
  justify-content: center;
}

.reward-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.reward-icon {
  font-size: 50rpx;
}

.reward-text {
  font-size: 28rpx;
  color: #FF6B35;
  font-weight: 500;
}

/* 操作按钮 */
.action-buttons {
  padding: 30rpx 0;
}

.btn-primary {
  width: 100%;
  padding: 28rpx;
  background: linear-gradient(135deg, #FF6B35 0%, #FF8C5A 100%);
  color: white;
  text-align: center;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 53, 0.3);
}

.btn-group {
  display: flex;
  gap: 20rpx;
}

.btn-secondary {
  flex: 1;
  padding: 28rpx;
  background: white;
  color: #FF6B35;
  text-align: center;
  border-radius: 16rpx;
  font-size: 28rpx;
  border: 2rpx solid #FF6B35;
}

.btn-danger {
  flex: 1;
  padding: 28rpx;
  background: white;
  color: #f44336;
  text-align: center;
  border-radius: 16rpx;
  font-size: 28rpx;
  border: 2rpx solid #f44336;
}

.btn-completed {
  width: 100%;
  padding: 28rpx;
  background: #e0e0e0;
  color: #999;
  text-align: center;
  border-radius: 16rpx;
  font-size: 28rpx;
}
