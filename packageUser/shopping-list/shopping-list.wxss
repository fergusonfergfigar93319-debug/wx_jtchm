/* pages/shopping-list/shopping-list.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* 头部统计 */
.header {
  background: linear-gradient(135deg, #FF6B35 0%, #FF8C5A 100%);
  padding: 40rpx 30rpx;
  color: white;
}

.stats {
  display: flex;
  justify-content: space-around;
  align-items: center;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-label {
  font-size: 24rpx;
  opacity: 0.9;
  margin-bottom: 10rpx;
}

.stat-value {
  font-size: 48rpx;
  font-weight: bold;
}

.stat-value.price {
  color: #FFD700;
}

.stat-value.platform {
  font-size: 32rpx;
  background: rgba(255, 255, 255, 0.2);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

/* 工具栏 */
.toolbar {
  background: white;
  padding: 20rpx 30rpx;
  margin-bottom: 20rpx;
}

.filter-tabs {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.filter-tab {
  padding: 10rpx 24rpx;
  background: #f5f5f5;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #666;
}

.filter-tab.active {
  background: #FF6B35;
  color: white;
}

.sort-options {
  display: flex;
  gap: 20rpx;
}

.sort-option {
  padding: 8rpx 20rpx;
  font-size: 24rpx;
  color: #999;
  border-bottom: 2rpx solid transparent;
}

.sort-option.active {
  color: #FF6B35;
  border-bottom-color: #FF6B35;
}

/* 购物清单列表 */
.list-container {
  padding: 0 30rpx;
}

.shopping-item {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.item-info {
  flex: 1;
}

.item-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 10rpx;
}

.item-details {
  display: flex;
  gap: 20rpx;
  font-size: 24rpx;
  color: #999;
}

.item-price {
  color: #FF6B35;
  font-weight: 500;
}

.item-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.compare-btn {
  background: #f0f0f0;
  color: #666;
}

.delete-btn {
  background: #ffebee;
  color: #f44336;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  display: block;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
  display: block;
  margin-bottom: 10rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #ccc;
  display: block;
}

.empty-go-cook {
  margin-top: 40rpx;
  padding: 24rpx 40rpx;
  background: linear-gradient(135deg, #FFF3E0 0%, #FFE0B2 100%);
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  border: 2rpx solid #FFB74D;
}

.empty-go-cook:active {
  opacity: 0.9;
}

.empty-go-cook-icon {
  font-size: 36rpx;
}

.empty-go-cook-text {
  font-size: 28rpx;
  color: #E65100;
  font-weight: 600;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 20rpx;
  box-shadow: 0 -2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.bottom-btn {
  flex: 1;
  padding: 24rpx;
  text-align: center;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.bottom-btn.secondary {
  background: #f5f5f5;
  color: #666;
}

.bottom-btn.primary {
  background: #FF6B35;
  color: white;
}

/* 弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: none;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal.show {
  display: flex;
}

.modal-content {
  background: white;
  border-radius: 24rpx;
  width: 90%;
  max-height: 80vh;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.modal-header {
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
}

.modal-close {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
}

/* 比价列表 */
.compare-list {
  padding: 30rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.compare-item {
  background: #f9f9f9;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.compare-item.best {
  background: #fff3e0;
  border: 2rpx solid #FF6B35;
}

.platform-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.platform-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
}

.platform-badge {
  background: #FF6B35;
  color: white;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
}

.platform-price,
.platform-delivery,
.platform-total {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10rpx;
  font-size: 26rpx;
}

.price-label,
.delivery-label,
.total-label {
  color: #999;
}

.price-value,
.delivery-value {
  color: #666;
}

.total-value {
  color: #FF6B35;
  font-weight: 500;
  font-size: 32rpx;
}

.platform-btn {
  margin-top: 20rpx;
  padding: 20rpx;
  background: #FF6B35;
  color: white;
  text-align: center;
  border-radius: 8rpx;
  font-size: 28rpx;
}

/* 添加表单 */
.add-form {
  padding: 30rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

.form-input {
  width: 100%;
  min-height: 88rpx;
  padding: 26rpx 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 30rpx;
  line-height: 1.5;
  box-sizing: border-box;
}

.category-selector {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.category-option {
  padding: 12rpx 24rpx;
  background: #f5f5f5;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #666;
}

.category-option.active {
  background: #FF6B35;
  color: white;
}

.unit-selector {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.unit-option {
  padding: 12rpx 24rpx;
  background: #f5f5f5;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #666;
}

.unit-option.active {
  background: #FF6B35;
  color: white;
}

.form-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}

.form-btn {
  flex: 1;
  padding: 24rpx;
  text-align: center;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.form-btn.cancel {
  background: #f5f5f5;
  color: #666;
}

.form-btn.confirm {
  background: #FF6B35;
  color: white;
}