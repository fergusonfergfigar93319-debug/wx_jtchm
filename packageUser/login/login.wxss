/* packageUser/login/login.wxss — 登录主题动效：清新绿 / 一餐一会 / 与全站 Neo 一致 */

.container.login-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #ecfdf5 0%, #f8fafc 38%, #ffffff 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 72rpx 48rpx 60rpx;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}

/* 整页淡入 */
.login-page-shell {
  animation: login-shell-fade 0.55s cubic-bezier(0.22, 1, 0.36, 1) both;
}

@keyframes login-shell-fade {
  from {
    opacity: 0;
  }

  to {
    opacity: 1;
  }
}

/* 背景装饰层 */
.login-decor {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 0;
  overflow: hidden;
}

.login-orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(0);
}

.login-orb--a {
  width: 520rpx;
  height: 520rpx;
  top: -12%;
  right: -25%;
  background: radial-gradient(circle at 40% 40%, rgba(52, 211, 153, 0.22) 0%, rgba(52, 211, 153, 0) 70%);
  animation: login-orb-drift 14s ease-in-out infinite;
}

.login-orb--b {
  width: 420rpx;
  height: 420rpx;
  bottom: 8%;
  left: -30%;
  background: radial-gradient(circle at 50% 50%, rgba(96, 165, 250, 0.14) 0%, rgba(96, 165, 250, 0) 68%);
  animation: login-orb-drift 18s ease-in-out infinite reverse;
}

@keyframes login-orb-drift {
  0%,
  100% {
    transform: translate(0, 0) scale(1);
    opacity: 1;
  }

  50% {
    transform: translate(20rpx, 16rpx) scale(1.05);
    opacity: 0.85;
  }
}

.login-leaf {
  position: absolute;
  font-size: 40rpx;
  opacity: 0.35;
  animation: login-leaf-float 6s ease-in-out infinite;
}

.login-leaf--1 {
  top: 18%;
  left: 8%;
  animation-delay: 0s;
}

.login-leaf--2 {
  bottom: 22%;
  right: 10%;
  font-size: 36rpx;
  animation-delay: 1.2s;
}

@keyframes login-leaf-float {
  0%,
  100% {
    transform: translateY(0) rotate(0deg);
    opacity: 0.28;
  }

  50% {
    transform: translateY(-20rpx) rotate(8deg);
    opacity: 0.45;
  }
}

.content {
  width: 100%;
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  position: relative;
  z-index: 1;
}

/* 品牌区：上浮 + 轻微缩放入场 */
.login-brand-card {
  animation: login-brand-enter 0.78s cubic-bezier(0.22, 1, 0.36, 1) 0.06s both;
}

@keyframes login-brand-enter {
  from {
    opacity: 0;
    transform: translateY(48rpx) scale(0.96);
  }

  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

.brand-card {
  margin-top: 56rpx;
  padding: 48rpx 32rpx 40rpx;
  border-radius: 32rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.95) 0%, rgba(240, 253, 244, 0.55) 100%);
  border: 1rpx solid rgba(52, 211, 153, 0.12);
  box-shadow:
    0 4rpx 6rpx rgba(15, 23, 42, 0.03),
    0 20rpx 48rpx rgba(52, 211, 153, 0.1);
}

.brand {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.logo-wrap {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 40rpx;
  background: linear-gradient(145deg, #4cd9a1 0%, #2dd4bf 48%, #22c55e 100%);
  box-shadow: 0 20rpx 40rpx rgba(34, 197, 94, 0.28);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
  animation: login-logo-breathe 3.6s ease-in-out infinite;
}

@keyframes login-logo-breathe {
  0%,
  100% {
    transform: translateY(0);
    box-shadow: 0 20rpx 40rpx rgba(34, 197, 94, 0.28);
  }

  50% {
    transform: translateY(-10rpx);
    box-shadow: 0 20rpx 48rpx rgba(34, 197, 94, 0.38);
  }
}

.logo-shine {
  position: absolute;
  top: 4rpx;
  left: 8%;
  width: 56%;
  height: 38%;
  border-radius: 999rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.45) 0%, rgba(255, 255, 255, 0) 100%);
  pointer-events: none;
}

.logo-icon {
  font-size: 88rpx;
  line-height: 1;
  display: block;
  animation: login-icon-wiggle 4.5s ease-in-out infinite;
}

@keyframes login-icon-wiggle {
  0%,
  100% {
    transform: translateY(0) rotate(0deg);
  }

  35% {
    transform: translateY(-4rpx) rotate(-4deg);
  }

  70% {
    transform: translateY(2rpx) rotate(3deg);
  }
}

.app-name {
  font-size: 48rpx;
  font-weight: 700;
  color: #0f172a;
  letter-spacing: 2rpx;
  margin-bottom: 16rpx;
}

.slogan {
  font-size: 28rpx;
  color: #64748b;
}

.slogan.sub {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #94a3b8;
}

.tag-row {
  margin-top: 32rpx;
  display: flex;
  flex-direction: row;
  justify-content: center;
  flex-wrap: wrap;
  gap: 16rpx;
}

.feature-tag {
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(52, 211, 153, 0.12);
  color: #047857;
  font-size: 22rpx;
  font-weight: 500;
}

.feature-tag.soft {
  background: rgba(251, 191, 36, 0.1);
  color: #b45309;
}

/* 登录区入场 */
.login-section-anim {
  animation: login-section-enter 0.72s cubic-bezier(0.22, 1, 0.36, 1) 0.2s both;
}

@keyframes login-section-enter {
  from {
    opacity: 0;
    transform: translateY(28rpx);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.login-section {
  margin-top: 72rpx;
  width: 100%;
}

.btn-wx-login {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #4cd9a1 0%, #2dd4bf 48%, #22c55e 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 32rpx rgba(34, 197, 94, 0.28);
  position: relative;
  overflow: hidden;
  transition: transform 0.2s ease, opacity 0.2s ease;
}

.btn-wx-login::after {
  border: none;
}

.btn-wx-login[disabled] {
  opacity: 0.88;
}

/* 登录中：光带扫过 */
.btn-wx-login.is-processing::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(
    105deg,
    transparent 0%,
    rgba(255, 255, 255, 0.35) 45%,
    rgba(255, 255, 255, 0.15) 55%,
    transparent 100%
  );
  animation: login-btn-shimmer 1.2s ease-in-out infinite;
}

@keyframes login-btn-shimmer {
  0% {
    transform: translateX(-120%);
  }

  100% {
    transform: translateX(120%);
  }
}

.is-logging .btn-wx-login {
  box-shadow: 0 8rpx 24rpx rgba(34, 197, 94, 0.2);
}

.btn-icon {
  margin-right: 16rpx;
  font-size: 40rpx;
}

.btn-text {
  font-size: 32rpx;
  color: #ffffff;
  position: relative;
  z-index: 1;
}

.login-tip {
  margin-top: 28rpx;
  text-align: center;
  font-size: 26rpx;
  color: #94a3b8;
  line-height: 1.5;
}

.dev-channel-row {
  margin-top: 36rpx;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  background: rgba(251, 191, 36, 0.12);
  border: 1rpx dashed rgba(217, 119, 6, 0.35);
}

.dev-channel-text {
  font-size: 24rpx;
  color: #b45309;
  line-height: 1.45;
  text-align: center;
}

/* 协议区入场 */
.login-agreement-anim {
  animation: login-agreement-enter 0.65s ease-out 0.38s both;
}

@keyframes login-agreement-enter {
  from {
    opacity: 0;
    transform: translateY(16rpx);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.agreement {
  position: absolute;
  bottom: 60rpx;
  left: 48rpx;
  right: 48rpx;
  text-align: center;
  font-size: 24rpx;
  color: #94a3b8;
}

.agreement-link {
  color: #10b981;
  font-weight: 500;
}

/* ========== 登录成功：涟漪 + 勾选弹出 ========== */
.login-success-overlay {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(248, 250, 252, 0.96);
  animation: login-success-overlay-fade 0.4s ease-out forwards;
}

@keyframes login-success-overlay-fade {
  from {
    opacity: 0;
  }

  to {
    opacity: 1;
  }
}

.login-success-panel {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 44rpx 52rpx 48rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.98);
  border: 1rpx solid rgba(52, 211, 153, 0.18);
  box-shadow: 0 24rpx 56rpx rgba(15, 23, 42, 0.08);
  animation: login-success-panel-fade 0.5s cubic-bezier(0.22, 1, 0.36, 1) 0.05s both;
}

@keyframes login-success-panel-fade {
  from {
    opacity: 0;
    transform: translateY(24rpx) scale(0.96);
  }

  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

.login-success-visual {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-success-ripple {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 120rpx;
  height: 120rpx;
  margin-left: -60rpx;
  margin-top: -60rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(52, 211, 153, 0.45);
  animation: login-ripple-out 1.6s ease-out infinite;
}

.login-success-ripple--2 {
  animation-delay: 0.45s;
  border-color: rgba(96, 165, 250, 0.35);
}

@keyframes login-ripple-out {
  0% {
    transform: scale(0.75);
    opacity: 0.85;
  }

  100% {
    transform: scale(1.55);
    opacity: 0;
  }
}

.login-success-icon-wrap {
  position: relative;
  z-index: 2;
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, rgba(52, 211, 153, 0.2) 0%, rgba(45, 212, 191, 0.12) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(52, 211, 153, 0.25);
}

.login-success-check {
  font-size: 48rpx;
  color: #059669;
  font-weight: 700;
  line-height: 1;
  animation: login-check-pop 0.55s cubic-bezier(0.34, 1.56, 0.64, 1) 0.12s both;
}

@keyframes login-check-pop {
  from {
    transform: scale(0);
    opacity: 0;
  }

  to {
    transform: scale(1);
    opacity: 1;
  }
}

.login-success-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 12rpx;
}

.login-success-sub {
  font-size: 26rpx;
  color: #64748b;
}
