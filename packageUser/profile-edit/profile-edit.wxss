/* pages/profile-edit/profile-edit.wxss */
.container {
  padding-bottom: calc(60rpx + env(safe-area-inset-bottom));
  min-height: 100vh;
  background: #F5F5F5;
  box-sizing: border-box;
}

.section-card {
  margin: 20rpx;
  padding: 30rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  animation: fadeInUp 0.45s ease-out both;
}

.section-card:nth-child(1) { animation-delay: 0.04s; }
.section-card:nth-child(2) { animation-delay: 0.10s; }
.section-card:nth-child(3) { animation-delay: 0.16s; }

.card-header {
  margin-bottom: 30rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.avatar-section-hint {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: #94a3b8;
  margin: 20rpx 0 8rpx;
  line-height: 1.45;
}

.default-avatar-block {
  margin-top: 28rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #f1f5f9;
}

.default-avatar-label {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #334155;
  margin-bottom: 16rpx;
}

.default-avatar-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx 24rpx;
}

.default-avatar-cell {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 8rpx;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  background: #f8fafc;
  transition: border-color 0.2s ease,
              background 0.2s ease,
              transform var(--duration-tap, 220ms) var(--ease-tap, cubic-bezier(0.34, 1.56, 0.64, 1)),
              box-shadow 0.2s ease;
}

.default-avatar-cell:active {
  transform: scale(0.94);
}

.default-avatar-cell.is-selected {
  border-color: #10b981;
  background: #ecfdf5;
  transform: scale(1.06);
  box-shadow: 0 0 0 6rpx rgba(16, 185, 129, 0.15), 0 6rpx 18rpx rgba(16, 185, 129, 0.2);
}

.default-avatar-thumb-wrap {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 2rpx solid #e2e8f0;
  background: #fff;
}

.default-avatar-cell.is-selected .default-avatar-thumb-wrap {
  border-color: #34d399;
}

.default-avatar-img {
  width: 100%;
  height: 100%;
  display: block;
}

.default-avatar-name {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #64748b;
  text-align: center;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.avatar-edit {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  margin: 0 auto;
  border-radius: 50%;
  overflow: hidden;
}

.avatar-preview {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.avatar-icon {
  font-size: 120rpx;
  opacity: 0.8;
}

.avatar-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.3s;
}

.avatar-edit:active .avatar-mask {
  opacity: 1;
}

.avatar-text {
  color: #fff;
  font-size: 28rpx;
}

.avatar-loading {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}

.loading-spinner {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.form-list {
  display: flex;
  flex-direction: column;
}

.form-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #E0E0E0;
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  width: 200rpx;
  font-size: 28rpx;
  color: #333;
  flex-shrink: 0;
}

.form-input {
  flex: 1;
  min-height: 88rpx;
  padding: 26rpx 24rpx;
  font-size: 30rpx;
  color: #333;
  text-align: right;
  line-height: 1.5;
  box-sizing: border-box;
}

.form-item-signature {
  flex-direction: column;
  align-items: stretch;
  padding-top: 30rpx;
}

.form-item-signature-row {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  width: 100%;
}

.signature-preview-block {
  margin-top: 16rpx;
  padding-left: 200rpx;
  box-sizing: border-box;
}

.signature-preview-hint {
  display: block;
  font-size: 22rpx;
  color: #94a3b8;
  margin-bottom: 10rpx;
  line-height: 1.4;
}

.signature-preview-inner {
  display: flex;
  flex-direction: row;
  align-items: stretch;
  gap: 14rpx;
  padding: 16rpx 18rpx;
  border-radius: 16rpx;
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.92) 0%, #f1f5f9 55%, #eef2f7 100%);
  border: 1rpx solid rgba(15, 23, 42, 0.07);
  box-shadow: 0 2rpx 12rpx rgba(15, 23, 42, 0.04);
  box-sizing: border-box;
}

.signature-preview-accent {
  width: 6rpx;
  min-height: 40rpx;
  align-self: stretch;
  border-radius: 6rpx;
  background: linear-gradient(180deg, #5eead4 0%, #38bdf8 45%, #22c55e 100%);
  flex-shrink: 0;
}

.signature-preview-text {
  flex: 1;
  min-width: 0;
  font-size: 24rpx;
  color: #475569;
  line-height: 1.7;
  word-break: break-word;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 4;
  overflow: hidden;
}

.form-textarea {
  flex: 1;
  min-height: 120rpx;
  max-height: 240rpx;
  padding: 26rpx 24rpx;
  font-size: 30rpx;
  color: #333;
  text-align: right;
  line-height: 1.5;
  box-sizing: border-box;
}

.picker-view {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.picker-text {
  font-size: 28rpx;
  color: #333;
  margin-right: 12rpx;
}

.picker-arrow {
  font-size: 32rpx;
  color: #999;
}

.save-button-container {
  padding: 40rpx 20rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.save-button {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #4CAF50 0%, #45a049 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 44rpx;
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.3);
}

.save-button:active {
  opacity: 0.8;
  transform: scale(0.98);
}
